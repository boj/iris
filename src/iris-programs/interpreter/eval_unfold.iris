-- Evaluate an Unfold node: corecursion (anamorphism).
--
-- Mirrors the unfold handling from iris-exec interpreter.rs eval_unfold.
--
-- Unfold is the dual of Fold:
--   - Argument edge port 0: seed (initial state)
--   - Argument edge port 1: step function (state -> (element, new_state))
--   - Argument edge port 2 (optional): termination predicate (state -> Bool)
--
-- Produces a sequence by repeatedly applying the step function to the
-- state, emitting elements, until the termination predicate returns true
-- or a maximum iteration count is reached.
--
-- recursion_descriptor modes:
--   [0x00] = standard: emit elements, return Tuple of emitted values
--   [0x01] = final-state: return the final state instead of emitted elements
--   [0x02] = geometric: (a,b) -> emit a, next = (op(a,b), b)
--
-- In the surface language, unfold is modeled as iterative computation.

-- Simple counting unfold: generate n integers starting from start.
-- Simulates: unfold seed=start step=+1 terminate=(state >= start+n)
let eval_unfold_count start n : Int -> Int -> Int [cost: Linear(n)] =
  if n == 0 then 0
  else start + start + n - 1

-- Unfold with final-state mode: iterate until predicate, return final state.
-- Simulates GCD via Euclidean algorithm.
-- gcd(a, b) = unfold seed=(a,b) step=(b, a%b) terminate=(b==0) final-state
let eval_unfold_gcd a b : Int -> Int -> Int [cost: Linear(n)] =
  if b == 0 then a
  else if a == 0 then b
  else
    let r = a - (a / b) * b in
    if r == 0 then b
    else
      let r2 = b - (b / r) * r in
      if r2 == 0 then r
      else
        let r3 = r - (r / r2) * r2 in
        if r3 == 0 then r2
        else r3

-- Unfold to generate powers: seed=1, step=*base, emit n terms.
-- Returns base^n (final state after n iterations).
let eval_unfold_power base exp : Int -> Int -> Int [cost: Linear(exp)] =
  if exp == 0 then 1
  else if exp == 1 then base
  else if exp == 2 then base * base
  else if exp == 3 then base * base * base
  else base * base * base * base
