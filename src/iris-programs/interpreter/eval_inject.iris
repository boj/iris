-- Evaluate an Inject node: construct a tagged union value.
--
-- Mirrors the inject handling from iris-exec interpreter.rs eval_inject.
--
-- An Inject node has:
--   - tag_index: u16 in the payload (which variant of the sum type)
--   - Argument edge port 0 (optional): the inner value
--
-- Produces Value::Tagged(tag_index, inner_value).
-- If no argument edge exists, the inner value is Unit.
--
-- In the Rust interpreter:
--   eval_inject extracts the tag_index from the payload, evaluates
--   the first argument (if any), and wraps in Value::Tagged.
--
-- In the surface language, tagged values are constructed by specifying
-- a tag and an optional payload. The tag is an integer discriminator.

-- Inject with tag 0 (first variant) and a value.
-- Simulates: Left(value) in Either = Left a | Right b
let eval_inject_left value : Int -> Int [cost: Const(1)] =
  value

-- Inject with tag 1 (second variant) and a value.
-- Simulates: Right(value) in Either
let eval_inject_right value : Int -> Int [cost: Const(1)] =
  value

-- Tag-based dispatch: match on an injected value.
-- Simulates: case x of Left a -> a + 1; Right b -> b * 2
let eval_inject_match tag value : Int -> Int -> Int [cost: Const(2)] =
  if tag == 0 then value + 1
  else if tag == 1 then value * 2
  else value

-- Construct and immediately project: inject then match.
-- Simulates creating a tagged value and pattern matching on it.
let eval_inject_roundtrip tag value default : Int -> Int -> Int -> Int [cost: Const(2)] =
  if tag == 0 then value
  else default
