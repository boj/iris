-- Evaluate a Prim node: dispatch on opcode to the appropriate operation.
--
-- Mirrors the opcode dispatch from iris-exec interpreter_impl.rs eval_prim.
--
-- The Rust interpreter has ~200 opcodes organized in groups:
--   0x00-0x0F: Arithmetic (add, sub, mul, div, mod, neg, abs, min, max, pow)
--   0x10-0x19: Bitwise (and, or, xor, not, shl, shr, rotl, rotr, popcount, clz)
--   0x20-0x25: Comparison (eq, ne, lt, gt, le, ge)
--   0x30-0x3F: Higher-order (map, filter, zip, take, drop, concat, reverse, flat_map)
--   0x40-0x44: Type conversion (int_to_float, float_to_int, widen, narrow, bool_to_int)
--   0x50-0x55: State (get, set, update, keys, merge, empty)
--   0x60-0x63: Channel (send, recv, try_recv, pending)
--   0x70-0x7B: Knowledge graph (12 ops)
--   0x80-0x8F: Self-modification (16 ops -- requires graph_eval delegation)
--   0x90-0x95: Concurrency (6 ops -- requires Rust runtime)
--   0xA0:      Meta-evolution (requires Rust runtime)
--   0xB0-0xBF: String (16 ops)
--   0xC0:      Extended string (char_at)
--   0xC1-0xC7: List (7 ops)
--   0xC8-0xCD: Map (6 ops)
--   0xD0-0xD3: JSON (4 ops)
--   0xD8-0xE3: Math (12 ops)
--   0xE4-0xE5: Time (2 ops)
--   0xE6-0xE8: Bytes (3 ops)
--   0xE9-0xEB: Lazy lists (3 ops -- requires graph_eval delegation)
--
-- Strategy: For opcodes that can be computed in pure IRIS (arithmetic,
-- bitwise, comparison, type conversion), implement them natively.
-- For opcodes that require Rust runtime (channels, concurrency,
-- meta-evolution, self-modification, lazy thunks), delegate to graph_eval.
--
-- This file implements the core dispatch. Each opcode group has a
-- dedicated helper function.

-- === ARITHMETIC (0x00-0x09) ===
-- These are the most commonly used opcodes in evolved programs.

-- Full arithmetic dispatch: given opcode and two operands, compute result.
-- Covers add(0x00), sub(0x01), mul(0x02), div(0x03), mod(0x04),
-- neg(0x05, unary), abs(0x06, unary), min(0x07), max(0x08), pow(0x09).
let eval_prim_arith op a b : Int -> Int -> Int -> Int [cost: Const(3)] =
  if op == 0 then a + b
  else if op == 1 then a - b
  else if op == 2 then a * b
  else if op == 3 then
    if b == 0 then 0  -- division by zero returns 0 (safe fallback)
    else a / b
  else if op == 4 then
    if b == 0 then 0  -- mod by zero returns 0
    else a - (a / b) * b
  else if op == 5 then 0 - a  -- neg (unary, b ignored)
  else if op == 6 then        -- abs (unary, b ignored)
    if a < 0 then 0 - a else a
  else if op == 7 then        -- min
    if a < b then a else b
  else if op == 8 then        -- max
    if a > b then a else b
  else if op == 9 then        -- pow(a, b) via repeated squaring
    -- Handles all non-negative exponents correctly for i64.
    -- Repeated squaring unrolled: 6 steps handles exponents up to 63,
    -- which is the maximum meaningful exponent for i64 values.
    -- For b < 0, returns 0 (integer truncation of fractional result).
    if b < 0 then 0
    else if b == 0 then 1
    else
      -- Repeated squaring: extract bits of b from LSB to MSB.
      -- bit_i = (b / pow2_i) - (b / pow2_i / 2) * 2 (extract bit i)
      -- We accumulate: result *= base^(2^i) when bit i is set.
      -- base^(2^i) is computed by squaring the previous base.
      let r0 = 1 in
      let b0 = b - (b / 2) * 2 in   -- bit 0
      let r1 = if b0 == 1 then r0 * a else r0 in
      let s1 = a * a in              -- a^2
      let e1 = b / 2 in
      if e1 == 0 then r1
      else
        let b1 = e1 - (e1 / 2) * 2 in  -- bit 1
        let r2 = if b1 == 1 then r1 * s1 else r1 in
        let s2 = s1 * s1 in            -- a^4
        let e2 = e1 / 2 in
        if e2 == 0 then r2
        else
          let b2 = e2 - (e2 / 2) * 2 in  -- bit 2
          let r3 = if b2 == 1 then r2 * s2 else r2 in
          let s3 = s2 * s2 in            -- a^8
          let e3 = e2 / 2 in
          if e3 == 0 then r3
          else
            let b3 = e3 - (e3 / 2) * 2 in  -- bit 3
            let r4 = if b3 == 1 then r3 * s3 else r3 in
            let s4 = s3 * s3 in            -- a^16
            let e4 = e3 / 2 in
            if e4 == 0 then r4
            else
              let b4 = e4 - (e4 / 2) * 2 in  -- bit 4
              let r5 = if b4 == 1 then r4 * s4 else r4 in
              let s5 = s4 * s4 in            -- a^32
              let e5 = e4 / 2 in
              if e5 == 0 then r5
              else
                let b5 = e5 - (e5 / 2) * 2 in  -- bit 5
                let r6 = if b5 == 1 then r5 * s5 else r5 in
                r6
  else -9999

-- === BITWISE (0x10-0x19) ===
-- Bitwise operations on integers.
-- 0x10 = bitand, 0x11 = bitor, 0x12 = bitxor, 0x13 = bitnot (unary),
-- 0x14 = shl, 0x15 = shr, 0x16 = rotl, 0x17 = rotr,
-- 0x18 = popcount (unary), 0x19 = clz (unary)
--
-- SHL and SHR are implemented natively using arithmetic:
--   shl(a, n) = a * pow(2, n)
--   shr(a, n) = a / pow(2, n)
-- AND, OR, XOR, NOT, rotl, rotr, popcount, clz delegate to graph_eval
-- because they require true bit manipulation not expressible with +,-,*,/.

-- Helper: compute 2^n for n in [0, 63] using repeated squaring.
-- Same algorithm as pow() in eval_prim_arith but hardcoded base=2.
let pow2 n : Int -> Int [cost: Const(10)] =
  if n < 0 then 0
  else if n == 0 then 1
  else if n == 1 then 2
  else if n == 2 then 4
  else if n == 3 then 8
  else if n == 4 then 16
  else if n == 5 then 32
  else if n == 6 then 64
  else if n == 7 then 128
  else if n == 8 then 256
  else if n == 9 then 512
  else if n == 10 then 1024
  else if n == 11 then 2048
  else if n == 12 then 4096
  else if n == 13 then 8192
  else if n == 14 then 16384
  else if n == 15 then 32768
  else if n == 16 then 65536
  else
    -- For n > 16, compute using repeated doubling from known base.
    -- pow2(16) = 65536, then double (n-16) more times.
    -- We unroll up to 47 more steps (total 63).
    let base = 65536 in
    let rem = n - 16 in
    let r1 = if rem > 0 then base * 2 else base in
    let r2 = if rem > 1 then r1 * 2 else r1 in
    let r3 = if rem > 2 then r2 * 2 else r2 in
    let r4 = if rem > 3 then r3 * 2 else r3 in
    let r5 = if rem > 4 then r4 * 2 else r4 in
    let r6 = if rem > 5 then r5 * 2 else r5 in
    let r7 = if rem > 6 then r6 * 2 else r6 in
    let r8 = if rem > 7 then r7 * 2 else r7 in
    let r9 = if rem > 8 then r8 * 2 else r8 in
    let r10 = if rem > 9 then r9 * 2 else r9 in
    let r11 = if rem > 10 then r10 * 2 else r10 in
    let r12 = if rem > 11 then r11 * 2 else r11 in
    let r13 = if rem > 12 then r12 * 2 else r12 in
    let r14 = if rem > 13 then r13 * 2 else r13 in
    let r15 = if rem > 14 then r14 * 2 else r14 in
    let r16 = if rem > 15 then r15 * 2 else r15 in
    let r17 = if rem > 16 then r16 * 2 else r16 in
    let r18 = if rem > 17 then r17 * 2 else r17 in
    let r19 = if rem > 18 then r18 * 2 else r18 in
    let r20 = if rem > 19 then r19 * 2 else r19 in
    let r21 = if rem > 20 then r20 * 2 else r20 in
    let r22 = if rem > 21 then r21 * 2 else r21 in
    let r23 = if rem > 22 then r22 * 2 else r22 in
    let r24 = if rem > 23 then r23 * 2 else r23 in
    let r25 = if rem > 24 then r24 * 2 else r24 in
    let r26 = if rem > 25 then r25 * 2 else r25 in
    let r27 = if rem > 26 then r26 * 2 else r26 in
    let r28 = if rem > 27 then r27 * 2 else r27 in
    let r29 = if rem > 28 then r28 * 2 else r28 in
    let r30 = if rem > 29 then r29 * 2 else r29 in
    let r31 = if rem > 30 then r30 * 2 else r30 in
    r31

let eval_prim_bitwise program inputs op a b : Program -> Tuple -> Int -> Int -> Int -> Int [cost: Const(8)] =
  -- SHL: a * pow(2, b)
  if op == 20 then a * pow2 b
  -- SHR: a / pow(2, b) -- integer division (arithmetic shift for positive a)
  else if op == 21 then
    let p = pow2 b in
    if p == 0 then 0
    else a / p
  -- AND, OR, XOR, NOT, rotl, rotr, popcount, clz: delegate to Rust
  else graph_eval program inputs

-- === COMPARISON (0x20-0x25) ===
-- Return 1 for true, 0 for false (Int encoding of Bool).
-- 0x20 = eq, 0x21 = ne, 0x22 = lt, 0x23 = gt, 0x24 = le, 0x25 = ge

let eval_prim_cmp op a b : Int -> Int -> Int -> Int [cost: Const(2)] =
  if op == 32 then      -- 0x20 eq
    if a == b then 1 else 0
  else if op == 33 then  -- 0x21 ne
    if a == b then 0 else 1
  else if op == 34 then  -- 0x22 lt
    if a < b then 1 else 0
  else if op == 35 then  -- 0x23 gt
    if a > b then 1 else 0
  else if op == 36 then  -- 0x24 le
    if a < b then 1
    else if a == b then 1
    else 0
  else if op == 37 then  -- 0x25 ge
    if a > b then 1
    else if a == b then 1
    else 0
  else 0

-- === TYPE CONVERSION (0x40-0x44) ===
-- KNOWN LIMITATION: widen (0x42) and narrow (0x43) are identity operations.
--
-- The bootstrap evaluator cannot distinguish between Int32/Int64/Float32/Float64
-- at runtime -- all integer values are i64 and all float values are f64.
-- Therefore widen (e.g. i32 -> i64) and narrow (e.g. i64 -> i32) both return
-- the input unchanged. This is correct for pure Int programs, but programs that
-- depend on precision truncation (e.g. narrowing i64 to i32 and checking for
-- overflow) will not get the expected behavior.
--
-- This limitation will be resolved when IRIS gains a proper type-tagged value
-- representation (Phase Transition 1 requirement).
--
-- 0x40 = int_to_float: identity in Int-only world (no float distinction)
-- 0x41 = float_to_int: identity in Int-only world
-- 0x42 = widen: identity (KNOWN LIMITATION: no precision distinction, see above)
-- 0x43 = narrow: identity (KNOWN LIMITATION: no precision truncation, see above)
-- 0x44 = bool_to_int: normalizes to 0/1

let eval_prim_convert op a : Int -> Int -> Int [cost: Const(1)] =
  if op == 64 then a       -- 0x40 int_to_float: identity for Ints
  else if op == 65 then a  -- 0x41 float_to_int: identity for Ints
  else if op == 66 then a  -- 0x42 widen: identity (see KNOWN LIMITATION above)
  else if op == 67 then a  -- 0x43 narrow: identity (see KNOWN LIMITATION above)
  else if op == 68 then    -- 0x44 bool_to_int
    if a == 0 then 0 else 1
  else a

-- === HIGHER-ORDER (0x30-0x36, 0x39) ===
-- These require function references and collection manipulation.
-- They must delegate to graph_eval because IRIS surface syntax cannot
-- yet express higher-order function application over collections.
--
-- 0x30 = map, 0x31 = filter, 0x32 = zip, 0x33 = take, 0x34 = drop,
-- 0x35 = concat, 0x36 = reverse, 0x39 = flat_map
--
-- The Rust interpreter evaluates arg0 as collection, arg1 as function
-- reference (lazy), and applies the function element-wise.

let eval_prim_higher_order program inputs : Program -> Tuple -> Value [cost: Unknown] =
  graph_eval program inputs

-- === STATE (0x50-0x55) ===
-- State operations require mutable StateStore threading, which is
-- handled by the Rust interpreter. Delegate to graph_eval.
-- 0x50 = state_get, 0x51 = state_set, 0x52 = state_update,
-- 0x53 = state_keys, 0x54 = state_merge, 0x55 = state_empty

let eval_prim_state program inputs : Program -> Tuple -> Value [cost: Const(2)] =
  graph_eval program inputs

-- === CHANNEL (0x60-0x63) ===
-- Channel operations require the MessageBus runtime.
-- Must delegate to Rust. 0x60 = send, 0x61 = recv,
-- 0x62 = try_recv, 0x63 = pending

let eval_prim_channel program inputs : Program -> Tuple -> Value [cost: Const(2)] =
  graph_eval program inputs

-- === KNOWLEDGE GRAPH (0x70-0x7B) ===
-- KG operations manipulate Value::Graph structures.
-- These could theoretically be implemented in IRIS using State-based
-- adjacency lists, but the Rust implementation uses dedicated KnowledgeGraph
-- types. Delegate to graph_eval.

let eval_prim_kg program inputs : Program -> Tuple -> Value [cost: Unknown] =
  graph_eval program inputs

-- === SELF-MODIFICATION (0x80-0x8F) ===
-- These are the most important opcodes for IRIS self-hosting: they let
-- programs introspect and modify their own SemanticGraph. They MUST
-- delegate to graph_eval because they operate on the graph representation
-- itself, which is only accessible from the Rust runtime.
--
-- 0x80 = self_graph, 0x81 = sg_nodes, 0x82 = sg_get_kind,
-- 0x83 = sg_get_prim_op, 0x84 = sg_set_prim_op, 0x85 = sg_add_node_rt,
-- 0x86 = sg_connect, 0x87 = sg_disconnect, 0x88 = sg_replace_subtree,
-- 0x89 = sg_eval, 0x8A = sg_get_root, 0x8B = sg_add_guard_rt,
-- 0x8C = sg_add_ref_rt, 0x8D = sg_set_cost, 0x8E = sg_get_lit_value,
-- 0x8F = sg_outgoing

let eval_prim_self_mod program inputs : Program -> Tuple -> Value [cost: Unknown] =
  graph_eval program inputs

-- === CONCURRENCY (0x90-0x95) ===
-- Thread spawning and parallel execution require the Rust runtime.
-- 0x90 = par_eval, 0x91 = par_map, 0x92 = par_fold,
-- 0x93 = spawn, 0x94 = await_future, 0x95 = par_zip_with

let eval_prim_concurrency program inputs : Program -> Tuple -> Value [cost: Unknown] =
  graph_eval program inputs

-- === META-EVOLUTION (0xA0) ===
-- Requires the MetaEvolver runtime.

let eval_prim_meta_evolve program inputs : Program -> Tuple -> Value [cost: Unknown] =
  graph_eval program inputs

-- === STRING (0xB0-0xBF) ===
-- String operations work on Value::String. Since IRIS surface syntax has
-- limited string support, most of these delegate to graph_eval.
-- However, length and comparison can be handled natively for programs
-- that encode strings as integer sequences.
--
-- 0xB0 = str_len, 0xB1 = str_concat, 0xB2 = str_slice,
-- 0xB3 = str_contains, 0xB4 = str_split, 0xB5 = str_join,
-- 0xB6 = str_to_int, 0xB7 = int_to_str, 0xB8 = str_eq,
-- 0xB9 = str_starts_with, 0xBA = str_ends_with, 0xBB = str_replace,
-- 0xBC = str_trim, 0xBD = str_upper, 0xBE = str_lower,
-- 0xBF = str_chars

let eval_prim_string program inputs : Program -> Tuple -> Value [cost: Unknown] =
  graph_eval program inputs

-- === LIST (0xC1-0xC7) ===
-- List operations on Tuples. These could be partially implemented
-- in IRIS, but require tuple construction/destruction.
-- 0xC1 = list_append, 0xC2 = list_nth, 0xC3 = list_take,
-- 0xC4 = list_drop, 0xC5 = list_sort, 0xC6 = list_dedup,
-- 0xC7 = list_range

let eval_prim_list program inputs : Program -> Tuple -> Value [cost: Unknown] =
  graph_eval program inputs

-- === MAP (0xC8-0xCD) ===
-- Map operations on State (BTreeMap). Delegate to graph_eval.
-- 0xC8 = map_insert, 0xC9 = map_get, 0xCA = map_remove,
-- 0xCB = map_keys, 0xCC = map_values, 0xCD = map_size

let eval_prim_map program inputs : Program -> Tuple -> Value [cost: Unknown] =
  graph_eval program inputs

-- === JSON (0xD0-0xD3) — REMOVED ===
-- json_parse (0xD0), json_stringify (0xD1), json_array_len (0xD3) have been
-- removed from the substrate. Programs that need JSON must implement parsing
-- in IRIS using string operations (see src/iris-programs/stdlib/json.iris).
-- 0xD2 is now tuple_get (get field from tuple by key or index).
-- Only tuple_get remains; it is dispatched via eval_prim_list or the
-- master dispatch (opcode 210 decimal = 0xD2).

let eval_prim_tuple_get program inputs : Program -> Tuple -> Value [cost: Const(2)] =
  graph_eval program inputs

-- === MATH (0xD8-0xE3) ===
-- Transcendental math functions require floating-point. Some can be
-- approximated in IRIS with integer arithmetic.
-- 0xD8 = sqrt, 0xD9 = log, 0xDA = exp, 0xDB = sin, 0xDC = cos,
-- 0xDD = floor, 0xDE = ceil, 0xDF = round, 0xE0 = pi, 0xE1 = e,
-- 0xE2 = random_int, 0xE3 = random_float

-- Integer square root via Newton's method (for Int-only programs)
let eval_prim_isqrt n : Int -> Int [cost: Const(48)] =
  if n < 0 then 0
  else if n == 0 then 0
  else if n == 1 then 1
  else
    -- Newton's method: x_{n+1} = (x_n + n / x_n) / 2
    -- Starting from n/2, 12 iterations converge for all i64 values.
    let guess = n / 2 in
    let g1 = (guess + n / guess) / 2 in
    let g2 = (g1 + n / g1) / 2 in
    let g3 = (g2 + n / g2) / 2 in
    let g4 = (g3 + n / g3) / 2 in
    let g5 = (g4 + n / g4) / 2 in
    let g6 = (g5 + n / g5) / 2 in
    let g7 = (g6 + n / g6) / 2 in
    let g8 = (g7 + n / g7) / 2 in
    let g9 = (g8 + n / g8) / 2 in
    let g10 = (g9 + n / g9) / 2 in
    let g11 = (g10 + n / g10) / 2 in
    let g12 = (g11 + n / g11) / 2 in
    g12

-- Integer floor/ceil/round for Int-only programs are identity
let eval_prim_math_int op a : Int -> Int -> Int [cost: Const(1)] =
  if op == 221 then a   -- 0xDD floor: identity for Int
  else if op == 222 then a  -- 0xDE ceil: identity for Int
  else if op == 223 then a  -- 0xDF round: identity for Int
  else a

-- Full math dispatch (delegates to graph_eval for transcendentals)
let eval_prim_math program inputs : Program -> Tuple -> Value [cost: Unknown] =
  graph_eval program inputs

-- === TIME (0xE4-0xE5) ===
-- Time formatting requires clock access. Delegate to graph_eval.
-- 0xE4 = time_format, 0xE5 = time_parse

let eval_prim_time program inputs : Program -> Tuple -> Value [cost: Const(2)] =
  graph_eval program inputs

-- === BYTES (0xE6-0xE8) ===
-- Byte buffer operations. Delegate to graph_eval.
-- 0xE6 = bytes_from_ints, 0xE7 = bytes_concat, 0xE8 = bytes_len

let eval_prim_bytes program inputs : Program -> Tuple -> Value [cost: Unknown] =
  graph_eval program inputs

-- === LAZY LISTS (0xE9-0xEB) ===
-- Lazy list operations require Thunk values. Delegate to graph_eval.
-- 0xE9 = lazy_unfold, 0xEA = thunk_force, 0xEB = lazy_take

let eval_prim_lazy program inputs : Program -> Tuple -> Value [cost: Unknown] =
  graph_eval program inputs

-- === MASTER DISPATCH ===
-- Route an opcode to the correct group handler.
-- For opcodes that can be computed natively in IRIS (arithmetic,
-- bitwise shl/shr, comparison, type conversion, math int ops),
-- compute directly. For all others, delegate to graph_eval.

let eval_prim program inputs op a b : Program -> Tuple -> Int -> Int -> Int -> Value [cost: Const(5)] =
  -- Arithmetic: 0x00-0x09 (0-9 decimal)
  if op < 10 then eval_prim_arith op a b
  -- Bitwise: 0x10-0x19 (16-25 decimal) -- shl/shr native, rest delegated
  else if op > 15 then
    if op < 26 then eval_prim_bitwise program inputs op a b
    -- Comparison: 0x20-0x25 (32-37 decimal)
    else if op > 31 then
      if op < 38 then eval_prim_cmp op a b
      -- Higher-order: 0x30-0x3F (48-63 decimal)
      else if op > 47 then
        if op < 64 then graph_eval program inputs
        -- Conversion: 0x40-0x44 (64-68 decimal)
        else if op < 69 then eval_prim_convert op a
        -- Math: 0xD8-0xE3 (216-227 decimal) -- sqrt, floor, ceil, round native
        else if op > 215 then
          if op < 228 then
            -- sqrt (0xD8 = 216): use IRIS native isqrt
            if op == 216 then eval_prim_isqrt a
            -- floor/ceil/round (0xDD-0xDF = 221-223): identity for Int
            else if op > 220 then
              if op < 224 then eval_prim_math_int op a
              else graph_eval program inputs
            else graph_eval program inputs
          else graph_eval program inputs
        -- All remaining opcodes delegate to graph_eval
        else graph_eval program inputs
      else graph_eval program inputs
    else graph_eval program inputs
  else graph_eval program inputs
