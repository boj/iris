-- Complete IRIS lowerer: AST -> (Program, SourceMap)
-- Returns a tuple of (Program, source_map_list) where source_map_list
-- contains (node_id, start_pos, end_pos) tuples.
-- Type inference is applied to the Program via graph_set_node_type.
-- Cost bounds from [cost: ...] annotations are applied via graph_set_cost.
-- Uses fold-based stack machine with cons-cell stacks.
-- Stack depths tracked by integer counters (nsp/wsp) to avoid
-- comparing Tuples to Int which causes type errors.
--
-- Capability declarations (allow/deny) from ast.1 are encoded as a
-- hub Lit node (type_tag=0, value=n_caps) attached to root via port 127.
-- Each entry is a Lit node (packed int) connected to the hub at port 0..n.

-- lower: main entry point for AST -> (Program, SourceMap)
-- ast layout: (kind=40 Module, cap_info, items_list)
-- items_list: list of LetDecl/TypeDecl/ImportDecl/AllowDecl/DenyDecl nodes
-- The last LetDecl in items_list is treated as the program entry point.
--
-- Returns (program, source_map) where program is a SemanticGraph and
-- source_map is a list of (node_id, start_pos, end_pos) tuples.
let lower ast src =
  let mt = list_range 0 0 in
  let cap_info = ast.1 in
  let items = ast.2 in
  let n_items = list_len items in

  if n_items == 0 then (graph_new, mt)
  else
    let entry = list_nth items (n_items - 1) in
    let params = (entry.2).0 in
    let raw_body = (entry.2).1 in
    let n_params = list_len params in

    -- Multi-function chaining: wrap ALL earlier LetDecl items as nested
    -- let-in bindings around the entry point's body. This makes helper
    -- functions defined in earlier top-level lets available in the last one.
    --   let a x = x*2       =>  let body = let a = \x -> x*2 in
    --   let b y = a y + 1        let b = \y -> a y + 1 in
    --   let main n = b n          b n
    -- Process items n-2..0 (reverse order) so first item is outermost let.
    let body_ast = if n_items <= 1 then raw_body
      else fold raw_body
        (\wrapped idx ->
          let rev_idx = n_items - 2 - idx in
          if rev_idx < 0 then wrapped
          else
            let prior = list_nth items rev_idx in
            if prior.0 != 30 then wrapped
            else
              let prior_name = prior.1 in
              let prior_params = (prior.2).0 in
              let prior_body = (prior.2).1 in
              let n_pp = list_len prior_params in
              let is_rec = if prior_name >= 2147483648 then 1 else 0 in
              let clean_name = if is_rec == 1 then prior_name - 2147483648 else prior_name in
              -- TCO: for tail-recursive functions with pattern
              --   let rec f args = if cond then base else f new_args
              -- Compile as a trampoline fold instead of a recursive Lambda.
              -- The fold state is (done_flag, arg_tuple). Each iteration either
              -- returns (1, result) [done] or (0, new_args) [continue].
              let value_ast = if is_rec == 1 then
                if n_pp >= 1 then
                  -- Build trampoline: fold (0, arg0, arg1, ...) step 1000000
                  -- Step function checks the body, returns (1, result) or (0, new_args)
                  -- For now, wrap as a curried lambda that uses fold internally.
                  -- The recursive call f(x) becomes updating the accumulator.
                  -- This is complex AST surgery; for now use the simple lambda approach
                  -- and rely on the stdlib/tco.iris helpers for deep recursion.
                  fold prior_body
                    (\inner j ->
                      let rj = n_pp - 1 - j in
                      if rj < 0 then inner
                      else
                        let ph = (list_nth prior_params rj).1 in
                        (13, ph, list_append mt inner, 0))
                    n_pp
                else prior_body
              else if n_pp == 0 then prior_body
              else
                fold prior_body
                  (\inner j ->
                    let rj = n_pp - 1 - j in
                    if rj < 0 then inner
                    else
                      let ph = (list_nth prior_params rj).1 in
                      (13, ph, list_append mt inner, 0))
                  n_pp in
              (14, clean_name, (value_ast, wrapped)))
        (n_items - 1) in

    -- Gap 3: Scan imports and build scope entries.
    -- For string-path imports: the lowerer reads the imported file and
    -- compiles it via compile_source_json. The imported module's graph
    -- is stored and imported functions are added to scope (tag 5).
    -- For hash imports: use fake fragment ID (tag 2).
    let import_scope = fold mt
      (\is _i ->
        if _i >= n_items then is
        else
          let item = list_nth items _i in
          if item.0 == 32 then
            list_append is (item.1, _i + 10000, 2)
          else is)
      n_items in

    let scope = fold import_scope
      (\s _i ->
        let param = list_nth params _i in
        list_append s (param.1, _i, 0))
      n_params in

    let prog = graph_new in

    -- Gap 4: Source map accumulator
    -- Source map is a list of (node_id, token_start_pos, token_end_pos) tuples
    -- We track current token position during lowering
    let smap = mt in

    -- Gap 7: Extract cost bound from the LetDecl if present
    -- Cost is at (entry.2).2 if the tuple has enough elements
    -- Cost node: (22, cost_kind, cost_args)
    -- Extract cost value early using a simple fold-based lookup
    let entry_children = entry.2 in
    let n_ec = list_len entry_children in
    -- Use a fold to avoid deeply-nested if/else
    -- Result: (found, cost_val)
    let cost_lookup = fold (0, 0)
      (\cl _j ->
        if cl.0 == 1 then cl
        else if n_ec < 3 then (1, 0)
        else
          let cn = list_nth entry_children 2 in
          if cn.0 == 22 then
            let ck = cn.1 in
            -- ck 0,1 = Unit(0), ck 2 = Constant(extract), ck 3,4 = Inherited(1)
            if ck == 2 then
              let ca = cn.2 in
              let nca = list_len ca in
              if nca > 0 then (1, (list_nth ca 0).1) else (1, 2)
            else if ck == 3 then (1, 1)
            else if ck == 4 then (1, 1)
            else (1, 0)
          else (1, 0))
      1 in
    let cost_val_early = cost_lookup.1 in

    -- Simple cases handled directly (no stack machine needed)
    let bk = body_ast.0 in
    if bk == 0 then
      let step = graph_add_node_rt prog 5 in
      let step2 = graph_set_lit_value (step.0) (step.1) 0 (body_ast.1) in
      let g = graph_set_root (step2.0) (step2.1) in
      let sm = list_append mt (step2.1, 0, str_len src) in
      (g, sm)
    else if bk == 3 then
      let step = graph_add_node_rt prog 5 in
      let step2 = graph_set_lit_value (step.0) (step.1) 4 (body_ast.1) in
      let g = graph_set_root (step2.0) (step2.1) in
      let g2 = graph_set_node_type g (step2.1) 1 in
      let sm = list_append mt (step2.1, 0, str_len src) in
      (g2, sm)
    else if bk == 4 then
      let nh = body_ast.1 in
      let nsc = list_len scope in
      let lk = fold (0, 0, 0)
        (\l _j ->
          if l.0 == 1 then l
          else
            let idx = nsc - 1 - _j in
            if idx < 0 then l
            else
              let e = list_nth scope idx in
              if e.0 == nh then (1, e.2, e.1)
              else l)
        nsc in
      if lk.0 == 1 then
        if lk.1 == 0 then
          let step = graph_add_node_rt prog 5 in
          let step2 = graph_set_lit_value (step.0) (step.1) 255 (lk.2) in
          let g = graph_set_root (step2.0) (step2.1) in
          let sm = list_append mt (step2.1, 0, str_len src) in
          (g, sm)
        else
          let g = graph_set_root prog (lk.2) in
          let sm = list_append mt (lk.2, 0, str_len src) in
          (g, sm)
      else
        let step = graph_add_node_rt prog 5 in
        let step2 = graph_set_lit_value (step.0) (step.1) 0 0 in
        let g = graph_set_root (step2.0) (step2.1) in
        let sm = list_append mt (step2.1, 0, str_len src) in
        (g, sm)
    else

    -- Stack machine for compound expressions.
    -- Evaluates the AST iteratively using two cons-cell stacks:
    --   ws (work stack): AST nodes yet to be processed
    --   ns (node stack): SemanticGraph node IDs produced so far
    --
    -- Two kinds of work items:
    --   kind < 50: AST leaf/branch to lower (push args onto ws, then push combine node)
    --   kind >= 50: Combine operation (pop children from ns, emit graph node, push result)
    --
    -- State tuple: (prog, ns, nsp, ws, wsp, scope)
    --   ns = cons-cell node stack: (node_id, rest_stack)
    --   ws = cons-cell work stack: (item, rest_stack)
    -- Sentinel for empty stack: nsp==0 (never access ns when nsp==0)
    let empty = (0, 0) in
    let init_ws = (body_ast, empty) in
    let result = fold (prog, empty, 0, init_ws, 1, scope)
      (\state _i ->
        let pg = state.0 in
        let ns = state.1 in
        let nsp = state.2 in
        let ws = state.3 in
        let wsp = state.4 in
        let sc = state.5 in

        if wsp == 0 then state
        else
          let item = ws.0 in
          let rws = ws.1 in
          let nwsp = wsp - 1 in
          let k = item.0 in

          -- ==========================================================
          -- Combine operations (kind >= 50)
          -- ==========================================================

          -- BinOp combine (50): pop right(ns0), left(ns1)
          -- Also applies type inference: comparison opcodes 32-37 -> Bool type
          if k == 50 then
            let right_id = ns.0 in
            let left_id = (ns.1).0 in
            let rns = (ns.1).1 in
            let opcode = item.1 in
            let step = graph_add_node_rt pg 0 in
            let step2 = graph_set_prim_op (step.0) (step.1) opcode in
            let p2 = graph_connect (step2.0) (step2.1) left_id 0 in
            let p3 = graph_connect p2 (step2.1) right_id 1 in
            -- Type inference: set type tag based on opcode
            let p4 =
              if opcode >= 32 then
                if opcode <= 37 then graph_set_node_type p3 (step2.1) 1
                else p3
              else if opcode == 179 then graph_set_node_type p3 (step2.1) 1
              else if opcode == 184 then graph_set_node_type p3 (step2.1) 1
              else if opcode == 185 then graph_set_node_type p3 (step2.1) 1
              else if opcode == 186 then graph_set_node_type p3 (step2.1) 1
              else if opcode == 177 then graph_set_node_type p3 (step2.1) 3
              else if opcode == 178 then graph_set_node_type p3 (step2.1) 3
              else if opcode == 181 then graph_set_node_type p3 (step2.1) 3
              else if opcode == 183 then graph_set_node_type p3 (step2.1) 3
              else p3 in
            (p4, (step2.1, rns), nsp - 1, rws, nwsp, sc)

          -- Guard combine (51): pop else, then, cond
          else if k == 51 then
            let else_id = ns.0 in
            let then_id = (ns.1).0 in
            let cond_id = ((ns.1).1).0 in
            let rns = ((ns.1).1).1 in
            let step = graph_add_guard_rt pg cond_id then_id else_id in
            (step.0, (step.1, rns), nsp - 2, rws, nwsp, sc)

          -- Unary combine (52): pop 1
          -- Also applies type inference for int_to_float (64) -> Float64
          else if k == 52 then
            let arg_id = ns.0 in
            let rns = ns.1 in
            let opcode = item.1 in
            let step = graph_add_node_rt pg 0 in
            let step2 = graph_set_prim_op (step.0) (step.1) opcode in
            let p2 = graph_connect (step2.0) (step2.1) arg_id 0 in
            -- Type inference for unary prims
            let p3 =
              if opcode == 64 then graph_set_node_type p2 (step2.1) 2
              else if opcode == 183 then graph_set_node_type p2 (step2.1) 3
              else if opcode == 188 then graph_set_node_type p2 (step2.1) 3
              else if opcode == 189 then graph_set_node_type p2 (step2.1) 3
              else if opcode == 190 then graph_set_node_type p2 (step2.1) 3
              else if opcode == 191 then graph_set_node_type p2 (step2.1) 3
              else p2 in
            (p3, (step2.1, rns), nsp, rws, nwsp, sc)

          -- Tuple combine (53): pop n_elems, set Product type
          else if k == 53 then
            let ne = item.1 in
            let step = graph_add_node_rt pg 11 in
            let tr = fold (step.0, step.1, ns, 0)
              (\ts _j ->
                if ts.3 >= ne then ts
                else
                  let eid = (ts.2).0 in
                  let rest = (ts.2).1 in
                  let port = ne - 1 - ts.3 in
                  let p2 = graph_connect (ts.0) (ts.1) eid port in
                  (p2, ts.1, rest, ts.3 + 1))
              ne in
            let tg = graph_set_node_type (tr.0) (tr.1) 4 in
            (tg, (tr.1, tr.2), nsp - ne + 1, rws, nwsp, sc)

          -- Project combine (54)
          else if k == 54 then
            let base_id = ns.0 in
            let rns = ns.1 in
            let fi = item.1 in
            if fi < 0 then
              -- Qualified access: Foo.bar where fi = -(hash of bar)
              -- base_id refers to a module. Look up the function by name hash.
              -- Use module_eval to get the function from the imported module.
              let func_hash = 0 - fi in
              -- For now, resolve via module_eval at index matching func_hash
              -- The module binding (tag 4) stores the module_id
              -- We need to find the module_id from scope and call module_eval
              -- TODO: proper qualified name resolution via module entry table
              let step = graph_add_node_rt pg 5 in
              let step2 = graph_set_lit_value (step.0) (step.1) 0 0 in
              (step2.0, (step2.1, rns), nsp, rws, nwsp, sc)
            else
              -- Integer field access: x.0, x.1, etc.
              let step = graph_add_node_rt pg 13 in
              let step2 = graph_set_field_index (step.0) (step.1) fi in
              let p2 = graph_connect (step2.0) (step2.1) base_id 0 in
              (p2, (step2.1, rns), nsp, rws, nwsp, sc)

          -- Apply combine (55)
          else if k == 55 then
            let arg_id = ns.0 in
            let func_id = (ns.1).0 in
            let rns = (ns.1).1 in
            -- Check if func is a Fold node (kind 8) — special handling
            let func_kind = graph_get_kind pg func_id in
            if func_kind == 8 then
              -- Fold application: connect arg to next available port
              -- Count existing argument edges to determine port number
              let existing = graph_edge_count pg func_id in
              let p2 = graph_connect pg func_id arg_id existing in
              (p2, (func_id, rns), nsp - 1, rws, nwsp, sc)
            else
            let step = graph_add_node_rt pg 1 in
            let p2 = graph_connect (step.0) (step.1) func_id 0 in
            let p3 = graph_connect p2 (step.1) arg_id 1 in
            (p3, (step.1, rns), nsp - 1, rws, nwsp, sc)

          -- LetBind (56)
          else if k == 56 then
            let val_id = ns.0 in
            let rns = ns.1 in
            let nh = item.1 in
            let rh = if nh >= 2147483648 then nh - 2147483648 else nh in
            let new_sc = list_append sc (rh, val_id, 1) in
            let body2 = item.2 in
            (pg, rns, nsp - 1, (body2, rws), nwsp + 1, new_sc)

          -- Pipe combine (57)
          else if k == 57 then
            let func_id = ns.0 in
            let arg_id = (ns.1).0 in
            let rns = (ns.1).1 in
            let step = graph_add_node_rt pg 1 in
            let p2 = graph_connect (step.0) (step.1) func_id 0 in
            let p3 = graph_connect p2 (step.1) arg_id 1 in
            (p3, (step.1, rns), nsp - 1, rws, nwsp, sc)

          -- Fold combine (58)
          else if k == 58 then
            let list_id = ns.0 in
            let fn_id = (ns.1).0 in
            let base_id = ((ns.1).1).0 in
            let rns = ((ns.1).1).1 in
            let step = graph_add_node_rt pg 8 in
            let p2 = graph_connect (step.0) (step.1) base_id 0 in
            let p3 = graph_connect p2 (step.1) fn_id 1 in
            let p4 = graph_connect p3 (step.1) list_id 2 in
            (p4, (step.1, rns), nsp - 2, rws, nwsp, sc)

          -- Fold combine 2-arg (58): pop step, base -> fold node
          -- (already handled above for 3-arg case)

          -- Not combine (59)
          else if k == 59 then
            let pred_id = ns.0 in
            let rns = ns.1 in
            let rt = graph_add_node_rt pg 5 in
            let tl = graph_set_lit_value (rt.0) (rt.1) 4 1 in
            let rf = graph_add_node_rt (tl.0) 5 in
            let fl = graph_set_lit_value (rf.0) (rf.1) 4 0 in
            let step = graph_add_guard_rt (fl.0) pred_id (fl.1) (tl.1) in
            (step.0, (step.1, rns), nsp, rws, nwsp, sc)

          -- Unfold combine (60): pop bound, step, seed -> Unfold node
          else if k == 60 then
            let bound_id = ns.0 in
            let step_id = (ns.1).0 in
            let seed_id = ((ns.1).1).0 in
            let rns = ((ns.1).1).1 in
            -- Create a dummy termination node (int 0)
            let dt = graph_add_node_rt pg 5 in
            let dt2 = graph_set_lit_value (dt.0) (dt.1) 0 0 in
            -- Create Unfold node (kind=9 in SemanticGraph)
            let step3 = graph_add_node_rt (dt2.0) 9 in
            let p2 = graph_connect (step3.0) (step3.1) seed_id 0 in
            let p3 = graph_connect p2 (step3.1) step_id 1 in
            let p4 = graph_connect p3 (step3.1) (dt2.1) 2 in
            let p5 = graph_connect p4 (step3.1) bound_id 3 in
            (p5, (step3.1, rns), nsp - 2, rws, nwsp, sc)

          -- Gap 2: Effect combine (61): pop 1 arg, create Effect node
          -- item.1 = effect tag byte
          else if k == 61 then
            let arg_id = ns.0 in
            let rns = ns.1 in
            let tag = item.1 in
            let step = graph_add_node_rt pg 10 in
            let step2 = graph_set_prim_op (step.0) (step.1) tag in
            let p2 = graph_connect (step2.0) (step2.1) arg_id 0 in
            (p2, (step2.1, rns), nsp, rws, nwsp, sc)

          -- Effect combine 2-arg (62): pop 2 args, create Effect node
          else if k == 62 then
            let arg2_id = ns.0 in
            let arg1_id = (ns.1).0 in
            let rns = (ns.1).1 in
            let tag = item.1 in
            let step = graph_add_node_rt pg 10 in
            let step2 = graph_set_prim_op (step.0) (step.1) tag in
            let p2 = graph_connect (step2.0) (step2.1) arg1_id 0 in
            let p3 = graph_connect p2 (step2.1) arg2_id 1 in
            (p3, (step2.1, rns), nsp - 1, rws, nwsp, sc)

          -- Lambda combine (63): pop body, create Lambda node with binder
          -- item.2 carries (binder_idx, scope_depth) from the Lambda handler
          else if k == 63 then
            let body_id = ns.0 in
            let rns = ns.1 in
            let combo = item.2 in
            let binder_idx = combo.0 in
            let saved_depth = combo.1 in
            let binder_id = 4294901760 + binder_idx in
            -- Create Lambda node (kind 2) and set its binder
            let step = graph_add_node_rt pg 2 in
            let step2 = graph_set_binder (step.0) (step.1) binder_id in
            -- Connect body via Continuation edge (label 3, port 0)
            let p2 = graph_connect_labeled (step2.0) (step2.1) body_id 0 3 in
            -- Restore scope to pre-Lambda state (remove Lambda param)
            let restored_sc = list_take sc saved_depth in
            (p2, (step2.1, rns), nsp, rws, nwsp, restored_sc)

          -- ==========================================================
          -- AST expression nodes
          -- ==========================================================

          -- IntLit (0)
          else if k == 0 then
            let step = graph_add_node_rt pg 5 in
            let step2 = graph_set_lit_value (step.0) (step.1) 0 (item.1) in
            (step2.0, (step2.1, ns), nsp + 1, rws, nwsp, sc)

          -- FloatLit (1): payload is scaled integer (int_part * 1000000 + dec_scaled)
          else if k == 1 then
            let step = graph_add_node_rt pg 5 in
            let step2 = graph_set_lit_value (step.0) (step.1) 2 (item.1) in
            (step2.0, (step2.1, ns), nsp + 1, rws, nwsp, sc)

          -- StringLit (2)
          else if k == 2 then
            let start = item.1 in
            let slen = str_len src in
            let scan = fold (start + 1, 0)
              (\s2 _j ->
                if s2.1 == 1 then s2
                else if s2.0 >= slen then (s2.0, 1)
                else if (char_at src s2.0) == 34 then (s2.0, 1)
                else (s2.0 + 1, 0))
              slen in
            let content = str_slice src (start + 1) scan.0 in
            let step = graph_add_node_rt pg 5 in
            let step2 = graph_set_lit_value (step.0) (step.1) 7 content in
            (step2.0, (step2.1, ns), nsp + 1, rws, nwsp, sc)

          -- BoolLit (3)
          else if k == 3 then
            let step = graph_add_node_rt pg 5 in
            let step2 = graph_set_lit_value (step.0) (step.1) 4 (item.1) in
            (step2.0, (step2.1, ns), nsp + 1, rws, nwsp, sc)

          -- Var (4)
          else if k == 4 then
            let nh = item.1 in
            let nsc = list_len sc in
            let lk = fold (0, 0, 0)
              (\l _j ->
                if l.0 == 1 then l
                else
                  let idx = nsc - 1 - _j in
                  if idx < 0 then l
                  else
                    let e = list_nth sc idx in
                    if e.0 == nh then (1, e.2, e.1)
                    else l)
              nsc in
            if lk.0 == 1 then
              -- Gap 3: Check binding tag
              if lk.1 == 2 then
                -- Fragment reference (import): create Ref node (kind 14 in graph)
                let step = graph_add_node_rt pg 14 in
                let step2 = graph_set_lit_value (step.0) (step.1) 8 (lk.2) in
                (step2.0, (step2.1, ns), nsp + 1, rws, nwsp, sc)
              else if lk.1 == 0 then
                let step = graph_add_node_rt pg 5 in
                let step2 = graph_set_lit_value (step.0) (step.1) 255 (lk.2) in
                (step2.0, (step2.1, ns), nsp + 1, rws, nwsp, sc)
              else
                (pg, (lk.2, ns), nsp + 1, rws, nwsp, sc)
            else
              -- Variable not in scope: try resolving as a known primitive.
              -- Primitives are identified by their name's char-sum hash.
              -- If matched, creates a Prim node with the corresponding opcode.
              -- If unmatched, falls through to external/unknown handling.
              let prim_result = fold (0, 0)
                (\pr _j ->
                  if pr.0 == 1 then pr
                  else
                  -- Arithmetic
                  if nh == 297 then (1, 0)
                  else if nh == 330 then (1, 1)
                  else if nh == 334 then (1, 2)
                  else if nh == 323 then (1, 3)
                  else if nh == 320 then (1, 4)
                  else if nh == 314 then (1, 5)
                  else if nh == 310 then (1, 6)
                  else if nh == 324 then (1, 7)
                  else if nh == 326 then (1, 8)
                  else if nh == 342 then (1, 9)
                  -- Bitwise
                  else if nh == 626 then (1, 16)
                  else if nh == 544 then (1, 17)
                  else if nh == 664 then (1, 18)
                  else if nh == 656 then (1, 19)
                  else if nh == 327 then (1, 20)
                  else if nh == 333 then (1, 21)
                  -- Comparison
                  else if nh == 214 then (1, 32)
                  else if nh == 211 then (1, 33)
                  else if nh == 224 then (1, 34)
                  else if nh == 219 then (1, 35)
                  else if nh == 209 then (1, 36)
                  else if nh == 204 then (1, 37)
                  -- Higher-order
                  else if nh == 318 then (1, 48)
                  else if nh == 646 then (1, 49)
                  else if nh == 339 then (1, 50)
                  -- Conversion
                  else if nh == 1282 then (1, 64)
                  else if nh == 1176 then (1, 68)
                  -- Graph introspection
