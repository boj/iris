                -- math_sin (hash=851)
                else if fa.1 == 851 then (pg, ns, nsp, (aa, ((52, 219, mt), rws)), nwsp + 2, sc)
                -- math_cos (hash=846)
                else if fa.1 == 846 then (pg, ns, nsp, (aa, ((52, 220, mt), rws)), nwsp + 2, sc)
                -- math_floor (hash=1067) -- collision with map_remove/random_int (arity 2)
                else if fa.1 == 1067 then (pg, ns, nsp, (aa, ((52, 221, mt), rws)), nwsp + 2, sc)
                -- math_ceil (hash=934)
                else if fa.1 == 934 then (pg, ns, nsp, (aa, ((52, 222, mt), rws)), nwsp + 2, sc)
                -- math_round (hash=1073)
                else if fa.1 == 1073 then (pg, ns, nsp, (aa, ((52, 223, mt), rws)), nwsp + 2, sc)
                -- list_len (hash=858)
                else if fa.1 == 858 then (pg, ns, nsp, (aa, ((52, 240, mt), rws)), nwsp + 2, sc)
                -- bytes_from_ints (hash=1623)
                else if fa.1 == 1623 then (pg, ns, nsp, (aa, ((52, 230, mt), rws)), nwsp + 2, sc)
                -- bytes_len (hash=965)
                else if fa.1 == 965 then (pg, ns, nsp, (aa, ((52, 232, mt), rws)), nwsp + 2, sc)
                -- str_bc (hash=1172) = str_replace is arity 3, skip
                -- thunk_force (hash=1176 same as bool_to_int, handled above)
                -- Gap 2: Effect name dispatch for single-arg effects
                -- print (hash=557)
                else if fa.1 == 557 then
                  (pg, ns, nsp, (aa, ((61, 0, mt), rws)), nwsp + 2, sc)
                -- read_line (hash=931)
                else if fa.1 == 931 then
                  (pg, ns, nsp, (aa, ((61, 1, mt), rws)), nwsp + 2, sc)
                -- sleep (hash=537)
                else if fa.1 == 537 then
                  (pg, ns, nsp, (aa, ((61, 8, mt), rws)), nwsp + 2, sc)
                -- timestamp (hash=980)
                else if fa.1 == 980 then
                  (pg, ns, nsp, (aa, ((61, 9, mt), rws)), nwsp + 2, sc)
                -- random (hash=641)
                else if fa.1 == 641 then
                  (pg, ns, nsp, (aa, ((61, 10, mt), rws)), nwsp + 2, sc)
                -- log (hash=322)
                else if fa.1 == 322 then
                  (pg, ns, nsp, (aa, ((61, 11, mt), rws)), nwsp + 2, sc)
                -- tcp_listen (hash=1077)
                else if fa.1 == 1077 then
                  (pg, ns, nsp, (aa, ((61, 20, mt), rws)), nwsp + 2, sc)
                -- file_open (hash=945)
                else if fa.1 == 945 then
                  (pg, ns, nsp, (aa, ((61, 22, mt), rws)), nwsp + 2, sc)
                -- file_stat (hash=955)
                else if fa.1 == 955 then
                  (pg, ns, nsp, (aa, ((61, 26, mt), rws)), nwsp + 2, sc)
                -- dir_list (hash=858 - collision with list_len, list_len wins)
                -- env_get (hash=744)
                else if fa.1 == 744 then
                  (pg, ns, nsp, (aa, ((61, 28, mt), rws)), nwsp + 2, sc)
                -- clock_ns (hash=844)
                else if fa.1 == 844 then
                  (pg, ns, nsp, (aa, ((61, 29, mt), rws)), nwsp + 2, sc)
                -- sleep_ms (hash=856 - collision with map_size, map_size wins)
                -- thread_join (hash=1159)
                else if fa.1 == 1159 then
                  (pg, ns, nsp, (aa, ((61, 33, mt), rws)), nwsp + 2, sc)
                -- atomic_read (hash=1144)
                else if fa.1 == 1144 then
                  (pg, ns, nsp, (aa, ((61, 34, mt), rws)), nwsp + 2, sc)
                -- atomic_new (hash=1062)
                else if fa.1 == 1062 then
                  (pg, ns, nsp, (aa, ((61, 44, mt), rws)), nwsp + 2, sc)
                -- rwlock_release (hash=1490)
                else if fa.1 == 1490 then
                  (pg, ns, nsp, (aa, ((61, 40, mt), rws)), nwsp + 2, sc)
                -- mmap_exec (hash=943)
                else if fa.1 == 943 then
                  (pg, ns, nsp, (aa, ((61, 41, mt), rws)), nwsp + 2, sc)
                -- ffi_call (hash=816)
                else if fa.1 == 816 then
                  (pg, ns, nsp, (aa, ((61, 43, mt), rws)), nwsp + 2, sc)
                else
                  (pg, ns, nsp, (fa, (aa, ((55, 0, mt), rws))), nwsp + 3, sc)
              -- OpSection (16) used as function: apply to argument
              else if fa.0 == 16 then
                (pg, ns, nsp, (fa, (aa, ((55, 0, mt), rws))), nwsp + 3, sc)
              else
                (pg, ns, nsp, (fa, (aa, ((55, 0, mt), rws))), nwsp + 3, sc)

          -- Lambda (13): push body + Lambda combine (63) to work stack
          else if k == 13 then
            let ph = item.1 in
            let ba = list_nth (item.2) 0 in
            -- param2: second parameter hash (0 if single-param lambda)
            let param2 = if tuple_len item > 3 then item.3 else 0 in
            let nsc = list_len sc in
            let pc = fold 0
              (\c2 _j ->
                if _j >= nsc then c2
                else
                  let e = list_nth sc _j in
                  if e.2 == 0 then c2 + 1 else c2)
              nsc in
            -- For multi-param lambdas, create InputRef + Project nodes
            -- The lambda parameter is a tuple (acc, i). We need:
            --   InputRef(128+pc) for the tuple
            --   Project(0) on InputRef for param1
            --   Project(1) on InputRef for param2
            let binder_idx = 128 + pc in
            let scope_depth = list_len sc in
            if param2 == 0 then
              -- Single param lambda: add param hash to scope
              let new_sc = list_append sc (ph, binder_idx, 0) in
              -- Pass (binder_idx, scope_depth) to combine so it can restore scope
              (pg, ns, nsp, (ba, ((63, ph, (binder_idx, scope_depth)), rws)), nwsp + 2, new_sc)
            else
              -- Multi-param lambda: curry as \p1 -> \p2 -> body
              -- Create inner Lambda AST for the second param, then outer for first
              -- Inner: (13, param2, [body], 0) — single-param lambda for p2
              let inner_lambda = (13, param2, list_append mt ba, 0) in
              -- Outer: single-param lambda for p1, body = inner_lambda
              let new_sc = list_append sc (ph, binder_idx, 0) in
              (pg, ns, nsp, (inner_lambda, ((63, ph, (binder_idx, scope_depth)), rws)), nwsp + 2, new_sc)

          -- Let/in (14)
          else if k == 14 then
            let nh = item.1 in
            let va = (item.2).0 in
            let ba = (item.2).1 in
            -- For both rec and non-rec, use standard LetBind.
            -- Recursion is handled through the evaluator's fragment registry
            -- (run command) or through trampoline fold (IRIS pipeline).
            -- Strip rec bit so the name resolves correctly.
            let clean_nh = if nh >= 2147483648 then nh - 2147483648 else nh in
            (pg, ns, nsp, (va, ((56, clean_nh, ba), rws)), nwsp + 2, sc)

          -- If/then/else (15)
          else if k == 15 then
            let ca = (item.2).0 in
            let ta = (item.2).1 in
            let ea = (item.2).2 in
            (pg, ns, nsp, (ca, (ta, (ea, ((51, 0, mt), rws)))), nwsp + 4, sc)

          -- Tuple (17)
          else if k == 17 then
            let elems = item.2 in
            let ne = list_len elems in
            if ne == 0 then
              let step = graph_add_node_rt pg 11 in
              (step.0, (step.1, ns), nsp + 1, rws, nwsp, sc)
            else
              let w1 = ((53, ne, mt), rws) in
              let wf = fold (w1, 0)
                (\wst _j ->
                  if wst.1 >= ne then wst
                  else
                    let idx = ne - 1 - wst.1 in
                    let elem = list_nth elems idx in
                    ((elem, wst.0), wst.1 + 1))
                ne in
              (pg, ns, nsp, wf.0, nwsp + ne + 1, sc)

          -- TupleAccess (18)
          else if k == 18 then
            let ba = list_nth (item.2) 0 in
            let fi = item.1 in
            (pg, ns, nsp, (ba, ((54, fi, mt), rws)), nwsp + 2, sc)

          -- OpSection (16): operator as first-class value
          -- op_id: 0=add,1=sub,2=mul,3=div,4=mod,5=eq,6=ne,7=lt,8=gt,9=le,10=ge
          else if k == 16 then
            let op_id = item.1 in
            let opcode =
              if op_id == 0 then 0
              else if op_id == 1 then 1
              else if op_id == 2 then 2
              else if op_id == 3 then 3
              else if op_id == 4 then 4
              else if op_id == 5 then 32
              else if op_id == 6 then 33
              else if op_id == 7 then 34
              else if op_id == 8 then 35
              else if op_id == 9 then 36
              else if op_id == 10 then 37
              else 0 in
            let step = graph_add_node_rt pg 0 in
            let step2 = graph_set_prim_op (step.0) (step.1) opcode in
            (step2.0, (step2.1, ns), nsp + 1, rws, nwsp, sc)

          -- Pipe (19)
          else if k == 19 then
            let la = (item.2).0 in
            let ra = (item.2).1 in
            (pg, ns, nsp, (la, (ra, ((57, 0, mt), rws))), nwsp + 3, sc)

          -- Match (20): scrutinee with arms -> cascading guards
          -- children = (scrutinee, arms_list)
          -- Each arm = (pattern_kind, pattern_val, body_ast)
          -- Lowered as: guard (scrutinee == pat0) body0
          --               (guard (scrutinee == pat1) body1 ... default)
          else if k == 20 then
            let scr = (item.2).0 in
            let arms = (item.2).1 in
            let n_arms = list_len arms in
            if n_arms == 0 then
              let step = graph_add_node_rt pg 5 in
              let step2 = graph_set_lit_value (step.0) (step.1) 0 0 in
              (step2.0, (step2.1, ns), nsp + 1, rws, nwsp, sc)
            else if n_arms == 1 then
              -- Single arm: just emit the body (with scrutinee bound)
              let arm = list_nth arms 0 in
              let body = arm.2 in
              (pg, ns, nsp, (body, rws), nwsp + 1, sc)
            else
              -- Multiple arms: push scrutinee first, then cascade guards
              -- We build: push scrutinee, then for each arm push a guard-combine
              -- For now, flatten as nested if-then-else using guard combines
              -- Push arms in reverse, with combine operations
              let last_arm = list_nth arms (n_arms - 1) in
              let last_body = last_arm.2 in
              -- Start work stack with last arm body as fallback
              let w1 = (last_body, rws) in
              let nw1 = nwsp + 1 in
              -- For each arm from n_arms-2 down to 0, push:
              --   scrutinee, pattern_lit, eq_compare(50), arm_body, guard_combine(51)
              let wf = fold (w1, nw1, n_arms - 2)
                (\wst _j ->
                  if wst.2 < 0 then wst
                  else
                    let arm = list_nth arms wst.2 in
                    let arm_body = arm.2 in
                    -- Push: scr, patlit, eq-combine, arm_body, guard-combine
                    let w_guard = ((51, 0, mt), wst.0) in
                    let w_body = (arm_body, w_guard) in
                    let w_eq = ((50, 32, mt), w_body) in
                    let w_pat = ((0, arm.1, mt), w_eq) in
                    let w_scr = (scr, w_pat) in
                    (w_scr, wst.1 + 5, wst.2 - 1))
                n_arms in
              (pg, ns, nsp, wf.0, wf.1, sc)

          -- ForAll (21): just lower the body expression (type variables erased)
          else if k == 21 then
            let ba = list_nth (item.2) 0 in
            (pg, ns, nsp, (ba, rws), nwsp + 1, sc)

          -- CostExpr (22): skip in lowering (cost is metadata)
          else if k == 22 then
            (pg, ns, nsp, rws, nwsp, sc)

          -- Unknown: skip
          else (pg, ns, nsp, rws, nwsp, sc)
      )
      4096 in

    let pre_graph = graph_set_root (result.0) ((result.1).0) in
    let root_id = (result.1).0 in

    -- Apply cost bound right after setting root
    let cost_graph =
      if cost_val_early >= 2 then
        graph_set_cost pre_graph root_id cost_val_early
      else if cost_val_early == 1 then
        graph_set_cost pre_graph root_id 1
      else pre_graph in

    -- Attach capability metadata if present.
    -- cap_info is 0 (no capabilities) or a list of entries.
    -- Each entry: (is_allow, name_hash, name_len, arg_start, arg_end)
    -- Hub node: Lit(type_tag=0, value=n_caps) connected to root at port 127.
    -- Entry nodes: Lit(type_tag=0, packed_value) connected to hub at ports 0..n.
    -- Packed entry: is_allow + name_hash * 2 + name_len * 8192
    let capped_graph =
      if cap_info == 0 then cost_graph
      else
        let n_caps = list_len cap_info in
        if n_caps == 0 then cost_graph
        else
          let hub_step = graph_add_node_rt cost_graph 5 in
          let hub_lit = graph_set_lit_value (hub_step.0) (hub_step.1) 0 n_caps in
          let g1 = graph_connect (hub_lit.0) root_id (hub_lit.1) 127 in
          let cap_result = fold (g1, 0)
            (\cr _i ->
              if cr.1 >= n_caps then cr
              else
                let e = list_nth cap_info (cr.1) in
                let packed = (e.0) + (e.1) * 2 + (e.2) * 8192 in
                let entry_step = graph_add_node_rt (cr.0) 5 in
                let entry_lit = graph_set_lit_value (entry_step.0) (entry_step.1) 0 packed in
                let g2 = graph_connect (entry_lit.0) (hub_lit.1) (entry_lit.1) (cr.1) in
                (g2, cr.1 + 1))
            n_caps in
          cap_result.0 in

    let final_graph = capped_graph in

    -- Build source map from the graph
    let body_start = 0 in
    let body_end = str_len src in
    let source_map = list_append mt (root_id, body_start, body_end) in

    let nodes = graph_nodes final_graph in
    let n_nodes = list_len nodes in

    let ext_smap = fold source_map
      (\sm _i ->
        if _i >= n_nodes then sm
        else
          let nid = list_nth nodes _i in
          let chunk = if n_nodes > 0 then body_end / (n_nodes + 1) else body_end in
          let es = _i * chunk in
          let ee = if es + chunk > body_end then body_end else es + chunk in
          list_append sm (nid, es, ee))
      n_nodes in

    -- Return: (Program, source_map)
    (final_graph, ext_smap)
