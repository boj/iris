-- stage1_test.iris — Test the bytecode compiler + VM pipeline.
--
-- Compiles a source program to SemanticGraph via compile_source_json,
-- then compiles the graph to bytecodes, then executes via the VM.
--
-- This is the proof-of-concept for the self-hosted stage1:
--   source → tokenizer → parser → lowerer → SemanticGraph → bytecode → VM → result
--
-- Usage: iris-stage0 run stage1_test.iris <source_path> <arg>

let rec compile_node program node_id env next_slot =
  let kind = graph_get_kind program node_id in
  let children = graph_outgoing program node_id in
  let nc = list_len children in
  if kind == 5 then
    let tt = graph_get_lit_type_tag program node_id in
    let lv = graph_get_lit_value program node_id in
    if tt == 255 then
      let slot = fold 0 (\s i ->
        if i >= list_len env then s
        else let e = list_nth env i in if e.0 == lv then e.1 else s
      ) (list_len env) in
      ((14, slot), env, next_slot)
    else ((1, lv), env, next_slot)
  else if kind == 0 then
    let opcode = graph_get_prim_op program node_id in
    let bc_op = if opcode == 0 then 2 else if opcode == 1 then 3
      else if opcode == 2 then 4 else if opcode == 3 then 5
      else if opcode == 4 then 6 else if opcode == 5 then 7
      else if opcode == 32 then 8 else if opcode == 33 then 11
      else if opcode == 34 then 9 else if opcode == 35 then 10
      else if opcode == 36 then 12 else if opcode == 37 then 13
      else 0 in
    if bc_op >= 2 then
      if nc == 2 then
        let r0 = compile_node program (list_nth children 0) env next_slot in
        let r1 = compile_node program (list_nth children 1) (r0.1) (r0.2) in
        (list_concat (list_concat (r0.0) (r1.0)) (bc_op,), r1.1, r1.2)
      else if nc == 1 then
        let r0 = compile_node program (list_nth children 0) env next_slot in
        (list_concat (r0.0) (bc_op,), r0.1, r0.2)
      else ((1, 0), env, next_slot)
    else
      let child_code = fold ((), env, next_slot) (\st i ->
        if i >= nc then st
        else let r = compile_node program (list_nth children i) (st.1) (st.2) in
          (list_concat (st.0) (r.0), r.1, r.2)
      ) nc in
      (list_concat (child_code.0) (28, opcode, nc), child_code.1, child_code.2)
  else if kind == 17 then
    let rc = compile_node program (list_nth children 0) env next_slot in
    let rt = compile_node program (list_nth children 1) (rc.1) (rc.2) in
    let re = compile_node program (list_nth children 2) (rt.1) (rt.2) in
    let cl = list_len (rc.0) in
    let tl = list_len (rt.0) in
    let el = list_len (re.0) in
    let full = list_concat (rc.0) (17, cl + 2 + tl + 2) in
    let full2 = list_concat (list_concat full (rt.0)) (16, cl + 2 + tl + 2 + el) in
    (list_concat full2 (re.0), re.1, re.2)
  else if kind == 11 then
    let cc = fold ((), env, next_slot) (\st i ->
      if i >= nc then st
      else let r = compile_node program (list_nth children i) (st.1) (st.2) in
        (list_concat (st.0) (r.0), r.1, r.2)
    ) nc in
    (list_concat (cc.0) (18, nc), cc.1, cc.2)
  else if kind == 13 then
    let fi = graph_get_field_index program node_id in
    let r0 = compile_node program (list_nth children 0) env next_slot in
    (list_concat (r0.0) (19, fi), r0.1, r0.2)
  else if kind == 8 then
    let rb = compile_node program (list_nth children 0) env next_slot in
    let rl = compile_node program (list_nth children 2) (rb.1) (rb.2) in
    let step_id = list_nth children 1 in
    let sk = graph_get_kind program step_id in
    if sk == 2 then
      let ob = graph_get_binder program step_id in
      let oi = bitand ob 255 in
      let sc = graph_outgoing program step_id in
      let bid = list_nth sc 0 in
      let ik = graph_get_kind program bid in
      let as2 = rl.2 in
      let is2 = as2 + 1 in
      let abid = if ik == 2 then list_nth (graph_outgoing program bid) 0 else bid in
      let ibi = if ik == 2 then bitand (graph_get_binder program bid) 255 else 0 in
      let e2 = list_append (rl.1) (oi, as2) in
      let e3 = if ik == 2 then list_append e2 (ibi, is2) else e2 in
      let rbd = compile_node program abid e3 (is2 + 1) in
      let bl = list_len (rbd.0) in
      let c = list_concat (list_concat (rb.0) (rl.0)) (25, bl + 6) in
      let c2 = list_concat c (15, is2) in
      let c3 = list_concat c2 (15, as2) in
      let c4 = list_concat c3 (14, as2) in
      let c5 = list_concat c4 (rbd.0) in
      (list_concat c5 (26,), rl.1, rbd.2)
    else (rb.0, rb.1, rb.2)
  else if kind == 2 then
    let bc = graph_outgoing program node_id in
    let bid2 = list_nth bc 0 in
    let b = graph_get_binder program node_id in
    let bi = bitand b 255 in
    let sl = next_slot in
    compile_node program bid2 (list_append env (bi, sl)) (sl + 1)
  else if kind == 3 then
    let vid = list_nth children 0 in
    let bdid = list_nth children 1 in
    let b = graph_get_binder program node_id in
    let bi = bitand b 255 in
    let sl = next_slot in
    let rv = compile_node program vid env next_slot in
    let sc = list_concat (rv.0) (15, sl) in
    let e2 = list_append (rv.1) (bi, sl) in
    let rbd = compile_node program bdid e2 (sl + 1) in
    (list_concat sc (rbd.0), rbd.1, rbd.2)
  else ((1, 0), env, next_slot)

-- Minimal inline VM (handles core ops for testing)
let vm_run code input =
  let locals = fold () (\a i -> list_append a 0) 64 in
  let li = fold () (\a i -> if i == 0 then list_append a input else list_append a (tuple_get locals i)) 64 in
  let fs = fold (0, (input, ()), li, 0) (\st _i ->
    if st.3 == 1 then st
    else
      let pc = st.0 in
      let sk = st.1 in
      let lo = st.2 in
      let op = tuple_get code pc in
      let top = sk.0 in
      let sk1 = sk.1 in
      if op == 0 then (pc, sk, lo, 1)
      else if op == 1 then (pc + 2, (tuple_get code (pc + 1), sk), lo, 0)
      else if op == 2 then let b = sk1.0 in (pc + 1, (b + top, sk1.1), lo, 0)
      else if op == 3 then let b = sk1.0 in (pc + 1, (b - top, sk1.1), lo, 0)
      else if op == 4 then let b = sk1.0 in (pc + 1, (b * top, sk1.1), lo, 0)
      else if op == 5 then let b = sk1.0 in (pc + 1, (b / top, sk1.1), lo, 0)
      else if op == 6 then let b = sk1.0 in (pc + 1, (b % top, sk1.1), lo, 0)
      else if op == 8 then let b = sk1.0 in (pc + 1, (if b == top then 1 else 0, sk1.1), lo, 0)
      else if op == 9 then let b = sk1.0 in (pc + 1, (if b < top then 1 else 0, sk1.1), lo, 0)
      else if op == 10 then let b = sk1.0 in (pc + 1, (if b > top then 1 else 0, sk1.1), lo, 0)
      else if op == 12 then let b = sk1.0 in (pc + 1, (if b <= top then 1 else 0, sk1.1), lo, 0)
      else if op == 14 then
        let sl = tuple_get code (pc + 1) in
        (pc + 2, (tuple_get lo sl, sk), lo, 0)
      else if op == 15 then
        let sl = tuple_get code (pc + 1) in
        let nlo = fold () (\a j -> if j == sl then list_append a top else list_append a (tuple_get lo j)) 64 in
        (pc + 2, sk1, nlo, 0)
      else if op == 16 then (tuple_get code (pc + 1), sk, lo, 0)
      else if op == 17 then
        let addr = tuple_get code (pc + 1) in
        if top == 0 then (addr, sk1, lo, 0) else (pc + 2, sk1, lo, 0)
      else if op == 18 then
        let n = tuple_get code (pc + 1) in
        let popped = fold (sk, ()) (\ps _j ->
          if _j >= n then ps
          else let ptop = ps.0 in (ptop.1, list_append (ps.1) (ptop.0))
        ) n in
        let rl = list_len (popped.1) in
        let rev = fold () (\a _j -> if _j >= rl then a else list_append a (tuple_get (popped.1) (rl - 1 - _j))) rl in
        (pc + 2, (rev, popped.0), lo, 0)
      else if op == 19 then
        let idx = tuple_get code (pc + 1) in
        (pc + 2, (tuple_get top idx, sk1), lo, 0)
      else if op == 25 then
        -- FOLD_BEGIN
        let blen = tuple_get code (pc + 1) in
        let limit = top in
        let acc = sk1.0 in
        let rest = sk1.1 in
        let bstart = pc + 2 in
        let fr = fold (acc, 0) (\fs2 _j ->
          if fs2.1 >= limit then fs2
          else
            let bs = fold (bstart, (fs2.1, (fs2.0, ())), lo, 0) (\bs2 _k ->
              if bs2.3 == 1 then bs2
              else
                let bpc = bs2.0 in
                let bsk = bs2.1 in
                let blo = bs2.2 in
                let btop = bsk.0 in
                let bsk1 = bsk.1 in
                let bop = tuple_get code bpc in
                if bop == 26 then (bpc + 1, bsk, blo, 1)
                else if bop == 15 then
                  let sl = tuple_get code (bpc + 1) in
                  let nlo2 = fold () (\a j -> if j == sl then list_append a btop else list_append a (tuple_get blo j)) 64 in
                  (bpc + 2, bsk1, nlo2, 0)
                else if bop == 14 then
                  let sl = tuple_get code (bpc + 1) in
                  (bpc + 2, (tuple_get blo sl, bsk), blo, 0)
                else if bop == 1 then
                  (bpc + 2, (tuple_get code (bpc + 1), bsk), blo, 0)
                else if bop == 2 then let bb = bsk1.0 in (bpc + 1, (bb + btop, bsk1.1), blo, 0)
                else if bop == 3 then let bb = bsk1.0 in (bpc + 1, (bb - btop, bsk1.1), blo, 0)
                else if bop == 4 then let bb = bsk1.0 in (bpc + 1, (bb * btop, bsk1.1), blo, 0)
                else if bop == 18 then
                  let n = tuple_get code (bpc + 1) in
                  let popped = fold (bsk, ()) (\ps _m ->
                    if _m >= n then ps
                    else let pt = ps.0 in (pt.1, list_append (ps.1) (pt.0))
                  ) n in
                  let brl = list_len (popped.1) in
                  let brev = fold () (\a _m -> if _m >= brl then a else list_append a (tuple_get (popped.1) (brl - 1 - _m))) brl in
                  (bpc + 2, (brev, popped.0), blo, 0)
                else if bop == 19 then
                  let idx = tuple_get code (bpc + 1) in
                  (bpc + 2, (tuple_get btop idx, bsk1), blo, 0)
                else (bpc + 1, bsk, blo, 0)
            ) (blen + 10) in
            let bres = bs.1 in
            (bres.0, fs2.1 + 1)
        ) limit in
        (bstart + blen, (fr.0, rest), lo, 0)
      else (pc + 1, sk, lo, 0)
  ) 10000000 in
  let fsk = fs.1 in
  fsk.0

let main path arg =
  let src = file_read path in
  -- Use compile_source to get module, then build graph manually for testing
  -- For simple programs (n + expr), build a test graph
  let m = compile_source src in
  -- Evaluate through module_eval directly to get the expected result
  let n_bindings = list_len (m.1) in
  let expected = module_eval (m.0) (n_bindings - 1) arg in
  -- Test bytecode programs one at a time
  -- f(n) = n + 1: LOAD 0, PUSH 1, ADD, HALT
  let bc1 = (14, 0, 1, 1, 2, 0) in
  let r1 = vm_run bc1 arg in
  -- f(n) = n * n: LOAD 0, LOAD 0, MUL, HALT
  let bc2 = (14, 0, 14, 0, 4, 0) in
  let r2 = vm_run bc2 arg in
  -- f(n) = if n == 0 then 99 else n + 1
  let bc3 = (14, 0, 1, 0, 8, 17, 11, 1, 99, 16, 16, 14, 0, 1, 1, 2, 0) in
  let r3a = vm_run bc3 0 in
  let r3b = vm_run bc3 5 in
  -- fold 0 (\acc i -> acc + i) n = sum(0..n-1)
  -- PUSH 0 (1,0), LOAD 0 (14,0), FOLD_BEGIN 12 (25,12),
  -- STORE 2 (15,2), STORE 1 (15,1), LOAD 1 (14,1), LOAD 2 (14,2), ADD (2), FOLD_END (26), HALT (0)
  let bc4 = (1, 0, 14, 0, 25, 12, 15, 2, 15, 1, 14, 1, 14, 2, 2, 26, 0) in
  let r4 = vm_run bc4 10 in
  -- Tuple: (3, 7).1 = 7
  let bc5 = (1, 3, 1, 7, 18, 2, 19, 1, 0) in
  let r5 = vm_run bc5 0 in
  -- Tuple-state fold: fib(n) = (fold (0,1) (\st i -> (st.1, st.0+st.1)) (n-1)).1
  -- PUSH 0, PUSH 1, MAKE_TUPLE 2   → init = (0, 1)
  -- LOAD 0, PUSH 1, SUB            → n - 1 (fold count)
  -- FOLD_BEGIN 18                   → body is 18 ints
  --   STORE 2                       → store idx
  --   STORE 1                       → store acc (the tuple)
  --   LOAD 1                        → load acc
  --   LOAD 1, TUPLE_GET 1           → st.1
  --   LOAD 1, TUPLE_GET 0           → st.0
  --   LOAD 1, TUPLE_GET 1           → st.1
  --   ADD                           → st.0 + st.1
  --   MAKE_TUPLE 2                  → (st.1, st.0+st.1)
  --   FOLD_END
  -- TUPLE_GET 1                     → result.1
  -- HALT
  let bc6 = (1, 0, 1, 1, 18, 2, 14, 0, 1, 1, 3, 25, 20, 15, 2, 15, 1, 14, 1, 19, 1, 14, 1, 19, 0, 14, 1, 19, 1, 2, 18, 2, 26, 19, 1, 0) in
  let r6 = vm_run bc6 10 in
  (expected, r1, r2, r3a, r3b, r4, r5, r6)
