-- save_pipeline_bc.iris — Pre-compile pipeline bytecodes and save counts
-- Outputs: (tok_count, par_count, ast_count) and the bytecodes as 3 fields

let ws_push stack item = (item, stack)
let cache_lookup nid cache =
  fold (0 - 1) (\s i -> if s >= 0 then s else if i >= list_len cache then s else let e = list_nth cache i in if e.0 == nid then e.1 else s) (list_len cache)

let compile_graph pg start_nid init_env init_ns max_iter =
  let init_state = (((0, start_nid), ()), (), init_env, init_ns, (), ()) in
  let final_state = fold init_state (\state step ->
    let ws = state.0 in let bc = state.1 in let env = state.2 in let ns = state.3 in let segs = state.4 in let cache = state.5 in
    if ws == () then state
    else let item = ws.0 in let rest = ws.1 in let tag = item.0 in
      if tag == 0 then let nid = item.1 in let cached = cache_lookup nid cache in
        if cached >= 0 then (rest, list_concat bc (14, cached), env, ns, segs, cache)
        else let kind = graph_get_kind pg nid in
          if kind == 5 then let tt = graph_get_lit_type_tag pg nid in let lv = graph_get_lit_value pg nid in
            if tt == 255 then let s = fold (0 - 1) (\s i -> if s >= 0 then s else if i >= list_len env then s else let e = list_nth env i in if e.0 == lv then e.1 else s) (list_len env) in
              (rest, list_concat bc (14, if s >= 0 then s else lv), env, ns, segs, cache)
            else (rest, list_concat bc (1, lv), env, ns, segs, cache)
          else let cs = ns in let ns2 = ns + 1 in let rest2 = ws_push rest (12, nid, cs) in
            if kind == 0 then let op = graph_get_prim_op pg nid in let ch = graph_outgoing pg nid in let nc = list_len ch in
              let bop = if op == 0 then 2 else if op == 1 then 3 else if op == 2 then 4 else if op == 3 then 5 else if op == 4 then 6 else if op == 16 then 23 else if op == 21 then 24 else if op == 32 then 8 else if op == 33 then 11 else if op == 34 then 9 else if op == 35 then 10 else if op == 36 then 12 else if op == 37 then 13 else if op == 176 then 30 else if op == 177 then 32 else if op == 192 then 31 else if op == 193 then 22 else if op == 194 then 35 else if op == 199 then 27 else if op == 206 then 34 else if op == 210 then 19 else if op == 214 then 21 else if op == 240 then 21 else 0 in
              if nc == 3 then let bop3 = if op == 178 then 33 else 0 in
                if bop3 >= 2 then (ws_push (ws_push (ws_push (ws_push rest2 (1, bop3)) (0, list_nth ch 2)) (0, list_nth ch 1)) (0, list_nth ch 0), bc, env, ns2, segs, cache)
                else (ws_push (ws_push (ws_push (ws_push rest2 (2, op, 3)) (0, list_nth ch 2)) (0, list_nth ch 1)) (0, list_nth ch 0), bc, env, ns2, segs, cache)
              else if nc == 2 then if bop >= 2 then (ws_push (ws_push (ws_push rest2 (1, bop)) (0, list_nth ch 1)) (0, list_nth ch 0), bc, env, ns2, segs, cache)
                else (ws_push (ws_push (ws_push rest2 (2, op, nc)) (0, list_nth ch 1)) (0, list_nth ch 0), bc, env, ns2, segs, cache)
              else if nc == 1 then if bop >= 2 then (ws_push (ws_push rest2 (1, bop)) (0, list_nth ch 0), bc, env, ns2, segs, cache)
                else (ws_push (ws_push rest2 (2, op, 1)) (0, list_nth ch 0), bc, env, ns2, segs, cache)
              else (rest2, bc, env, ns2, segs, cache)
            else if kind == 17 then let ch = graph_outgoing pg nid in (ws_push (ws_push rest2 (3, list_nth ch 1, list_nth ch 2)) (0, list_nth ch 0), bc, env, ns2, segs, cache)
            else if kind == 11 then let ch = graph_outgoing pg nid in let nc = list_len ch in let w = fold (ws_push rest2 (4, nc)) (\w i -> if i >= nc then w else ws_push w (0, list_nth ch (nc - 1 - i))) nc in (w, bc, env, ns2, segs, cache)
            else if kind == 13 then let ch = graph_outgoing pg nid in let fi = graph_get_field_index pg nid in (ws_push (ws_push rest2 (5, fi)) (0, list_nth ch 0), bc, env, ns2, segs, cache)
            else if kind == 2 then let ch = graph_outgoing pg nid in let b = bitand (graph_get_binder pg nid) 255 in let w0 = ws_push rest2 (11, env) in (ws_push w0 (0, list_nth ch 0), bc, list_append env (b, ns2), ns2 + 1, segs, cache)
            else if kind == 3 then let ch = graph_outgoing pg nid in let b = bitand (graph_get_binder pg nid) 255 in let w0 = ws_push rest2 (11, env) in (ws_push (ws_push (ws_push w0 (0, list_nth ch 1)) (6, ns2)) (0, list_nth ch 0), bc, list_append env (b, ns2), ns2 + 1, segs, cache)
            else if kind == 1 then let ch = graph_outgoing pg nid in let f = list_nth ch 0 in let a = list_nth ch 1 in
              if graph_get_kind pg f == 2 then let b = bitand (graph_get_binder pg f) 255 in let bd = list_nth (graph_outgoing pg f) 0 in let w0 = ws_push rest2 (11, env) in (ws_push (ws_push (ws_push w0 (0, bd)) (6, ns2)) (0, a), bc, list_append env (b, ns2), ns2 + 1, segs, cache)
              else (ws_push (ws_push rest2 (0, a)) (0, f), bc, env, ns2, segs, cache)
            else if kind == 8 then let ch = graph_outgoing pg nid in let step = list_nth ch 1 in let sc2 = graph_outgoing pg step in let ob = bitand (graph_get_binder pg step) 255 in let bd = list_nth sc2 0 in let ik = graph_get_kind pg bd in
              let ab = if ik == 2 then list_nth (graph_outgoing pg bd) 0 else bd in let ib = if ik == 2 then bitand (graph_get_binder pg bd) 255 else 0 in
              let e2 = list_append env (ob, ns2) in let e3 = if ik == 2 then list_append e2 (ib, ns2 + 1) else e2 in let w0 = ws_push rest2 (11, env) in
              (ws_push (ws_push (ws_push (ws_push (ws_push w0 (8, 0)) (0, ab)) (7, ns2, ns2 + 1)) (0, list_nth ch 2)) (0, list_nth ch 0), bc, e3, ns2 + 2, segs, cache)
            else if kind == 16 then let ch = graph_outgoing pg nid in let b = bitand (graph_get_binder pg nid) 255 in let w0 = ws_push rest2 (11, env) in (ws_push (ws_push (ws_push w0 (0, list_nth ch 1)) (6, ns2)) (0, list_nth ch 0), bc, list_append env (b, ns2), ns2 + 1, segs, cache)
            else (rest2, list_concat bc (1, 0), env, ns2, segs, cache)
      else if tag == 1 then (rest, list_concat bc (item.1,), env, ns, segs, cache)
      else if tag == 2 then (rest, list_concat bc (28, item.1, item.2), env, ns, segs, cache)
      else if tag == 3 then (ws_push (ws_push (ws_push (ws_push (ws_push rest (10, 0)) (0, item.2)) (9, 0)) (0, item.1)) (9, 0), bc, env, ns, segs, cache)
      else if tag == 4 then (rest, list_concat bc (18, item.1), env, ns, segs, cache)
      else if tag == 5 then (rest, list_concat bc (19, item.1), env, ns, segs, cache)
      else if tag == 6 then (rest, list_concat bc (15, item.1), env, ns, segs, cache)
      else if tag == 7 then
        (rest, (), env, ns, ((item.1, item.2, bc), segs), cache)
      else if tag == 8 then
        let fbc = bc in let a_s = (segs.0).0 in let i_s = (segs.0).1 in let sbc = (segs.0).2 in let rs = segs.1 in
        let bl = tuple_len fbc in
        (rest, list_concat (list_concat (list_concat (list_concat sbc (25, bl + 4)) (15, i_s)) (15, a_s)) (list_concat fbc (26,)), env, ns, rs, cache)
      else if tag == 9 then (rest, (), env, ns, (bc, segs), cache)
      else if tag == 10 then let then_bc = segs.0 in let s1 = segs.1 in let cond_bc = s1.0 in let rest_segs = s1.1 in let else_bc = bc in
        let tl = tuple_len then_bc in let el = tuple_len else_bc in let cl = tuple_len cond_bc in
        let jz_rel = 2 + tl + 2 in let jmp_rel = 2 + el in
        (rest, list_concat (list_concat (list_concat (list_concat cond_bc (17, jz_rel)) then_bc) (16, jmp_rel)) else_bc, env, ns, rest_segs, cache)
      else if tag == 11 then (rest, bc, item.1, ns, segs, cache)
      else if tag == 12 then (rest, list_concat bc (15, item.2, 14, item.2), env, ns, segs, list_append cache (item.1, item.2))
      else (rest, bc, env, ns, segs, cache)
  ) max_iter in
  list_concat (final_state.1) (0,)

let compile_to_bc source dummy_input num_params max_iter =
  let slen = str_len source in
  let pos = fold (0 - 1) (\p i ->
    if p >= 0 then p else if i >= slen - 2 then p
    else if char_at source i == 61 then if char_at source (i + 1) == 10 then i else p else p
  ) slen in
  let injected = str_concat (str_slice source 0 pos) (str_concat "=\n  (self_graph,\n" (str_concat (str_trim (str_slice source (pos + 2) slen)) ")")) in
  let m = compile_source injected in
  let nb = list_len (m.1) in
  let result = module_eval (m.0) (nb - 1) dummy_input in
  let pg = result.0 in
  let root = graph_get_root pg in
  let body = list_nth (graph_outgoing pg root) 1 in
  let init_env = if num_params == 2 then ((0, 0), (1, 1)) else ((0, 0),) in
  compile_graph pg body init_env num_params max_iter

let le64_bc v =
  let b0 = bitand v 255 in let n1 = shr v 8 in let b1 = bitand n1 255 in
  let n2 = shr n1 8 in let b2 = bitand n2 255 in let n3 = shr n2 8 in let b3 = bitand n3 255 in
  let n4 = shr n3 8 in let b4 = bitand n4 255 in let n5 = shr n4 8 in let b5 = bitand n5 255 in
  let n6 = shr n5 8 in let b6 = bitand n6 255 in let n7 = shr n6 8 in let b7 = bitand n7 255 in
  bytes_from_ints (b0, b1, b2, b3, b4, b5, b6, b7)

let emit_bc_data bc =
  let n = tuple_len bc in
  let header = le64_bc (n * 256) in
  let n_chunks = (n + 7) / 8 in
  fold header (\acc ci ->
    if ci * 8 >= n then acc
    else let base = ci * 8 in
      let chunk = fold () (\ch j ->
        if j >= 8 then ch else if base + j >= n then ch
        else let v = tuple_get bc (base + j) in
          let b0 = bitand v 255 in let v1 = shr v 8 in let b1 = bitand v1 255 in
          let v2 = shr v1 8 in let b2 = bitand v2 255 in let v3 = shr v2 8 in let b3 = bitand v3 255 in
          let v4 = shr v3 8 in let b4 = bitand v4 255 in let v5 = shr v4 8 in let b5 = bitand v5 255 in
          let v6 = shr v5 8 in let b6 = bitand v6 255 in let v7 = shr v6 8 in let b7 = bitand v7 255 in
          list_concat ch (b0, b1, b2, b3, b4, b5, b6, b7)
      ) 8 in
      bytes_concat acc (bytes_from_ints chunk)
  ) n_chunks

let main stage x =
  if stage == 0 then
    -- Compile tokenizer
    let bc = compile_to_bc (file_read "src/iris-programs/syntax/tokenizer.iris") "test" 1 500000 in
    (tuple_len bc, bc)
  else if stage == 1 then
    -- Compile parser
    let tok_m = compile_source (file_read "src/iris-programs/syntax/tokenizer.iris") in
    let tokens = module_eval (tok_m.0) 0 "let x = 1" in
    let bc = compile_to_bc (file_read "src/iris-programs/syntax/iris_parser.iris") (tokens, "let x = 1") 2 2000000 in
    (tuple_len bc, bc)
  else if stage == 2 then
    -- Compile AST compiler
    let tok_m = compile_source (file_read "src/iris-programs/syntax/tokenizer.iris") in
    let par_m = compile_source (file_read "src/iris-programs/syntax/iris_parser.iris") in
    let tokens = module_eval (tok_m.0) 0 "let f n = n + 1" in
    let tree = module_eval (par_m.0) 0 (tokens, "let f n = n + 1") in
    let bc = compile_to_bc (file_read "src/iris-programs/compiler/ast_compile_single.iris") (list_append () tree) 1 500000 in
    (tuple_len bc, bc)
  -- Stages 10-12: compile AND emit bc_data as Bytes (top-level emit_bc_data for JIT)
  else if stage == 10 then
    emit_bc_data (compile_to_bc (file_read "src/iris-programs/syntax/tokenizer.iris") "test" 1 500000)
  else if stage == 11 then
    let tok_m = compile_source (file_read "src/iris-programs/syntax/tokenizer.iris") in
    let tokens = module_eval (tok_m.0) 0 "let x = 1" in
    emit_bc_data (compile_to_bc (file_read "src/iris-programs/syntax/iris_parser.iris") (tokens, "let x = 1") 2 2000000)
  else if stage == 12 then
    let tok_m = compile_source (file_read "src/iris-programs/syntax/tokenizer.iris") in
    let par_m = compile_source (file_read "src/iris-programs/syntax/iris_parser.iris") in
    let tokens = module_eval (tok_m.0) 0 "let f n = n + 1" in
    let tree = module_eval (par_m.0) 0 (tokens, "let f n = n + 1") in
    emit_bc_data (compile_to_bc (file_read "src/iris-programs/compiler/ast_compile_single.iris") (list_append () tree) 1 500000)
  else 0
