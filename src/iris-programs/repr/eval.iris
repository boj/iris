-- Evaluation types: Value, StateStore, EvalTier, HwCounters
--
-- Mirrors the Rust eval.rs (558 LOC) in iris-repr.
--
-- Value type (16 variants):
--   0=Int, 1=Nat, 2=Float64, 3=Float32, 4=Bool, 5=Bytes,
--   6=Unit, 7=Tuple, 8=Tagged, 9=State, 10=Graph, 11=Program,
--   12=Future, 13=String, 14=Thunk
--
-- EvalTier (3 tiers):
--   A = Cheap (interpreter only, 10 test cases)
--   B = Full counters (50-200 test cases)
--   C = JIT + full counters (200+ test cases)
--
-- HwCounters: 7 hardware performance counters

-- ============================================================
-- Value type tags
-- ============================================================

let val_int : Int [cost: Const(1)] = 0
let val_nat : Int [cost: Const(1)] = 1
let val_float64 : Int [cost: Const(1)] = 2
let val_float32 : Int [cost: Const(1)] = 3
let val_bool : Int [cost: Const(1)] = 4
let val_bytes : Int [cost: Const(1)] = 5
let val_unit : Int [cost: Const(1)] = 6
let val_tuple : Int [cost: Const(1)] = 7
let val_tagged : Int [cost: Const(1)] = 8
let val_state : Int [cost: Const(1)] = 9
let val_graph : Int [cost: Const(1)] = 10
let val_program : Int [cost: Const(1)] = 11
let val_future : Int [cost: Const(1)] = 12
let val_string : Int [cost: Const(1)] = 13
let val_thunk : Int [cost: Const(1)] = 14

-- ============================================================
-- EvalTier constants
-- ============================================================

-- Tier A: Cheap interpreter evaluation, no HW counters, ~10 test cases.
let tier_a : Int [cost: Const(1)] = 0

-- Tier B: Full counters, perf_event_open, 50-200 test cases.
let tier_b : Int [cost: Const(1)] = 1

-- Tier C: JIT + full counters + rewrite rules, 200+ test cases.
let tier_c : Int [cost: Const(1)] = 2

-- ============================================================
-- EvalTier classification
-- ============================================================

-- Classify a program into its evaluation tier based on complexity.
-- graph_complexity: estimated complexity (node count + edge count)
-- has_effects: 1 if program has effect nodes, 0 otherwise
-- has_recursion: 1 if program has Fold/LetRec, 0 otherwise
-- Returns: EvalTier (0=A, 1=B, 2=C)
let classify_eval_tier graph_complexity has_effects has_recursion : Int -> Int -> Int -> Int [cost: Const(5)] =
  if has_effects == 1 then tier_c
  else if has_recursion == 1 then
    if graph_complexity > 50 then tier_c
    else tier_b
  else if graph_complexity > 20 then tier_b
  else tier_a

-- Get the test case count for a given tier.
let tier_test_count tier : Int -> Int [cost: Const(3)] =
  if tier == 0 then 10
  else if tier == 1 then 100
  else 500

-- Get the step limit for a given tier.
let tier_step_limit tier : Int -> Int [cost: Const(3)] =
  if tier == 0 then 100000
  else if tier == 1 then 1000000
  else 10000000

-- ============================================================
-- HwCounters representation
-- ============================================================

-- Pack hardware counters into a tuple of 7 values.
-- (instructions_retired, cycles, ipc_x1000, l1d_miss_pct, llc_miss_pct, dtlb_miss_pct, branch_miss_pct)
-- Floating-point rates are represented as permille (x1000) integers.

-- Compute IPC (instructions per cycle) as permille.
let compute_ipc instructions cycles : Int -> Int -> Int [cost: Const(2)] =
  if cycles == 0 then 0
  else (instructions * 1000) / cycles

-- Compute miss rate as permille from hits and total.
let compute_miss_rate misses total : Int -> Int -> Int [cost: Const(2)] =
  if total == 0 then 0
  else (misses * 1000) / total

-- ============================================================
-- Value type classification
-- ============================================================

-- Check if a value type tag is valid.
let is_valid_value_type tag : Int -> Int [cost: Const(2)] =
  if tag >= 0 then
    if tag <= 14 then 1 else 0
  else 0

-- Check if a value type is numeric (Int, Nat, Float64, Float32).
let is_numeric_type tag : Int -> Int [cost: Const(2)] =
  if tag >= 0 then
    if tag <= 3 then 1 else 0
  else 0

-- Check if a value type is a compound type (Tuple, Tagged, State, Graph, Program).
let is_compound_value tag : Int -> Int [cost: Const(5)] =
  if tag == 7 then 1
  else if tag == 8 then 1
  else if tag == 9 then 1
  else if tag == 10 then 1
  else if tag == 11 then 1
  else 0

-- Check if a value type supports comparison (Int, Nat, Float64, Float32, Bool).
let is_comparable_type tag : Int -> Int [cost: Const(2)] =
  if tag >= 0 then
    if tag <= 4 then 1 else 0
  else 0

-- ============================================================
-- StateStore operations
-- ============================================================

-- Model a StateStore as a key-value store.
-- In IRIS, State is a first-class value (Value::State).
-- Operations are modeled as pure functions on state values.

-- State store is empty: returns 1 if empty, 0 otherwise.
-- Represented by checking if the state "size" key equals 0.
let is_empty_state state_size : Int -> Int [cost: Const(1)] =
  if state_size == 0 then 1 else 0

-- ============================================================
-- EvalResult representation
-- ============================================================

-- EvalResult fields as a flat tuple:
-- (correctness_score_pct, wall_time_ns, compile_time_ns, tier_executed, cache_hit)
-- correctness_score is represented as percentage (0-100).

-- Compute correctness score from expected and actual outputs.
-- correct_count: number of correct test cases
-- total_count: total test cases
-- Returns: percentage (0-100)
let compute_correctness correct_count total_count : Int -> Int -> Int [cost: Const(2)] =
  if total_count == 0 then 0
  else (correct_count * 100) / total_count

-- FNV-1a hash of outputs (simplified for IRIS).
-- Mirrors the outputs_hash field in EvalResult.
let fnv1a_hash v prev_hash : Int -> Int -> Int [cost: Const(2)] =
  let mixed = prev_hash * 1099511628211 in
  bitxor mixed v

-- ============================================================
-- EvalError classification
-- ============================================================

-- Error variant tags matching EvalError in Rust.
let err_compilation : Int [cost: Const(1)] = 0
let err_timeout : Int [cost: Const(1)] = 1
let err_memory_exceeded : Int [cost: Const(1)] = 2
let err_execution_fault : Int [cost: Const(1)] = 3
let err_arena_exhausted : Int [cost: Const(1)] = 4
let err_perf_unavailable : Int [cost: Const(1)] = 5

-- Check if an error is recoverable (can retry with different config).
let is_recoverable_error err_tag : Int -> Int [cost: Const(3)] =
  if err_tag == 1 then 1
  else if err_tag == 4 then 1
  else if err_tag == 5 then 1
  else 0

-- ============================================================
-- EffectTag mapping
-- ============================================================

-- Effect tag constants from eval.rs EffectTag.
let eff_print : Int [cost: Const(1)] = 0
let eff_read_line : Int [cost: Const(1)] = 1
let eff_http_get : Int [cost: Const(1)] = 2
let eff_http_post : Int [cost: Const(1)] = 3
let eff_file_read : Int [cost: Const(1)] = 4
let eff_file_write : Int [cost: Const(1)] = 5
let eff_db_query : Int [cost: Const(1)] = 6
let eff_db_execute : Int [cost: Const(1)] = 7
let eff_sleep : Int [cost: Const(1)] = 8
let eff_timestamp : Int [cost: Const(1)] = 9
let eff_random : Int [cost: Const(1)] = 10
let eff_log : Int [cost: Const(1)] = 11
let eff_send_msg : Int [cost: Const(1)] = 12
let eff_recv_msg : Int [cost: Const(1)] = 13

-- Raw I/O effects (0x10-0x1F)
let eff_tcp_connect : Int [cost: Const(1)] = 16
let eff_tcp_read : Int [cost: Const(1)] = 17
let eff_tcp_write : Int [cost: Const(1)] = 18
let eff_tcp_close : Int [cost: Const(1)] = 19

-- Check if an effect tag is valid.
let is_valid_effect tag : Int -> Int [cost: Const(3)] =
  if tag >= 0 then
    if tag <= 13 then 1
    else if tag >= 16 then
      if tag <= 43 then 1 else 0
    else 0
  else 0

-- Check if an effect is pure (no I/O side effects).
-- Only Timestamp and Random are "pseudo-pure".
let is_pure_effect tag : Int -> Int [cost: Const(2)] =
  if tag == 9 then 1
  else if tag == 10 then 1
  else 0
