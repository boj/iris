-- Type system operations: type constructors, checking, and manipulation
--
-- Mirrors the Rust types module in iris-repr/src/types.rs.
-- Provides the type algebra for IRIS's 11-variant type system:
--   0 = Primitive(PrimType)
--   1 = Product(Vec<TypeId>)  — tuples/structs
--   2 = Sum(Vec<(Tag, TypeId)>)  — tagged unions
--   3 = Recursive(BoundVar, TypeId)  — mu X. F(X)
--   4 = ForAll(BoundVar, TypeId)  — polymorphism
--   5 = Arrow(TypeId, TypeId, CostBound)  — functions with cost
--   6 = Refined(TypeId, Predicate)  — refinement types
--   7 = NeuralGuard(TypeId, TypeId, GuardSpec, CostBound)
--   8 = Exists(BoundVar, TypeId)  — existential types
--   9 = Vec(TypeId, SizeTerm)  — sized vectors
--  10 = HWParam(TypeId, HardwareProfile)

-- PrimType constants
let prim_int : Int [cost: Const(1)] = 0
let prim_nat : Int [cost: Const(1)] = 1
let prim_float64 : Int [cost: Const(1)] = 2
let prim_float32 : Int [cost: Const(1)] = 3
let prim_bool : Int [cost: Const(1)] = 4
let prim_bytes : Int [cost: Const(1)] = 5
let prim_unit : Int [cost: Const(1)] = 6

-- TypeDef kind constants
let typedef_primitive : Int [cost: Const(1)] = 0
let typedef_product : Int [cost: Const(1)] = 1
let typedef_sum : Int [cost: Const(1)] = 2
let typedef_recursive : Int [cost: Const(1)] = 3
let typedef_forall : Int [cost: Const(1)] = 4
let typedef_arrow : Int [cost: Const(1)] = 5
let typedef_refined : Int [cost: Const(1)] = 6
let typedef_neural : Int [cost: Const(1)] = 7
let typedef_exists : Int [cost: Const(1)] = 8
let typedef_vec : Int [cost: Const(1)] = 9
let typedef_hwparam : Int [cost: Const(1)] = 10

-- Check if a type definition kind is valid (0-10)
let is_valid_typedef kind : Int -> Int [cost: Const(2)] =
  if kind >= 0 && kind <= 10 then 1 else 0

-- Check if a PrimType is valid (0-6)
let is_valid_primtype prim : Int -> Int [cost: Const(2)] =
  if prim >= 0 && prim <= 6 then 1 else 0

-- Check if a type is a function type (Arrow)
let is_function_type kind : Int -> Int [cost: Const(1)] =
  if kind == 5 then 1 else 0

-- Check if a type is recursive (contains mu binder)
let is_recursive_type kind : Int -> Int [cost: Const(1)] =
  if kind == 3 then 1 else 0

-- Check if a type is polymorphic (ForAll or Exists)
let is_polymorphic kind : Int -> Int [cost: Const(2)] =
  if kind == 4 then 1
  else if kind == 8 then 1
  else 0

-- Check if a type is a compound type (Product, Sum, Arrow, etc.)
let is_compound_type kind : Int -> Int [cost: Const(3)] =
  if kind == 1 then 1
  else if kind == 2 then 1
  else if kind == 5 then 1
  else 0

-- Compute a hash for a TypeId from a TypeDef
-- Simplified: hash based on kind and payload
let compute_type_hash kind payload : Int -> Int -> Int [cost: Const(2)] =
  kind * 1000003 + payload * 7 + 42

-- Check if two types are structurally equal
-- type_kind_a, type_kind_b: TypeDef kind tags
-- payload_a, payload_b: type payloads
let types_equal kind_a payload_a kind_b payload_b : Int -> Int -> Int -> Int -> Int [cost: Const(2)] =
  if kind_a == kind_b && payload_a == payload_b then 1 else 0

-- Count the number of type variables in a type (bound vars)
-- For Recursive: 1, ForAll: 1, Exists: 1, others: 0
let count_type_vars kind : Int -> Int [cost: Const(4)] =
  if kind == 3 then 1
  else if kind == 4 then 1
  else if kind == 8 then 1
  else 0

-- Get the arity of a Product type (number of fields)
-- For non-Product types, returns 0
let product_arity kind field_count : Int -> Int -> Int [cost: Const(1)] =
  if kind == 1 then field_count else 0

-- Get the number of variants in a Sum type
-- For non-Sum types, returns 0
let sum_variant_count kind variant_count : Int -> Int -> Int [cost: Const(1)] =
  if kind == 2 then variant_count else 0

-- Check if a DecreaseWitness is Structural (rec_arg is subterm of outer_arg)
-- witness_kind: 0=Structural, 1=Sized, 2=WellFounded
let is_structural_decrease witness_kind : Int -> Int [cost: Const(1)] =
  if witness_kind == 0 then 1 else 0

-- LIA formula constants for refinement types
-- formula_kind: 0=True, 1=False, 2=And, 3=Or, 4=Not, 5=Implies, 6=Atom
let lia_true : Int [cost: Const(1)] = 0
let lia_false : Int [cost: Const(1)] = 1
let lia_and : Int [cost: Const(1)] = 2
let lia_or : Int [cost: Const(1)] = 3
let lia_not : Int [cost: Const(1)] = 4
let lia_implies : Int [cost: Const(1)] = 5
let lia_atom : Int [cost: Const(1)] = 6

-- Evaluate a simple LIA formula (True, False, And, Or, Not)
-- Returns 1 for true, 0 for false
let eval_lia formula_kind left right : Int -> Int -> Int -> Int [cost: Const(6)] =
  if formula_kind == 0 then 1
  else if formula_kind == 1 then 0
  else if formula_kind == 2 then left * right
  else if formula_kind == 3 then if left == 1 then 1 else right
  else if formula_kind == 4 then if left == 1 then 0 else 1
  else if formula_kind == 5 then if left == 1 then right else 1
  else 0
