#!/usr/bin/env bash
# build-native-self: Fully self-hosted IRIS native binary builder.
#
# Compiles ALL pipeline stages using iris-native itself:
#   - Tokenizer, parser, AST compiler: compiled via --compile flag
#   - Native VM: compiled and executed to produce x86 machine code
#   - Startup stub: extracted from current binary, offsets patched
#
# The ONLY non-IRIS dependency is the stub template (frozen x86 machine code).
# Everything else is compiled from .iris source by iris-native.
#
# Usage: bootstrap/build-native-self [-o output]
set -euo pipefail

DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT="$(cd "$DIR/.." && pwd)"
IRIS_NATIVE="${IRIS_NATIVE:-$DIR/iris-native}"
TMPDIR=$(mktemp -d)
trap "rm -rf $TMPDIR" EXIT

OUTPUT="${2:-$DIR/iris-native}"

echo "=== Self-Hosted IRIS Native Build ==="
echo "Compiler: $IRIS_NATIVE"
echo

cd "$PROJECT"

# Step 1: Compile pipeline stages using iris-native
echo -n "  Tokenizer...  "
"$IRIS_NATIVE" --compile src/iris-programs/syntax/tokenizer.iris > "$TMPDIR/tok.bin"
echo "$(wc -c < "$TMPDIR/tok.bin") bytes"

echo -n "  Parser...     "
"$IRIS_NATIVE" --compile src/iris-programs/syntax/iris_parser.iris > "$TMPDIR/par.bin"
echo "$(wc -c < "$TMPDIR/par.bin") bytes"

echo -n "  AST compiler..."
"$IRIS_NATIVE" --compile src/iris-programs/compiler/ast_compile_single.iris > "$TMPDIR/ast.bin"
echo " $(wc -c < "$TMPDIR/ast.bin") bytes"

# Step 2: Compile native VM from source
# native_vm.iris with arg=1 returns the x86 machine code as Bytes.
# The printer adds a trailing newline; strip it with head -c.
echo -n "  Native VM...  "
VM_SIZE=$("$IRIS_NATIVE" src/iris-programs/compiler/native_vm.iris 0 2>/dev/null)
"$IRIS_NATIVE" src/iris-programs/compiler/native_vm.iris 1 2>/dev/null | head -c "$VM_SIZE" > "$TMPDIR/vm.bin"
echo "$VM_SIZE bytes (compiled from source)"

HEADER_SIZE=120

# Step 3: Compute layout (need stub size from a test run first)
TOK_SIZE=$(wc -c < "$TMPDIR/tok.bin")
PAR_SIZE=$(wc -c < "$TMPDIR/par.bin")
AST_SIZE=$(wc -c < "$TMPDIR/ast.bin")

# Step 3.5: Generate ELF headers + startup stub using IRIS
# emit_elf_stub.iris has the stub template embedded as byte constants.
# The build script seds in the layout offsets, then iris-native runs it.
STUB_SIZE=788

VM_OFF=$((HEADER_SIZE + STUB_SIZE))
TOK_OFF=$((VM_OFF + VM_SIZE))
PAR_OFF=$((TOK_OFF + TOK_SIZE))
AST_OFF=$((PAR_OFF + PAR_SIZE))
FILE_SIZE=$((AST_OFF + AST_SIZE))
MEM_SIZE=$((FILE_SIZE + 262144))

echo -n "  ELF + Stub... "
sed "s/\\\$TOK_OFF/$TOK_OFF/g; s/\\\$PAR_OFF/$PAR_OFF/g; s/\\\$AST_OFF/$AST_OFF/g; s/\\\$FILE_SIZE/$FILE_SIZE/g; s/\\\$MEM_SIZE/$MEM_SIZE/g" \
  "$PROJECT/src/iris-programs/compiler/emit_elf_stub.iris" > "$TMPDIR/gen_elf_stub.iris"
"$IRIS_NATIVE" "$TMPDIR/gen_elf_stub.iris" 0 2>/dev/null | head -c 908 > "$TMPDIR/headers_and_stub.bin"
# Split into headers (120 bytes) and stub (788 bytes)
head -c 120 "$TMPDIR/headers_and_stub.bin" > "$TMPDIR/headers.bin"
tail -c +121 "$TMPDIR/headers_and_stub.bin" > "$TMPDIR/stub.bin"
echo "908 bytes (compiled from source)"

# Step 6: Assemble final binary
cat "$TMPDIR/headers.bin" "$TMPDIR/stub.bin" "$TMPDIR/vm.bin" \
    "$TMPDIR/tok.bin" "$TMPDIR/par.bin" "$TMPDIR/ast.bin" > "$OUTPUT"
chmod +x "$OUTPUT"

echo
echo "=== Self-hosted binary: $OUTPUT ($(wc -c < "$OUTPUT") bytes) ==="
echo "  Layout: Headers($HEADER_SIZE) + Stub($STUB_SIZE) + VM($VM_SIZE)"
echo "          + Tok($TOK_SIZE) + Par($PAR_SIZE) + AST($AST_SIZE)"
echo
echo "Usage: $OUTPUT <source.iris> <arg>"
