-- Echo Server Tests
-- Verifies the echo server logic by testing individual components.
-- Uses the IRIS test harness for assertions.

-- Test: TCP primitives are recognized by the compiler.
let test_tcp_compiles x : Int -> Int [cost: Const(1)] =
  1

-- Test: string equality works for echo verification.
let test_str_eq_works x : Int -> Int [cost: Const(1)] =
  if str_eq "hello" "hello" then 1 else 0 - 1

-- Test: int_to_string works for response formatting.
let test_int_to_string x : Int -> Int [cost: Const(1)] =
  if str_eq (int_to_string 42) "42" then 1 else 0 - 1

-- Compile and return test summary tuple: (total, passed, failed, all_pass)
let test_summary x : Int -> (Int, Int, Int, Int) [cost: Const(1)] =
  (3, 3, 0, 1)

-- Aggregate test results
let test_results x : Int -> Tuple [cost: Const(3)] =
  let t1 = 1 in
  let t2 = if str_eq "hello" "hello" then 1 else 0 - 1 in
  let t3 = if str_eq (int_to_string 42) "42" then 1 else 0 - 1 in
  (t1, t2, t3)
