-- Binary Search Tree (BST)
-- Represented using State (map) with integer node IDs.
-- Each node stores: value, left child ID, right child ID.
-- Node ID -1 means "null" (no child).
--
-- Layout in State:
--   "next_id" -> next available node ID
--   "{id}_val" -> node value
--   "{id}_left" -> left child ID
--   "{id}_right" -> right child ID
--   "root" -> root node ID

-- Create an empty BST state.
let bst_empty x : Int -> State [cost: Const(1)] =
  let m = map_insert state_empty "next_id" 0 in
  map_insert m "root" -1

-- Allocate a new node, returns (new_state, node_id).
let bst_alloc_node m val : State -> Int -> Tuple [cost: Const(1)] =
  let nid = map_get m "next_id" in
  let m = map_insert m "next_id" (nid + 1) in
  let key_val = str_concat (int_to_string nid) "_val" in
  let key_left = str_concat (int_to_string nid) "_left" in
  let key_right = str_concat (int_to_string nid) "_right" in
  let m = map_insert m key_val val in
  let m = map_insert m key_left -1 in
  let m = map_insert m key_right -1 in
  (m, nid)

-- Get a node's value field.
let node_val m nid : State -> Int -> Int [cost: Const(1)] =
  map_get m (str_concat (int_to_string nid) "_val")

-- Get a node's left child ID.
let node_left m nid : State -> Int -> Int [cost: Const(1)] =
  map_get m (str_concat (int_to_string nid) "_left")

-- Get a node's right child ID.
let node_right m nid : State -> Int -> Int [cost: Const(1)] =
  map_get m (str_concat (int_to_string nid) "_right")

-- Set a node's left child.
let node_set_left m nid child_id : State -> Int -> Int -> State [cost: Const(1)] =
  map_insert m (str_concat (int_to_string nid) "_left") child_id

-- Set a node's right child.
let node_set_right m nid child_id : State -> Int -> Int -> State [cost: Const(1)] =
  map_insert m (str_concat (int_to_string nid) "_right") child_id

-- Insert a value into the BST. Returns updated state.
let rec bst_insert_node m node_id val : State -> Int -> Int -> State [cost: Unknown] =
  if node_id == -1 then m  -- should not happen; allocation handled by caller
  else
    let v = node_val m node_id in
    if val == v then m  -- duplicate, no change
    else if val < v then
      let left = node_left m node_id in
      if left == -1 then
        let result = bst_alloc_node m val in
        let m2 = result.0 in
        let new_id = result.1 in
        node_set_left m2 node_id new_id
      else
        bst_insert_node m left val
    else
      let right = node_right m node_id in
      if right == -1 then
        let result = bst_alloc_node m val in
        let m2 = result.0 in
        let new_id = result.1 in
        node_set_right m2 node_id new_id
      else
        bst_insert_node m right val

-- Public insert: handles the root case.
let bst_insert m val : State -> Int -> State [cost: Unknown] =
  let root = map_get m "root" in
  if root == -1 then
    let result = bst_alloc_node m val in
    let m2 = result.0 in
    let new_id = result.1 in
    map_insert m2 "root" new_id
  else
    bst_insert_node m root val

-- Search for a value. Returns true/false.
let rec bst_search m node_id val : State -> Int -> Int -> Bool [cost: Unknown] =
  if node_id == -1 then false
  else
    let v = node_val m node_id in
    if val == v then true
    else if val < v then bst_search m (node_left m node_id) val
    else bst_search m (node_right m node_id) val

-- In-order traversal: returns sorted tuple of all values.
let rec bst_inorder m node_id : State -> Int -> Tuple [cost: Unknown] =
  if node_id == -1 then ()
  else
    let left_vals = bst_inorder m (node_left m node_id) in
    let right_vals = bst_inorder m (node_right m node_id) in
    list_concat left_vals (list_append right_vals (node_val m node_id))

-- Actually: append val between left and right for sorted order.
let rec bst_inorder_sorted m node_id : State -> Int -> Tuple [cost: Unknown] =
  if node_id == -1 then ()
  else
    let left_vals = bst_inorder_sorted m (node_left m node_id) in
    let v = node_val m node_id in
    let right_vals = bst_inorder_sorted m (node_right m node_id) in
    list_concat (list_append left_vals v) right_vals

-- Find minimum value (leftmost node).
let rec bst_min m node_id : State -> Int -> Int [cost: Unknown] =
  if node_id == -1 then -1
  else
    let left = node_left m node_id in
    if left == -1 then node_val m node_id
    else bst_min m left

-- Find maximum value (rightmost node).
let rec bst_max m node_id : State -> Int -> Int [cost: Unknown] =
  if node_id == -1 then -1
  else
    let right = node_right m node_id in
    if right == -1 then node_val m node_id
    else bst_max m right

-- Build a BST from an unsorted tuple.
let bst_from_list xs : Tuple -> State [cost: Unknown] =
  fold (bst_empty 0) (\m x -> bst_insert m x) xs

-- Test
let test_bst x : Int -> Tuple =
  let m = bst_from_list (5, 3, 7, 1, 4, 6, 8, 2) in
  let root = map_get m "root" in
  let found = bst_search m root 4 in
  let not_found = bst_search m root 9 in
  let minimum = bst_min m root in
  let maximum = bst_max m root in
  let sorted = bst_inorder_sorted m root in
  (found, not_found, minimum, maximum, sorted)
