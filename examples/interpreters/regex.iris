-- Inline helper: fold with early termination via (continue?, acc) pairs.
-- step_fn receives the current accumulator and returns (should_continue, new_acc).
-- When should_continue is false, the remaining elements are skipped.
-- This simulates a `while` / early-exit `fold` without mutable state.
let fold_while init step_fn xs =
  let result = fold (true, init) (\state elem ->
    if state.0 then step_fn state.1 elem else state
  ) xs in
  result.1

-- Simple Regex Matcher
-- Supports: literal chars, . (any), * (zero or more), + (one or more), ? (optional)
-- Patterns and strings are represented as tuples of character codes.
--
-- FIXME: A proper regex engine needs backtracking or NFA simulation.
-- This simplified version handles basic patterns without alternation or grouping.
-- FIXME: IRIS lacks a way to break out of a recursive match early when the first
-- successful path is found. fold_while helps but the NFA state explosion makes
-- this fundamentally difficult without mutable state or continuations.

-- Special pattern codes
-- 46 = '.', 42 = '*', 43 = '+', 63 = '?'

-- Match a single character against a pattern element.
let match_char pat_char text_char : Int -> Int -> Bool [cost: Const(1)] =
  if pat_char == 46 then true  -- '.' matches anything
  else pat_char == text_char

-- Match pattern starting at pat_pos against text starting at text_pos.
-- Returns the number of characters consumed, or -1 if no match.
let rec regex_match_aux pat pat_pos text text_pos : Tuple -> Int -> Tuple -> Int -> Int [cost: Unknown] =
  let pat_len = list_len pat in
  let text_len = list_len text in
  -- End of pattern = success
  if pat_pos >= pat_len then 0
  else
    let pc = list_nth pat pat_pos in
    -- Check if next pattern char is a quantifier
    let has_next = pat_pos + 1 < pat_len in
    let next_is_star = has_next && list_nth pat (pat_pos + 1) == 42 in
    let next_is_plus = has_next && list_nth pat (pat_pos + 1) == 43 in
    let next_is_question = has_next && list_nth pat (pat_pos + 1) == 63 in
    if next_is_star then
      -- Try matching 0 or more of pc (greedy: try max first, fall back to fewer)
      -- Phase 1: scan forward to find the maximum number of consecutive matches.
      let max_match = fold_while 0 (\pair ->
        let count = pair.0 in
        let idx = pair.1 in
        if text_pos + count >= text_len then (false, count)
        else if match_char pc (list_nth text (text_pos + count)) then
          (true, count + 1)
        else (false, count)
      ) (list_range 0 (text_len + 1)) in
      -- Phase 2: try counts from max down to 0; return on the first that allows
      -- the rest of the pattern to match (fold_while stops at first success).
      fold_while -1 (\pair ->
        let best = pair.0 in
        let try_count = pair.1 in
        if try_count < 0 then (false, best)
        else
          let rest = regex_match_aux pat (pat_pos + 2) text (text_pos + try_count) in
          if rest >= 0 then (false, try_count + rest)  -- success, stop trying
          else (true, best)  -- no match at this count, keep trying fewer
      ) (list_range 0 (max_match + 1))
    else if next_is_plus then
      -- One or more: must match at least once
      if text_pos >= text_len then -1
      else if match_char pc (list_nth text text_pos) == false then -1
      else
        -- Matched one, now behave like * for the rest
        let star_result = regex_match_aux pat pat_pos text (text_pos + 1) in
        if star_result >= 0 then 1 + star_result
        else
          let rest = regex_match_aux pat (pat_pos + 2) text (text_pos + 1) in
          if rest >= 0 then 1 + rest else -1
    else if next_is_question then
      -- Zero or one: try matching one first
      if text_pos < text_len && match_char pc (list_nth text text_pos) then
        let rest = regex_match_aux pat (pat_pos + 2) text (text_pos + 1) in
        if rest >= 0 then 1 + rest
        else regex_match_aux pat (pat_pos + 2) text text_pos
      else
        regex_match_aux pat (pat_pos + 2) text text_pos
    else
      -- Plain character
      if text_pos >= text_len then -1
      else if match_char pc (list_nth text text_pos) then
        let rest = regex_match_aux pat (pat_pos + 1) text (text_pos + 1) in
        if rest >= 0 then 1 + rest else -1
      else -1

-- Match a pattern against a string (both as char-code tuples).
-- Returns true if the pattern matches the entire string.
let regex_match pat text : Tuple -> Tuple -> Bool [cost: Unknown] =
  let result = regex_match_aux pat 0 text 0 in
  result == list_len text

-- Test
let test_regex x : Int -> Tuple =
  -- "ab" matches "ab"
  let r1 = regex_match (97, 98) (97, 98) in
  -- "a.c" matches "abc"
  let r2 = regex_match (97, 46, 99) (97, 98, 99) in
  -- "a*" matches "" and "aaa"
  let r3 = regex_match (97, 42) () in
  let r4 = regex_match (97, 42) (97, 97, 97) in
  -- "a+" must match at least one
  let r5 = regex_match (97, 43) () in          -- false
  let r6 = regex_match (97, 43) (97, 97) in    -- true
  (r1, r2, r3, r4, r5, r6)
