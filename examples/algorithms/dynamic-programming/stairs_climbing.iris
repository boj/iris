-- Stair Climbing Problem
-- Count the number of distinct ways to climb n stairs,
-- taking 1 or 2 steps at a time. (Fibonacci variant.)

-- Recursive with memoization via iterative DP.
let stairs n : Int -> Int [cost: Linear(n)] =
  if n <= 0 then 1
  else if n == 1 then 1
  else
    -- dp[i] = ways to reach step i
    -- dp[0] = 1, dp[1] = 1, dp[i] = dp[i-1] + dp[i-2]
    let init = (1, 1) in
    let result = fold init (\pair step ->
      let a = pair.0 in
      let b = pair.1 in
      (b, a + b)
    ) (list_range 2 (n + 1)) in
    result.1

-- Generalized: allow steps of size 1..k.
let stairs_k n k : Int -> Int -> Int [cost: Unknown] =
  if n <= 0 then 1
  else
    let init = map (\i -> if i == 0 then 1 else 0) (list_range 0 (n + 1)) in
    let dp = fold init (\dp i ->
      let val = fold 0 (\acc s ->
        if i - s >= 0 then acc + list_nth dp (i - s) else acc
      ) (list_range 1 (k + 1)) in
      let prefix = list_take dp i in
      let suffix = list_drop dp (i + 1) in
      list_concat (list_append prefix val) suffix
    ) (list_range 1 (n + 1)) in
    list_nth dp n

-- Test
let test_stairs x : Int -> Tuple =
  let s5 = stairs 5 in       -- 8 ways
  let s10 = stairs 10 in     -- 89 ways
  let sk53 = stairs_k 5 3 in -- steps of 1,2,3
  (s5, s10, sk53)
