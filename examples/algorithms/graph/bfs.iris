-- Breadth-First Search (BFS)
-- Explore a graph level by level using a queue.
-- Graph represented as adjacency lists: graph[i] = tuple of neighbor indices.

-- Check if a value exists in a tuple.
let contains xs val : Tuple -> Int -> Bool [cost: Linear(xs)] =
  fold false (\found x -> if x == val then true else found) xs

-- BFS from a start node. Returns visited nodes in BFS order.
-- Uses a tuple as a FIFO queue (dequeue from front, enqueue at back).
let rec bfs_aux graph queue visited : Tuple -> Tuple -> Tuple -> Tuple [cost: Unknown] =
  let n = list_len queue in
  if n == 0 then visited
  else
    let node = list_nth queue 0 in           -- dequeue from front
    let rest_queue = list_drop queue 1 in
    if contains visited node then
      bfs_aux graph rest_queue visited
    else
      let new_visited = list_append visited node in
      let neighbors = list_nth graph node in
      -- Enqueue unvisited neighbors
      let new_queue = fold rest_queue (\q nb ->
        if contains new_visited nb then q
        else list_append q nb
      ) neighbors in
      bfs_aux graph new_queue new_visited

let bfs graph start : Tuple -> Int -> Tuple [cost: Unknown] =
  bfs_aux graph (start,) ()

-- BFS with distance tracking: returns a tuple of (node, dist) pairs.
-- IRIS tuples can be nested — ((node, dist), ...) — so we accumulate
-- (node, dist) tuples directly. Queue entries are also (node, dist) pairs.
let rec bfs_dist_aux graph queue visited : Tuple -> Tuple -> Tuple -> Tuple [cost: Unknown] =
  let n = list_len queue in
  if n == 0 then visited
  else
    let entry = list_nth queue 0 in       -- entry = (node, dist)
    let node = entry.0 in
    let dist = entry.1 in
    let rest_queue = list_drop queue 1 in
    -- Check if node is already in visited (search by node id)
    let already = fold false (\found pair -> if pair.0 == node then true else found) visited in
    if already then
      bfs_dist_aux graph rest_queue visited
    else
      let new_visited = list_append visited (node, dist) in
      let neighbors = list_nth graph node in
      let new_queue = fold rest_queue (\q nb ->
        let nb_visited = fold false (\found pair -> if pair.0 == nb then true else found) new_visited in
        if nb_visited then q
        else list_append q (nb, dist + 1)
      ) neighbors in
      bfs_dist_aux graph new_queue new_visited

let bfs_distances graph start : Tuple -> Int -> Tuple [cost: Unknown] =
  bfs_dist_aux graph ((start, 0),) ()

-- Test: undirected graph (each edge listed in both directions)
--   0 -- 1, 0 -- 2
--   1 -- 3, 2 -- 3
--   3 -- 4
let test_bfs x : Int -> Tuple =
  let graph = ((1, 2), (0, 3), (0, 3), (1, 2, 4), (3,)) in
  let order = bfs graph 0 in
  -- bfs_distances returns ((node, dist), ...) nested tuples
  -- node 0: dist 0, nodes 1 and 2: dist 1, node 3: dist 2, node 4: dist 3
  let dists = bfs_distances graph 0 in
  let d0 = (list_nth dists 0).1 in  -- dist to node 0 = 0
  let d4 = (list_nth dists 4).1 in  -- dist to node 4 = 3
  (order, d0, d4)
