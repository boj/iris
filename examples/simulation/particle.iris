-- 2D Particle Simulation
-- Simulates particles with position, velocity, and simple physics.
-- Uses Verlet integration for stability.

type Vec2 = (Float64, Float64)
type Particle = (Float64, Float64, Float64, Float64, Float64)  -- (x, y, vx, vy, mass)

-- System state: tuple of particles

-- Compute gravitational force between two particles.
-- Returns (fx, fy) force on particle 1 from particle 2.
let gravity p1 p2 g : Particle -> Particle -> Float -> Vec2 [cost: Const(20)] =
  let (x1, y1, _, _, m1) = p1 in
  let (x2, y2, _, _, m2) = p2 in
  let dx = x2 - x1 in
  let dy = y2 - y1 in
  let dist_sq = dx * dx + dy * dy in
  let min_dist = 0.1 in
  let d2 = if dist_sq < min_dist then min_dist else dist_sq in
  let dist = math_sqrt d2 in
  let force = g * m1 * m2 / d2 in
  (force * dx / dist, force * dy / dist)

-- Compute total force on particle i from all other particles.
let total_force particles i g : Tuple -> Int -> Float -> Vec2 [cost: Unknown] =
  let p = list_nth particles i in
  let n = list_len particles in
  fold (0.0, 0.0) (\(ax, ay) j ->
    if j == i then (ax, ay)
    else
      let (fx, fy) = gravity p (list_nth particles j) g in
      (ax + fx, ay + fy)
  ) (list_range 0 n)

-- Advance one timestep using Euler integration.
let step particles dt g : Tuple -> Float -> Float -> Tuple [cost: Unknown] =
  let n = list_len particles in
  map (\i ->
    let (x, y, vx, vy, mass) = list_nth particles i in
    let (fx, fy) = total_force particles i g in
    let ax = fx / mass in
    let ay = fy / mass in
    let new_vx = vx + ax * dt in
    let new_vy = vy + ay * dt in
    let new_x = x + new_vx * dt in
    let new_y = y + new_vy * dt in
    (new_x, new_y, new_vx, new_vy, mass)
  ) (list_range 0 n)

-- Run simulation for n steps.
let simulate particles n_steps dt g : Tuple -> Int -> Float -> Float -> Tuple [cost: Unknown] =
  fold particles (\state i -> step state dt g) (list_range 0 n_steps)

-- Compute total kinetic energy.
let kinetic_energy particles : Tuple -> Float [cost: Linear(particles)] =
  fold 0.0 (\acc (_, _, vx, vy, mass) ->
    acc + 0.5 * mass * (vx * vx + vy * vy)
  ) particles

-- Compute center of mass.
let center_of_mass particles : Tuple -> Vec2 [cost: Linear(particles)] =
  let total_mass = fold 0.0 (\acc (_, _, _, _, mass) -> acc + mass) particles in
  let cx = fold 0.0 (\acc (x, _, _, _, mass) -> acc + x * mass) particles in
  let cy = fold 0.0 (\acc (_, y, _, _, mass) -> acc + y * mass) particles in
  (cx / total_mass, cy / total_mass)

-- Test: two-body orbit
let test_particles x : Int -> Tuple =
  let sun = (0.0, 0.0, 0.0, 0.0, 100.0) in
  let planet = (10.0, 0.0, 0.0, 3.16, 1.0) in  -- roughly circular orbit
  let system = (sun, planet) in
  let ke0 = kinetic_energy system in
  let final_state = simulate system 100 0.01 1.0 in
  let ke1 = kinetic_energy final_state in
  let com = center_of_mass final_state in
  (ke0, ke1, com)
