-- Visitor Pattern on AST
-- Demonstrates the visitor/fold pattern for processing tree structures.
--
-- AST nodes encoded as tuples:
--   (0, value)           -- IntLit: integer literal
--   (1, op, left, right) -- BinOp: binary operation (op: 0=+, 1=-, 2=*, 3=/)
--   (2, child)           -- Neg: negation
--   (3, cond, then, else) -- If: conditional

-- Evaluate an AST node.
let rec eval_ast node : Tuple -> Int [cost: Unknown] =
  let tag = list_nth node 0 in
  if tag == 0 then list_nth node 1  -- IntLit
  else if tag == 1 then
    let op = list_nth node 1 in
    let left = eval_ast (list_nth node 2) in
    let right = eval_ast (list_nth node 3) in
    if op == 0 then left + right
    else if op == 1 then left - right
    else if op == 2 then left * right
    else if op == 3 then
      if right == 0 then 0 else left / right
    else 0
  else if tag == 2 then
    neg (eval_ast (list_nth node 1))
  else if tag == 3 then
    let cond = eval_ast (list_nth node 1) in
    if cond != 0 then eval_ast (list_nth node 2)
    else eval_ast (list_nth node 3)
  else 0

-- Count nodes in the AST.
let rec count_nodes node : Tuple -> Int [cost: Unknown] =
  let tag = list_nth node 0 in
  if tag == 0 then 1  -- IntLit
  else if tag == 1 then
    1 + count_nodes (list_nth node 2) + count_nodes (list_nth node 3)
  else if tag == 2 then
    1 + count_nodes (list_nth node 1)
  else if tag == 3 then
    1 + count_nodes (list_nth node 1) + count_nodes (list_nth node 2) + count_nodes (list_nth node 3)
  else 1

-- Compute depth of the AST.
let rec ast_depth node : Tuple -> Int [cost: Unknown] =
  let tag = list_nth node 0 in
  if tag == 0 then 0
  else if tag == 1 then
    1 + max (ast_depth (list_nth node 2)) (ast_depth (list_nth node 3))
  else if tag == 2 then
    1 + ast_depth (list_nth node 1)
  else if tag == 3 then
    let d1 = ast_depth (list_nth node 1) in
    let d2 = ast_depth (list_nth node 2) in
    let d3 = ast_depth (list_nth node 3) in
    1 + max d1 (max d2 d3)
  else 0

-- Pretty-print to a flat string representation.
-- Returns a tuple of character codes.
-- FIXME: Building strings from nested ASTs requires repeated str_concat,
-- which is O(n^2) in total output length. A StringBuilder/buffer pattern
-- would be more efficient but IRIS lacks mutable strings.
let rec ast_to_string node : Tuple -> String [cost: Unknown] =
  let tag = list_nth node 0 in
  if tag == 0 then int_to_string (list_nth node 1)
  else if tag == 1 then
    let op = list_nth node 1 in
    let op_str = if op == 0 then "+" else if op == 1 then "-" else if op == 2 then "*" else "/" in
    str_concat "(" (str_concat (ast_to_string (list_nth node 2))
      (str_concat " " (str_concat op_str
        (str_concat " " (str_concat (ast_to_string (list_nth node 3)) ")")))))
  else if tag == 2 then
    str_concat "(-" (str_concat (ast_to_string (list_nth node 1)) ")")
  else "?"

-- Constant folding optimizer: simplify constant sub-expressions bottom-up.
-- Traverses the AST, and whenever a BinOp or Neg has only literal children,
-- evaluates it at compile time and replaces the node with a literal.
-- Returns a new AST node (may be structurally different from the input).
let rec const_fold node : Tuple -> Tuple [cost: Unknown] =
  let tag = list_nth node 0 in
  if tag == 0 then node  -- already a literal, nothing to fold
  else if tag == 1 then
    let left = const_fold (list_nth node 2) in
    let right = const_fold (list_nth node 3) in
    -- If both children reduced to literals, evaluate the whole node
    if list_nth left 0 == 0 && list_nth right 0 == 0 then
      let result = eval_ast (1, list_nth node 1, left, right) in
      (0, result)  -- replace with IntLit node
    else (1, list_nth node 1, left, right)  -- keep as BinOp with folded children
  else if tag == 2 then
    let child = const_fold (list_nth node 1) in
    if list_nth child 0 == 0 then (0, neg (list_nth child 1))
    else (2, child)
  else node

-- Test: build and evaluate (3 + 4) * (10 - 2)
let test_visitor x : Int -> Tuple =
  let three = (0, 3) in
  let four = (0, 4) in
  let ten = (0, 10) in
  let two = (0, 2) in
  let add = (1, 0, three, four) in       -- 3 + 4 = 7
  let sub = (1, 1, ten, two) in          -- 10 - 2 = 8
  let mul = (1, 2, add, sub) in          -- 7 * 8 = 56
  let result = eval_ast mul in
  let nodes = count_nodes mul in
  let depth = ast_depth mul in
  let printed = ast_to_string mul in
  let folded = const_fold mul in
  (result, nodes, depth, printed, folded)
