-- Self-Modification Tests
-- Verifies graph manipulation primitives and autopoiesis pipeline.

-- Test: add and mul produce different results for same inputs.
let test_ops_differ x : Int -> Int [cost: Const(2)] =
  let add_result = 5 + 3 in
  let mul_result = 5 * 3 in
  if add_result != mul_result then 1 else 0 - 1

-- Test: add(5, 3) = 8
let test_add_result x : Int -> Int [cost: Const(1)] =
  if 5 + 3 == 8 then 1 else 0 - 1

-- Test: mul(5, 3) = 15
let test_mul_result x : Int -> Int [cost: Const(1)] =
  if 5 * 3 == 15 then 1 else 0 - 1

-- Test: sub(10, 7) = 3
let test_sub_result x : Int -> Int [cost: Const(1)] =
  if 10 - 7 == 3 then 1 else 0 - 1

-- Test: all four ops on (10, 3) produce expected results.
let test_all_ops x : Int -> Int [cost: Const(4)] =
  let a = 10 in
  let b = 3 in
  if a + b == 13 then
    if a - b == 7 then
      if a * b == 30 then
        if a / b == 3 then 1 else 0 - 1
      else 0 - 1
    else 0 - 1
  else 0 - 1

-- Test: opcode constants are well-defined.
let test_opcodes x : Int -> Int [cost: Const(4)] =
  let op_add = 0 in
  let op_sub = 1 in
  let op_mul = 2 in
  let op_div = 3 in
  if op_add != op_sub then
    if op_mul != op_div then
      if op_add < op_div then 1 else 0 - 1
    else 0 - 1
  else 0 - 1

-- Aggregate test results
let test_results x : Int -> Tuple [cost: Const(15)] =
  let t1 = if (5 + 3) != (5 * 3) then 1 else 0 - 1 in
  let t2 = if 5 + 3 == 8 then 1 else 0 - 1 in
  let t3 = if 5 * 3 == 15 then 1 else 0 - 1 in
  let t4 = if 10 - 7 == 3 then 1 else 0 - 1 in
  let t5 = if 10 + 3 == 13 then 1 else 0 - 1 in
  let t6 = if 10 * 3 == 30 then 1 else 0 - 1 in
  let t7 = if 10 / 3 == 3 then 1 else 0 - 1 in
  (t1, t2, t3, t4, t5, t6, t7)
