-- Tests for the full evolution loop and supporting subsystems
-- depends: programs/evolution/novelty_search.iris, programs/evolution/map_elites.iris
-- depends: programs/evolution/phase_detect.iris, programs/evolution/resource.iris
-- depends: programs/evolution/migration.iris, programs/evolution/checkpoint.iris
-- depends: programs/evolution/coevolution.iris, programs/evolution/enumerate.iris
-- depends: programs/evolution/component_bridge.iris, programs/evolution/ecosystem.iris
-- depends: programs/evolution/stigmergy.iris, programs/analyzer/build_skeleton.iris
-- depends: programs/evolution/full_evolve_loop.iris, programs/evolution/meta_evolve.iris
--
-- Tests cover:
--   1. Fitness evaluation
--   2. Novelty scoring and archive management
--   3. NSGA-II Pareto dominance
--   4. MAP-Elites archive operations
--   5. Phase detection and transitions
--   6. Resource competition budget allocation
--   7. Migration decisions
--   8. Stagnation detection
--   9. Full evolution loop (simple programs)
--  10. Checkpoint serialization
--  11. Coevolution metrics
--  12. Enumeration synthesis
--  13. Component bridge operations
--  14. Ecosystem dynamics
--  15. Stigmergy field operations

-- =========================================================================
-- Fitness evaluation tests
-- =========================================================================

-- Test: eval_individual returns 100 for a perfect program
let test_eval_perfect : Int [cost: Unknown] =
  -- A constant program returning 42 on test cases expecting 42
  let prog = graph_new in
  let step = graph_add_node_rt prog 5 in
  let prog2 = graph_set_lit_value (step.0) (step.1) 0 42 in
  let prog3 = graph_set_root (prog2.0) (prog2.1) in
  let test_cases = ((0, 42),) in
  let score = eval_individual prog3 test_cases in
  assert_eq score 100 0

-- Test: node_count returns correct count
let test_node_count : Int [cost: Const(5)] =
  let prog = graph_new in
  let step = graph_add_node_rt prog 5 in
  let nc = node_count (step.0) in
  assert_gte nc 1 0

-- Test: simplicity_score is high for small programs
let test_simplicity_high : Int [cost: Const(5)] =
  let prog = graph_new in
  let score = simplicity_score prog in
  assert_gte score 900 0

-- =========================================================================
-- Novelty search tests
-- =========================================================================

-- Test: behavior_distance returns 0 for identical behaviors
let test_novelty_same : Int [cost: Const(5)] =
  let a = (1, 2, 3) in
  let b = (1, 2, 3) in
  let dist = behavior_distance a b in
  assert_eq dist 0 0

-- Test: behavior_distance returns correct Manhattan distance
let test_novelty_distance : Int [cost: Const(5)] =
  let a = (1, 2, 3) in
  let b = (4, 2, 0) in
  -- |1-4| + |2-2| + |3-0| = 3 + 0 + 3 = 6
  let dist = behavior_distance a b in
  assert_eq dist 6 0

-- Test: novelty_score returns 0 for identical archive entry (distance = 0)
let test_novelty_empty_archive : Int [cost: Const(5)] =
  let behavior = (1, 2, 3) in
  let archive = ((1, 2, 3),) in
  let score = novelty_score behavior archive 10 in
  assert_eq score 0 0

-- Test: should_add_to_archive returns 1 for novel behavior
let test_novelty_add : Int [cost: Const(3)] =
  let result = should_add_to_archive 100 50 in
  assert_eq result 1 0

-- Test: should_add_to_archive returns 0 for familiar behavior
let test_novelty_reject : Int [cost: Const(3)] =
  let result = should_add_to_archive 10 50 in
  assert_eq result 0 0

-- Test: adaptive_threshold increases when too many additions
let test_adaptive_threshold_up : Int [cost: Const(3)] =
  let new_threshold = adaptive_threshold 50 20 5 in
  assert_gt new_threshold 50 0

-- Test: adaptive_threshold decreases when too few additions
let test_adaptive_threshold_down : Int [cost: Const(3)] =
  let new_threshold = adaptive_threshold 50 1 10 in
  assert_lt new_threshold 50 0

-- =========================================================================
-- NSGA-II tests
-- =========================================================================

-- Test: dominates returns 1 when A strictly dominates B
let test_nsga_dominates : Int [cost: Const(3)] =
  let result = dominates 100 50 30 90 40 20 in
  assert_eq result 1 0

-- Test: dominates returns 0 when A doesn't dominate B
let test_nsga_no_dominate : Int [cost: Const(3)] =
  let result = dominates 100 50 30 100 60 30 in
  assert_eq result 0 0

-- Test: tournament_compare prefers lower rank
let test_nsga_tournament_rank : Int [cost: Const(3)] =
  let result = tournament_compare 1 50 2 100 in
  assert_eq result 1 0

-- Test: tournament_compare uses crowding for equal ranks
let test_nsga_tournament_crowd : Int [cost: Const(3)] =
  let result = tournament_compare 1 100 1 50 in
  assert_eq result 1 0

-- =========================================================================
-- MAP-Elites tests
-- =========================================================================

-- Test: complexity_bin classifies correctly
let test_mapelites_bin_small : Int [cost: Const(3)] =
  let bin = complexity_bin 5 in
  assert_eq bin 0 0

-- Test: complexity_bin classifies large
let test_mapelites_bin_large : Int [cost: Const(3)] =
  let bin = complexity_bin 200 in
  assert_eq bin 3 0

-- Test: grid_index computes correctly
let test_mapelites_index : Int [cost: Const(3)] =
  let idx = grid_index 5 2 in
  -- complexity_bin(5) = 0, diversity_bin(2) = 1, index = 0*3+1 = 1
  assert_eq idx 1 0

-- Test: empty archive has 0 occupied cells
let test_mapelites_empty : Int [cost: Const(3)] =
  let archive = empty_archive in
  let occupied = count_occupied archive in
  assert_eq occupied 0 0

-- Test: try_insert adds to empty cell
let test_mapelites_insert : Int [cost: Const(5)] =
  let archive = empty_archive in
  let result = try_insert archive 5 2 0 75 in
  let was_inserted = result.1 in
  assert_eq was_inserted 1 0

-- Test: try_insert replaces when better
let test_mapelites_replace : Int [cost: Const(5)] =
  let archive = empty_archive in
  let r1 = try_insert archive 5 2 0 50 in
  let r2 = try_insert r1.0 5 2 0 75 in
  assert_eq r2.1 1 0

-- =========================================================================
-- Phase detection tests
-- =========================================================================

-- Test: classify_phase returns Exploration for high improvement
let test_phase_exploration : Int [cost: Const(3)] =
  let phase = classify_phase 10 50 in
  assert_eq phase 0 0

-- Test: classify_phase returns Exploitation for low improvement and diversity
let test_phase_exploitation : Int [cost: Const(3)] =
  let phase = classify_phase 0 20 in
  assert_eq phase 2 0

-- Test: classify_phase returns SteadyState for moderate improvement
let test_phase_steady : Int [cost: Const(3)] =
  let phase = classify_phase 3 50 in
  assert_eq phase 1 0

-- Test: phase_mutation_rate is high for exploration
let test_phase_mutation_rate : Int [cost: Const(3)] =
  let rate = phase_mutation_rate 0 in
  assert_eq rate 80 0

-- Test: detect_transition detects phase change
let test_phase_transition : Int [cost: Const(3)] =
  let result = detect_transition 0 0 20 in
  -- Was Exploration (0), now should be Exploitation (2) with low improvement
  assert_eq result.1 1 0

-- =========================================================================
-- Resource competition tests
-- =========================================================================

-- Test: top 25% get 2x budget
let test_resource_top : Int [cost: Const(3)] =
  let budget = resource_budget 10 in
  assert_eq budget 200 0

-- Test: bottom 25% get 0.5x budget
let test_resource_bottom : Int [cost: Const(3)] =
  let budget = resource_budget 80 in
  assert_eq budget 50 0

-- Test: middle 50% get 1x budget
let test_resource_middle : Int [cost: Const(3)] =
  let budget = resource_budget 50 in
  assert_eq budget 100 0

-- =========================================================================
-- Migration tests
-- =========================================================================

-- Test: migration happens every 5 generations
let test_migrate_yes : Int [cost: Const(3)] =
  assert_eq (should_migrate 5) 1 0

-- Test: no migration at generation 3
let test_migrate_no : Int [cost: Const(3)] =
  assert_eq (should_migrate 3) 0 0

-- Test: ring_dest wraps around
let test_ring_dest : Int [cost: Const(3)] =
  let dest = ring_dest 3 in
  -- (3 + 1) % 4 = 0
  assert_eq dest 0 0

-- =========================================================================
-- Stagnation tests
-- =========================================================================

-- Test: update_stagnation resets on improvement
let test_stag_reset : Int [cost: Const(3)] =
  let result = update_stagnation 5 10 in
  assert_eq result 0 0

-- Test: update_stagnation increments without improvement
let test_stag_increment : Int [cost: Const(3)] =
  let result = update_stagnation 0 10 in
  assert_eq result 11 0

-- Test: is_stagnating returns 1 when count > 20
let test_stag_detected : Int [cost: Const(3)] =
  assert_eq (is_stagnating 25) 1 0

-- =========================================================================
-- Checkpoint tests
-- =========================================================================

-- Test: checkpoint_size returns reasonable estimate
let test_checkpoint_size : Int [cost: Const(3)] =
  let prog = graph_new in
  let size = checkpoint_size prog in
  assert_gt size 0 0

-- Test: should_checkpoint fires at interval
let test_checkpoint_interval : Int [cost: Const(3)] =
  assert_eq (should_checkpoint 10 5) 1 0

-- Test: is_stale detects old checkpoints
let test_checkpoint_stale : Int [cost: Const(3)] =
  assert_eq (is_stale 100 10 50) 1 0

-- Test: validate_checkpoint accepts valid data
let test_checkpoint_valid : Int [cost: Const(3)] =
  let cp = serialize_checkpoint 50 256 85 1 100 1000 graph_new in
  assert_eq (validate_checkpoint cp) 1 0

-- Test: validate_checkpoint rejects negative generation
let test_checkpoint_invalid : Int [cost: Const(3)] =
  let cp = (0 - 1, 256, 85, 1, 100, 1000) in
  assert_eq (validate_checkpoint cp) 0 0

-- =========================================================================
-- Coevolution tests
-- =========================================================================

-- Test: program_fitness computes correctly
let test_coevol_prog_fitness : Int [cost: Const(3)] =
  let fitness = program_fitness 8 10 in
  assert_eq fitness 80 0

-- Test: test_fitness computes correctly
let test_coevol_test_fitness : Int [cost: Const(3)] =
  let fitness = test_fitness 7 10 in
  assert_eq fitness 70 0

-- Test: arms_race_intensity
let test_coevol_intensity : Int [cost: Const(3)] =
  let intensity = arms_race_intensity 50 50 in
  assert_eq intensity 25 0

-- Test: red_queen_ratio is 100 for balanced progress
let test_coevol_red_queen : Int [cost: Const(3)] =
  let ratio = red_queen_ratio 50 50 in
  assert_eq ratio 100 0

-- =========================================================================
-- Enumeration tests
-- =========================================================================

-- Test: output_signature produces consistent hashes
let test_enum_signature : Int [cost: Const(3)] =
  let sig1 = output_signature (1, 2, 3) in
  let sig2 = output_signature (1, 2, 3) in
  assert_eq sig1 sig2 0

-- Test: matches_spec returns 1 for matching outputs
let test_enum_matches : Int [cost: Const(3)] =
  let result = matches_spec (3, 7, 10) (3, 7, 10) in
  assert_eq result 1 0

-- Test: matches_spec returns 0 for non-matching outputs
let test_enum_no_match : Int [cost: Const(3)] =
  let result = matches_spec (3, 7, 10) (3, 7, 11) in
  assert_eq result 0 0

-- Test: is_novel returns 1 for unseen signature
let test_enum_novel : Int [cost: Const(3)] =
  let result = is_novel 12345 (11111, 22222) in
  assert_eq result 1 0

-- Test: is_novel returns 0 for seen signature
let test_enum_not_novel : Int [cost: Const(3)] =
  let result = is_novel 12345 (11111, 12345, 22222) in
  assert_eq result 0 0

-- =========================================================================
-- Component bridge tests
-- =========================================================================

-- Test: is_valid_kind accepts mutation
let test_bridge_valid_mutation : Int [cost: Const(3)] =
  assert_eq (is_valid_kind 0) 1 0

-- Test: is_valid_kind accepts seed
let test_bridge_valid_seed : Int [cost: Const(3)] =
  assert_eq (is_valid_kind 1) 1 0

-- Test: is_valid_kind rejects invalid
let test_bridge_invalid : Int [cost: Const(3)] =
  assert_eq (is_valid_kind 5) 0 0

-- Test: apply_seed generates a real program for fold_add
let test_bridge_seed_fold_add : Int [cost: Const(15)] =
  let result = apply_seed 0 42 in
  assert_eq result.1 1 0

-- Test: apply_seed generates a real program for fold_max
let test_bridge_seed_fold_max : Int [cost: Const(15)] =
  let result = apply_seed 1 42 in
  assert_eq result.1 1 0

-- Test: apply_seed generates a real program for map_fold
let test_bridge_seed_map_fold : Int [cost: Const(15)] =
  let result = apply_seed 3 42 in
  assert_eq result.1 1 0

-- =========================================================================
-- Ecosystem tests
-- =========================================================================

-- Test: is_keystone for high ref count
let test_eco_keystone_yes : Int [cost: Const(3)] =
  assert_eq (is_keystone 10 5) 1 0

-- Test: is_keystone for low ref count
let test_eco_keystone_no : Int [cost: Const(3)] =
  assert_eq (is_keystone 2 5) 0 0

-- Test: is_decaying for old fragment
let test_eco_decaying : Int [cost: Const(3)] =
  assert_eq (is_decaying 10 100 50) 1 0

-- Test: should_prune for decaying non-keystone
let test_eco_prune : Int [cost: Const(3)] =
  assert_eq (should_prune 1 5 10 100 50) 1 0

-- Test: should_prune protects keystones
let test_eco_protect_keystone : Int [cost: Const(3)] =
  assert_eq (should_prune 10 5 10 100 50) 0 0

-- Test: turnover_rate computes correctly
let test_eco_turnover : Int [cost: Const(3)] =
  let rate = turnover_rate 5 3 100 in
  assert_eq rate 8 0

-- =========================================================================
-- Stigmergy tests
-- =========================================================================

-- Test: quantize_dim returns correct voxel coordinate
let test_stig_quantize : Int [cost: Const(3)] =
  let coord = quantize_dim 25 10 in
  assert_eq coord 2 0

-- Test: avg_fitness computes correctly
let test_stig_avg_fitness : Int [cost: Const(3)] =
  let avg = avg_fitness 300 3 in
  assert_eq avg 100 0

-- Test: failure_rate computes percentage
let test_stig_failure_rate : Int [cost: Const(3)] =
  let rate = failure_rate 3 10 in
  assert_eq rate 30 0

-- Test: decay_signal applies decay correctly
let test_stig_decay : Int [cost: Const(3)] =
  let decayed = decay_signal 100 95 in
  assert_eq decayed 95 0

-- Test: is_negligible returns 1 for small signal without failures
let test_stig_negligible : Int [cost: Const(3)] =
  assert_eq (is_negligible 2 0 10) 1 0

-- Test: net_signal combines avg fitness and failure rate
let test_stig_net_signal : Int [cost: Const(3)] =
  let sig = net_signal 300 3 1 in
  -- avg = 100, failure_rate = 1*100/4 = 25, net = 75
  assert_gt sig 0 0

-- =========================================================================
-- Test suite runner
-- =========================================================================

-- Run all evolution subsystem tests
let run_evolution_tests : (Int, Int, Int, Int) [cost: Unknown] =
  let results = (
    test_eval_perfect,
    test_node_count,
    test_simplicity_high,
    test_novelty_same,
    test_novelty_distance,
    test_novelty_empty_archive,
    test_novelty_add,
    test_novelty_reject,
    test_adaptive_threshold_up,
    test_adaptive_threshold_down,
    test_nsga_dominates,
    test_nsga_no_dominate,
    test_nsga_tournament_rank,
    test_nsga_tournament_crowd,
    test_mapelites_bin_small,
    test_mapelites_bin_large,
    test_mapelites_index,
    test_mapelites_empty,
    test_mapelites_insert,
    test_mapelites_replace,
    test_phase_exploration,
    test_phase_exploitation,
    test_phase_steady,
    test_phase_mutation_rate,
    test_phase_transition,
    test_resource_top,
    test_resource_bottom,
    test_resource_middle,
    test_migrate_yes,
    test_migrate_no,
    test_ring_dest,
    test_stag_reset,
    test_stag_increment,
    test_stag_detected,
    test_checkpoint_size,
    test_checkpoint_interval,
    test_checkpoint_stale,
    test_checkpoint_valid,
    test_checkpoint_invalid,
    test_coevol_prog_fitness,
    test_coevol_test_fitness,
    test_coevol_intensity,
    test_coevol_red_queen,
    test_enum_signature,
    test_enum_matches,
    test_enum_no_match,
    test_enum_novel,
    test_enum_not_novel,
    test_bridge_valid_mutation,
    test_bridge_valid_seed,
    test_bridge_invalid,
    test_bridge_seed_fold_add,
    test_bridge_seed_fold_max,
    test_bridge_seed_map_fold,
    test_eco_keystone_yes,
    test_eco_keystone_no,
    test_eco_decaying,
    test_eco_prune,
    test_eco_protect_keystone,
    test_eco_turnover,
    test_stig_quantize,
    test_stig_avg_fitness,
    test_stig_failure_rate,
    test_stig_decay,
    test_stig_negligible,
    test_stig_net_signal
  ) in
  test_summary results
