-- Tests for analyzer pattern detection and skeleton construction
-- depends: programs/analyzer/detect_identity.iris, programs/analyzer/detect_constant.iris
-- depends: programs/analyzer/detect_sum.iris, programs/analyzer/detect_max.iris
-- depends: programs/analyzer/detect_product.iris, programs/analyzer/detect_negation.iris
-- depends: programs/analyzer/detect_absolute.iris, programs/analyzer/detect_linear.iris
-- depends: programs/analyzer/detect_binary_arithmetic.iris
-- depends: programs/analyzer/detect_fold_reduction.iris
-- depends: programs/analyzer/detect_map_transform.iris
-- depends: programs/analyzer/detect_linear_transform.iris
-- depends: programs/analyzer/build_skeleton.iris
--
-- Tests cover:
--   1. Pattern detection: identity, constant, linear, sum, max, product
--   2. Binary arithmetic detection
--   3. Fold reduction detection
--   4. Map transform detection
--   5. Linear transform detection
--   6. Skeleton construction: build and verify correctness
--   7. Skeleton evaluation against test cases

-- =========================================================================
-- Pattern detection tests
-- =========================================================================

-- Test: detect_identity should return 100 confidence for identity pairs
let test_identity_detection : Int [cost: Const(5)] =
  let pairs = ((5, 5), (0, 0), (0 - 3, 0 - 3), (100, 100)) in
  let result = detect_identity pairs 4 in
  assert_eq result 100 0

-- Test: detect_identity should return 0 for non-identity pairs
let test_identity_negative : Int [cost: Const(5)] =
  let pairs = ((5, 10), (0, 1), (3, 6)) in
  let result = detect_identity pairs 3 in
  assert_eq result 0 0

-- Test: detect_constant should return 100 for constant output
let test_constant_detection : Int [cost: Const(5)] =
  let pairs = ((1, 42), (99, 42), (0 - 5, 42)) in
  let result = detect_constant 42 pairs 3 in
  assert_eq result 100 0

-- Test: detect_constant should return 0 for varying output
let test_constant_negative : Int [cost: Const(5)] =
  let pairs = ((1, 1), (2, 2), (3, 3)) in
  let result = detect_constant 1 pairs 3 in
  assert_lt result 100 0

-- Test: detect_sum should return 100 for sum-of-list pairs
let test_sum_detection : Int [cost: Const(5)] =
  let pairs = (((1, 2, 3), 6), ((10,), 10), ((0, 0), 0)) in
  let result = detect_sum pairs 3 in
  assert_eq result 100 0

-- Test: detect_max should return 100 for max-of-list pairs
let test_max_detection : Int [cost: Const(5)] =
  let pairs = (((1, 5, 3), 5), ((10,), 10), ((0 - 1, 0 - 2), 0 - 1)) in
  let result = detect_max pairs 3 in
  assert_eq result 100 0

-- Test: detect_product should return 100 for product-of-list pairs
let test_product_detection : Int [cost: Const(5)] =
  let pairs = (((1, 2, 3), 6), ((10,), 10), ((2, 2), 4)) in
  let result = detect_product pairs 3 in
  assert_eq result 100 0

-- Test: detect_negation should return 100 for negation pairs
let test_negation_detection : Int [cost: Const(5)] =
  let pairs = ((5, 0 - 5), (0, 0), (0 - 3, 3)) in
  let result = detect_negation pairs 3 in
  assert_eq result 100 0

-- Test: detect_absolute should return 100 for abs pairs
let test_absolute_detection : Int [cost: Const(5)] =
  let pairs = ((5, 5), (0 - 3, 3), (0, 0)) in
  let result = detect_absolute pairs 3 in
  assert_eq result 100 0

-- Test: detect_linear should return 100 for y = 2x + 1
let test_linear_detection : Int [cost: Const(5)] =
  let pairs = ((0, 1), (1, 3), (2, 5), (3, 7)) in
  let result = detect_linear 0 1 1 3 pairs 4 in
  assert_eq result 100 0

-- =========================================================================
-- Binary arithmetic detection tests
-- =========================================================================

-- Test: detect add pattern (a + b)
let test_binary_add : Int [cost: Const(5)] =
  let pairs = (((1, 2), 3), ((0, 0), 0), ((10, 0 - 3), 7)) in
  let result = detect_binary_arithmetic pairs 3 2 in
  assert_gte result.0 100 0

-- Test: detect sub pattern (a - b)
let test_binary_sub : Int [cost: Const(5)] =
  let pairs = (((5, 3), 2), ((10, 10), 0), ((0, 5), 0 - 5)) in
  let result = detect_binary_arithmetic pairs 3 2 in
  assert_gte result.0 100 0

-- Test: detect mul pattern (a * b)
let test_binary_mul : Int [cost: Const(5)] =
  let pairs = (((2, 3), 6), ((0, 5), 0), ((4, 0 - 2), 0 - 8)) in
  let result = detect_binary_arithmetic pairs 3 2 in
  assert_gte result.0 100 0

-- =========================================================================
-- Fold reduction detection tests
-- =========================================================================

-- Test: detect sum fold
let test_fold_sum : Int [cost: Const(5)] =
  let pairs = (((1, 2, 3), 6), ((10,), 10), ((0, 0), 0)) in
  let result = detect_fold_reduction pairs 3 in
  assert_eq result.0 100 0

-- Test: detect product fold
let test_fold_product : Int [cost: Const(5)] =
  let pairs = (((1, 2, 3), 6), ((10,), 10), ((2, 2), 4)) in
  let result = detect_fold_reduction pairs 3 in
  assert_gte result.0 50 0

-- Test: detect max fold
let test_fold_max : Int [cost: Const(5)] =
  let pairs = (((1, 5, 3), 5), ((10,), 10), ((0 - 1, 0 - 2), 0 - 1)) in
  let result = detect_fold_reduction pairs 3 in
  assert_eq result.0 100 0

-- =========================================================================
-- Map transform detection tests
-- =========================================================================

-- Test: detect double (map add x x)
let test_map_double : Int [cost: Const(5)] =
  let pairs = (((1, 2, 3), (2, 4, 6)), ((0,), (0,)), ((5, 10), (10, 20))) in
  let result = detect_map_transform pairs 3 in
  assert_eq result.0 100 0

-- Test: detect square (map mul x x)
let test_map_square : Int [cost: Const(5)] =
  let pairs = (((1, 2, 3), (1, 4, 9)), ((0,), (0,)), ((4, 3), (16, 9))) in
  let result = detect_map_transform pairs 3 in
  assert_eq result.0 100 0

-- =========================================================================
-- Linear transform detection tests
-- =========================================================================

-- Test: y = 3x + 2
let test_linear_transform_3x2 : Int [cost: Const(5)] =
  let pairs = ((0, 2), (1, 5), (2, 8), (3, 11)) in
  let result = detect_linear_transform pairs 4 in
  assert_eq result.0 100 0

-- Test: verify detected coefficients
let test_linear_coefficients : Int [cost: Const(5)] =
  let pairs = ((0, 2), (1, 5), (2, 8), (3, 11)) in
  let result = detect_linear_transform pairs 4 in
  let a_correct = assert_eq result.1 3 0 in
  let b_correct = assert_eq result.2 2 0 in
  a_correct * b_correct

-- Test: y = -x + 10
let test_linear_negative_slope : Int [cost: Const(5)] =
  let pairs = ((0, 10), (1, 9), (5, 5), (10, 0)) in
  let result = detect_linear_transform pairs 4 in
  assert_eq result.0 100 0

-- =========================================================================
-- Skeleton construction tests
-- =========================================================================

-- Test: build identity skeleton has correct structure
let test_skeleton_identity : Int [cost: Unknown] =
  let prog = graph_new in
  let skeleton = build_identity_skeleton prog in
  -- Check skeleton has valid root and at least 2 nodes (root + add)
  let root = graph_get_root skeleton in
  let nodes = graph_nodes skeleton in
  let nc = fold 0 (\acc x -> acc + 1) nodes in
  assert_gte nc 2 0

-- Test: build sum skeleton has correct structure
let test_skeleton_sum : Int [cost: Unknown] =
  let prog = graph_new in
  let skeleton = build_sum_skeleton prog in
  let root = graph_get_root skeleton in
  let nodes = graph_nodes skeleton in
  let nc = fold 0 (\acc x -> acc + 1) nodes in
  assert_gte nc 2 0

-- Test: build binary add skeleton has correct structure
let test_skeleton_binary_add : Int [cost: Unknown] =
  let prog = graph_new in
  let skeleton = build_binary_skeleton prog 0 in
  let root = graph_get_root skeleton in
  -- Root should be a Prim node (kind 0)
  let kind = graph_get_kind skeleton root in
  assert_eq kind 0 0

-- Test: build_skeleton_for_pattern dispatches correctly
let test_build_dispatch : Int [cost: Unknown] =
  let prog = graph_new in
  let skel = build_skeleton_for_pattern prog 4 0 0 in
  -- Pattern 4 = sum skeleton, should produce a program with nodes
  let nodes = graph_nodes skel in
  let nc = fold 0 (\acc x -> acc + 1) nodes in
  assert_gte nc 1 0

-- =========================================================================
-- Test suite runner
-- =========================================================================

-- Run all analyzer tests
let run_analyzer_tests : (Int, Int, Int, Int) [cost: Unknown] =
  let results = (
    test_identity_detection,
    test_identity_negative,
    test_constant_detection,
    test_constant_negative,
    test_sum_detection,
    test_max_detection,
    test_product_detection,
    test_negation_detection,
    test_absolute_detection,
    test_linear_detection,
    test_binary_add,
    test_binary_sub,
    test_binary_mul,
    test_fold_sum,
    test_fold_product,
    test_fold_max,
    test_map_double,
    test_map_square,
    test_linear_transform_3x2,
    test_linear_coefficients,
    test_linear_negative_slope,
    test_skeleton_identity,
    test_skeleton_sum,
    test_skeleton_binary_add,
    test_build_dispatch
  ) in
  test_summary results
