-- IRIS Test Harness
-- Provides assertion primitives and test result aggregation.
--
-- Convention: test_ bindings return 1 for pass, -1 (or any negative) for failure.
-- The universal Rust runner discovers all test_ bindings in a module and calls
-- module_eval_test for each; positive return = pass, non-positive = fail.
-- The lbl parameter is an integer label for distinguishing assertion failures
-- within a single test (not currently surfaced in output but aids debugging).

-- Assert two values are equal.
-- Returns 1 if actual == expected, -1 otherwise.
let assert_eq actual expected lbl : Int -> Int -> Int -> Int [cost: Const(1)] =
  if actual == expected then 1
  else 0 - 1

-- Assert a value is truthy (non-zero).
-- Returns 1 if v is truthy, -1 otherwise.
let assert_true v lbl : Int -> Int -> Int [cost: Const(1)] =
  if v != 0 then 1 else 0 - 1

-- Assert a value is falsy (zero).
-- Returns 1 if v is zero, -1 otherwise.
let assert_false v lbl : Int -> Int -> Int [cost: Const(1)] =
  if v == 0 then 1 else 0 - 1

-- Assert a value is greater than a threshold.
-- Returns 1 if actual > threshold, -1 otherwise.
let assert_gt actual threshold lbl : Int -> Int -> Int -> Int [cost: Const(1)] =
  if actual > threshold then 1 else 0 - 1

-- Assert a value is greater than or equal to a threshold.
-- Returns 1 if actual >= threshold, -1 otherwise.
let assert_gte actual threshold lbl : Int -> Int -> Int -> Int [cost: Const(1)] =
  if actual >= threshold then 1 else 0 - 1

-- Assert a value is less than a threshold.
-- Returns 1 if actual < threshold, -1 otherwise.
let assert_lt actual threshold lbl : Int -> Int -> Int -> Int [cost: Const(1)] =
  if actual < threshold then 1 else 0 - 1

-- Assert two values are not equal.
-- Returns 1 if actual != expected, -1 otherwise.
let assert_neq actual expected lbl : Int -> Int -> Int -> Int [cost: Const(1)] =
  if actual != expected then 1 else 0 - 1

-- Count passed tests: fold over results, count positives.
let count_passed results : Tuple -> Int [cost: Linear(results)] =
  fold 0 (\acc r -> if r > 0 then acc + 1 else acc) results

-- Count failed tests: fold over results, count non-positives.
let count_failed results : Tuple -> Int [cost: Linear(results)] =
  fold 0 (\acc r -> if r <= 0 then acc + 1 else acc) results

-- Count total tests.
let count_total results : Tuple -> Int [cost: Linear(results)] =
  fold 0 (\acc r -> acc + 1) results

-- Run a list of test results, return (passed, failed).
let run_tests results : Tuple -> (Int, Int) [cost: Linear(results)] =
  let passed = fold 0 (\acc r -> if r > 0 then acc + 1 else acc) results in
  let failed = fold 0 (\acc r -> if r <= 0 then acc + 1 else acc) results in
  (passed, failed)

-- Summary: (total, passed, failed, all_pass).
-- all_pass is 1 if all tests passed, 0 otherwise.
let test_summary results : Tuple -> (Int, Int, Int, Int) [cost: Linear(results)] =
  let total = fold 0 (\acc r -> acc + 1) results in
  let passed = fold 0 (\acc r -> if r > 0 then acc + 1 else acc) results in
  let failed = total - passed in
  (total, passed, failed, if passed == total then 1 else 0)

-- Assert string equality.
-- Returns 1 if strings are equal, -1 otherwise.
let assert_str_eq actual expected lbl : String -> String -> Int -> Int [cost: Const(1)] =
  if str_eq actual expected then 1 else 0 - 1
