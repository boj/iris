-- Tests for meta-evolution and self-improvement subsystems
-- depends: programs/meta/improvement_tracker.iris, programs/meta/auto_improve.iris
-- depends: programs/meta/daemon.iris, programs/evolution/meta_evolve.iris
--
-- Tests cover:
--   1. Improvement tracker: linear regression, acceleration, attribution
--   2. Auto-improve: gate checks, slowdown computation, improve cycle
--   3. Daemon: stagnation detection, convergence, mode selection
--   4. Meta-evolution: strategy perturbation, depth scaling

-- =========================================================================
-- Improvement tracker tests
-- =========================================================================

-- Test: mean of a list computes correctly
let test_tracker_mean : Int [cost: Const(5)] =
  let xs = (10, 20, 30) in
  let result = mean xs 3 in
  assert_eq result 20 0

-- Test: mean of empty list returns 0
let test_tracker_mean_empty : Int [cost: Const(3)] =
  let result = mean () 0 in
  assert_eq result 0 0

-- Test: regression_slope returns 0 for constant data
let test_tracker_slope_flat : Int [cost: Const(5)] =
  let data = ((1, 100), (2, 100), (3, 100)) in
  let slope = regression_slope data 3 in
  assert_eq slope 0 0

-- Test: regression_slope returns positive for increasing data
let test_tracker_slope_up : Int [cost: Const(5)] =
  let data = ((0, 100), (10, 200), (20, 300)) in
  let slope = regression_slope data 3 in
  assert_gt slope 0 0

-- Test: regression_slope returns negative for decreasing data
let test_tracker_slope_down : Int [cost: Const(5)] =
  let data = ((0, 300), (10, 200), (20, 100)) in
  let slope = regression_slope data 3 in
  assert_lt slope 0 0

-- Test: is_compounding returns 1 for negative acceleration
let test_tracker_compounding_yes : Int [cost: Const(3)] =
  assert_eq (is_compounding (0 - 5)) 1 0

-- Test: is_compounding returns 0 for positive acceleration
let test_tracker_compounding_no : Int [cost: Const(3)] =
  assert_eq (is_compounding 5) 0 0

-- Test: record_operator_application updates stats correctly
let test_tracker_op_record : Int [cost: Const(5)] =
  let stats = (0, 0, 0) in
  let updated = record_operator_application stats 10 in
  let used = assert_eq updated.0 1 0 in
  let imps = assert_eq updated.1 1 0 in
  used * imps

-- Test: record_operator_application ignores negative delta
let test_tracker_op_no_improve : Int [cost: Const(5)] =
  let stats = (5, 2, 20) in
  let updated = record_operator_application stats (0 - 5) in
  -- times_used should increment, improvements should not
  let used = assert_eq updated.0 6 0 in
  let imps = assert_eq updated.1 2 0 in
  used * imps

-- Test: operator_success_rate computes correctly
let test_tracker_success_rate : Int [cost: Const(3)] =
  let stats = (10, 3, 30) in
  let rate = operator_success_rate stats in
  -- 3/10 * 1000 = 300
  assert_eq rate 300 0

-- Test: operator_avg_improvement computes correctly
let test_tracker_avg_improvement : Int [cost: Const(3)] =
  let stats = (10, 4, 80) in
  let avg = operator_avg_improvement stats in
  -- 80/4 * 1000 = 20000
  assert_eq avg 20000 0

-- Test: problems_per_hour computes correctly
let test_tracker_pph : Int [cost: Const(3)] =
  let pph = problems_per_hour 0 0 3600000 10 in
  -- 10 problems in 1 hour = 10 problems/hour * 100 = 1000
  assert_gt pph 0 0

-- Test: adaptive_weight uses baseline for low samples
let test_tracker_adaptive_low : Int [cost: Const(3)] =
  let stats = (2, 1, 10) in
  let w = adaptive_weight stats 100 10 in
  assert_eq w 100 0

-- Test: adaptive_weight adjusts for high-sample operators
let test_tracker_adaptive_high : Int [cost: Const(5)] =
  let stats = (100, 50, 500) in
  let w = adaptive_weight stats 100 10 in
  -- Should be different from baseline since we have enough samples
  assert_gt w 0 0

-- =========================================================================
-- Auto-improve tests
-- =========================================================================

-- Test: passes_gate accepts perfect candidate
let test_auto_gate_pass : Int [cost: Const(3)] =
  assert_eq (passes_gate 100 150 200) 1 0

-- Test: passes_gate rejects imperfect correctness
let test_auto_gate_fail_corr : Int [cost: Const(3)] =
  assert_eq (passes_gate 95 150 200) 0 0

-- Test: passes_gate rejects excessive slowdown
let test_auto_gate_fail_slow : Int [cost: Const(3)] =
  assert_eq (passes_gate 100 250 200) 0 0

-- Test: compute_slowdown returns 100 for equal speed
let test_auto_slowdown_equal : Int [cost: Const(3)] =
  let result = compute_slowdown 1000 1000 in
  assert_eq result 100 0

-- Test: compute_slowdown returns 200 for 2x slower
let test_auto_slowdown_2x : Int [cost: Const(3)] =
  let result = compute_slowdown 2000 1000 in
  assert_eq result 200 0

-- Test: compute_correctness returns 100 for all correct
let test_auto_correctness_all : Int [cost: Const(3)] =
  let result = compute_correctness 10 10 in
  assert_eq result 100 0

-- Test: compute_correctness returns 50 for half correct
let test_auto_correctness_half : Int [cost: Const(3)] =
  let result = compute_correctness 5 10 in
  assert_eq result 50 0

-- Test: count_tests counts correctly
let test_auto_count_tests : Int [cost: Const(5)] =
  let tests = ((1, 2), (3, 4), (5, 6)) in
  let count = count_tests tests in
  assert_eq count 3 0

-- =========================================================================
-- Daemon tests
-- =========================================================================

-- Test: is_stagnating returns 1 when above threshold
let test_daemon_stag_yes : Int [cost: Const(3)] =
  assert_eq (is_stagnating 15) 1 0

-- Test: is_stagnating returns 0 when below threshold
let test_daemon_stag_no : Int [cost: Const(3)] =
  assert_eq (is_stagnating 5) 0 0

-- Test: is_converged returns 1 when all deltas are small
let test_daemon_converged : Int [cost: Const(3)] =
  let recent = (1, 0, 2, 1, 0) in
  assert_eq (is_converged recent) 1 0

-- Test: is_converged returns 0 when some deltas are large
let test_daemon_not_converged : Int [cost: Const(3)] =
  let recent = (1, 50, 2, 1, 0) in
  assert_eq (is_converged recent) 0 0

-- Test: decide_mode returns 0 (improve) for normal state
let test_daemon_mode_improve : Int [cost: Const(3)] =
  let mode = decide_mode 3 0 0 in
  assert_eq mode 0 0

-- Test: decide_mode returns 1 (explore) for convergence
let test_daemon_mode_explore : Int [cost: Const(3)] =
  let mode = decide_mode 0 1 0 in
  assert_eq mode 1 0

-- Test: decide_mode returns 2 (reset) after max explore attempts
let test_daemon_mode_reset : Int [cost: Const(3)] =
  let mode = decide_mode 0 1 5 in
  assert_eq mode 2 0

-- Test: decide_mode returns 1 (explore) for stagnation
let test_daemon_mode_stag : Int [cost: Const(3)] =
  let mode = decide_mode 15 0 0 in
  assert_eq mode 1 0

-- Test: should_continue returns 0 when solved
let test_daemon_continue_solved : Int [cost: Const(3)] =
  assert_eq (should_continue 100 10) 0 0

-- Test: should_continue returns 0 when budget exhausted
let test_daemon_continue_budget : Int [cost: Const(3)] =
  assert_eq (should_continue 50 0) 0 0

-- Test: should_continue returns 1 when unsolved and budget remains
let test_daemon_continue_yes : Int [cost: Const(3)] =
  assert_eq (should_continue 50 10) 1 0

-- =========================================================================
-- Meta-evolution tests
-- =========================================================================

-- Test: perturb_weight stays positive
let test_meta_perturb_positive : Int [cost: Const(3)] =
  let result = perturb_weight 100 42 in
  assert_gt result 0 0

-- Test: perturb_weight never returns 0
let test_meta_perturb_nonzero : Int [cost: Const(3)] =
  let result = perturb_weight 1 0 in
  assert_gte result 1 0

-- Test: is_meta_allowed accepts depth 0
let test_meta_allowed : Int [cost: Const(3)] =
  assert_eq (is_meta_allowed 0 2) 1 0

-- Test: is_meta_allowed rejects depth >= max
let test_meta_rejected : Int [cost: Const(3)] =
  assert_eq (is_meta_allowed 2 2) 0 0

-- Test: depth_scaled_population halves at depth 1
let test_meta_scale_pop : Int [cost: Const(3)] =
  let scaled = depth_scaled_population 32 1 in
  assert_eq scaled 16 0

-- Test: depth_scaled_generations quarters at depth 2
let test_meta_scale_gens : Int [cost: Const(3)] =
  let scaled = depth_scaled_generations 100 2 in
  assert_eq scaled 25 0

-- Test: meta_evolve_plan returns allowed for depth 0
let test_meta_plan : Int [cost: Const(3)] =
  let plan = meta_evolve_plan 0 10 in
  assert_eq plan.0 1 0

-- Test: meta_evolve_plan returns not-allowed for depth 2
let test_meta_plan_deep : Int [cost: Const(3)] =
  let plan = meta_evolve_plan 2 10 in
  assert_eq plan.0 0 0

-- =========================================================================
-- Test suite runner
-- =========================================================================

-- Run all meta/self-improvement tests
let run_meta_tests : (Int, Int, Int, Int) [cost: Unknown] =
  let results = (
    test_tracker_mean,
    test_tracker_mean_empty,
    test_tracker_slope_flat,
    test_tracker_slope_up,
    test_tracker_slope_down,
    test_tracker_compounding_yes,
    test_tracker_compounding_no,
    test_tracker_op_record,
    test_tracker_op_no_improve,
    test_tracker_success_rate,
    test_tracker_avg_improvement,
    test_tracker_pph,
    test_tracker_adaptive_low,
    test_tracker_adaptive_high,
    test_auto_gate_pass,
    test_auto_gate_fail_corr,
    test_auto_gate_fail_slow,
    test_auto_slowdown_equal,
    test_auto_slowdown_2x,
    test_auto_correctness_all,
    test_auto_correctness_half,
    test_auto_count_tests,
    test_daemon_stag_yes,
    test_daemon_stag_no,
    test_daemon_converged,
    test_daemon_not_converged,
    test_daemon_mode_improve,
    test_daemon_mode_explore,
    test_daemon_mode_reset,
    test_daemon_mode_stag,
    test_daemon_continue_solved,
    test_daemon_continue_budget,
    test_daemon_continue_yes,
    test_meta_perturb_positive,
    test_meta_perturb_nonzero,
    test_meta_allowed,
    test_meta_rejected,
    test_meta_scale_pop,
    test_meta_scale_gens,
    test_meta_plan,
    test_meta_plan_deep
  ) in
  test_summary results
