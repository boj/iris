-- elf_native.iris: elf_build tests
-- =========================================================================

-- Test: elf_build produces non-empty cons-list
let test_elf_build_nonempty : Int [cost: Const(5)] =
  let buf = generate_elf 0 1 0 in
  if buf == () then 0 - 1 else 1

-- Test: elf_build starts with ELF magic bytes
let test_elf_build_magic : Int [cost: Const(5)] =
  let buf = generate_elf 0 1 0 in
  let ok1 = assert_eq (buf.0) 127 0 in
  let r1 = buf.1 in
  let ok2 = assert_eq (r1.0) 69 1 in
  let r2 = r1.1 in
  let ok3 = assert_eq (r2.0) 76 2 in
  let r3 = r2.1 in
  let ok4 = assert_eq (r3.0) 70 3 in
  if ok1 > 0 then (if ok2 > 0 then (if ok3 > 0 then (if ok4 > 0 then 1 else 0 - 1) else 0 - 1) else 0 - 1) else 0 - 1

-- =========================================================================
-- shared_lib.iris: generate_shared_lib tests
-- =========================================================================

-- Test: generate_shared_lib validates and rejects arg_count > 6
let test_shared_lib_repr_valid : Int [cost: Const(5)] =
  let v = validate_shared_lib 100 2 in
  assert_eq v 1 0

-- Test: generate_shared_lib with invalid args fails validation
let test_shared_lib_repr_invalid : Int [cost: Const(3)] =
  let v = validate_shared_lib 100 7 in
  assert_eq v 0 0

-- =========================================================================
-- serialize_bytecode.iris: complete serialization tests
-- =========================================================================

-- Test: serialize_bytecode produces correct magic at start
let test_serialize_bytecode_magic : Int [cost: Const(5)] =
  let buf = 0 in
  let buf = prepend_const_int 42 buf in
  let result = serialize_bytecode 1 0 1 buf in
  let ok1 = assert_eq (result.0) 73 0 in
  let r1 = result.1 in
  let ok2 = assert_eq (r1.0) 82 1 in
  let r2 = r1.1 in
  let ok3 = assert_eq (r2.0) 73 2 in
  let r3 = r2.1 in
  let ok4 = assert_eq (r3.0) 83 3 in
  if ok1 > 0 then (if ok2 > 0 then (if ok3 > 0 then (if ok4 > 0 then 1 else 0 - 1) else 0 - 1) else 0 - 1) else 0 - 1

-- Test: prepend_bytecode_header includes version and arg_count
let test_serialize_header_fields : Int [cost: Const(5)] =
  let buf = prepend_bytecode_header 3 0 0 0 in
  let r = buf.1 in let r = r.1 in let r = r.1 in let r = r.1 in
  let version = r.0 in
  let r2 = r.1 in
  let argc = r2.0 in
  let ok1 = assert_eq version 1 0 in
  let ok2 = assert_eq argc 3 1 in
  if ok1 > 0 then (if ok2 > 0 then 1 else 0 - 1) else 0 - 1

-- Test: prepend_const_int produces 9 bytes (tag + 8 value bytes)
let test_serialize_prepend_int : Int [cost: Const(5)] =
  let buf = prepend_const_int 0 0 in
  let ok1 = assert_eq (buf.0) 0 0 in
  if ok1 > 0 then 1 else 0 - 1

-- =========================================================================
-- shared_lib.iris: generate + invoke tests
-- =========================================================================

-- Test: vm_step and invoke produce correct results for valid programs
let test_shared_lib_generate_valid : Int [cost: Const(5)] =
  let result = vm_step 0 0 1 42 in
  let ok1 = assert_eq (result.0) 42 0 in
  let result2 = vm_step 10 5 16 0 in
  let ok2 = assert_eq (result2.0) 15 1 in
  let inv = invoke_shared_lib 2 2 3 4 0 in
  let ok3 = assert_eq (inv.0) 0 2 in
  if ok1 > 0 then (if ok2 > 0 then (if ok3 > 0 then 1 else 0 - 1) else 0 - 1) else 0 - 1

-- Test: generate_shared_lib rejects arg_count > 6
let test_shared_lib_generate_bad_args : Int [cost: Const(3)] =
  let v = validate_shared_lib 100 7 in
  assert_eq v 0 0

-- Test: vm_step LoadConst pushes value
let test_shared_lib_vm_step_load : Int [cost: Const(3)] =
  let r = vm_step 0 0 1 42 in
  assert_eq (r.0) 42 0

-- Test: vm_step Add
let test_shared_lib_vm_step_add : Int [cost: Const(3)] =
  let r = vm_step 10 5 16 0 in
  assert_eq (r.0) 15 0

-- Test: vm_step Eq
let test_shared_lib_vm_step_eq : Int [cost: Const(3)] =
  let r = vm_step 5 5 32 0 in
  assert_eq (r.0) 1 0

-- Test: build_dispatch_table produces non-zero dispatch structure
let test_shared_lib_dispatch : Int [cost: Const(3)] =
  let d = build_dispatch_table in
  -- Dispatch table is a cons-list of (base, count) ranges
  -- Just verify it's non-empty (i.e., it produces something)
  if d == () then 0 - 1 else 1

-- =========================================================================
-- elf_native.iris: ELF generation tests
-- =========================================================================

-- Test: generate_elf produces correct ELF magic
let test_elf_generate_magic : Int [cost: Const(5)] =
  let elf = generate_elf 0 1 0 in
  let ok1 = assert_eq (elf.0) 127 0 in
  let r1 = elf.1 in
  let ok2 = assert_eq (r1.0) 69 1 in
  let r2 = r1.1 in
  let ok3 = assert_eq (r2.0) 76 2 in
  let r3 = r2.1 in
  let ok4 = assert_eq (r3.0) 70 3 in
  if ok1 > 0 then (if ok2 > 0 then (if ok3 > 0 then (if ok4 > 0 then 1 else 0 - 1) else 0 - 1) else 0 - 1) else 0 - 1

-- Test: build_elf_header_bytes starts with ELF magic
let test_elf_header_bytes_magic : Int [cost: Const(5)] =
  let hdr = build_elf_header_bytes 96 100 0 in
  let ok1 = assert_eq (hdr.0) 127 0 in
  if ok1 > 0 then 1 else 0 - 1

-- Test: build_program_header_bytes starts with PT_LOAD
let test_elf_phdr_bytes_type : Int [cost: Const(5)] =
  let phdr = build_program_header_bytes 96 100 0 in
  let ok1 = assert_eq (phdr.0) 1 0 in
  if ok1 > 0 then 1 else 0 - 1
