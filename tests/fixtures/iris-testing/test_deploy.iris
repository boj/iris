-- Tests for deploy programs: elf_native, serialize_bytecode, standalone, shared_lib
-- depends: programs/deploy/elf_native.iris, programs/deploy/serialize_bytecode.iris
-- depends: programs/deploy/standalone.iris, programs/deploy/shared_lib.iris

-- =========================================================================
-- elf_native.iris tests
-- =========================================================================

-- Test: build_ident produces correct ELF magic
let test_elf_build_ident : Int [cost: Const(5)] =
  let id = build_ident in
  let ok1 = assert_eq (id.0) 127 0 in
  let ok2 = assert_eq (id.1) 69 1 in
  let ok3 = assert_eq (id.2) 76 2 in
  let ok4 = assert_eq (id.3) 70 3 in
  if ok1 > 0 then (if ok2 > 0 then (if ok3 > 0 then (if ok4 > 0 then 1 else 0 - 1) else 0 - 1) else 0 - 1) else 0 - 1

-- Test: validate_ident correct
let test_elf_validate_ident_correct : Int [cost: Const(3)] =
  assert_eq (validate_ident 127 69 76 70 2 1 1) 1 0

-- Test: validate_ident wrong magic
let test_elf_validate_ident_bad_magic : Int [cost: Const(3)] =
  assert_eq (validate_ident 0 69 76 70 2 1 1) 0 0

-- Test: validate_code_size valid
let test_elf_validate_code_valid : Int [cost: Const(3)] =
  assert_eq (validate_code_size 1000) 1 0

-- Test: validate_code_size zero
let test_elf_validate_code_zero : Int [cost: Const(3)] =
  assert_eq (validate_code_size 0) 0 0

-- Test: validate_elf valid
let test_elf_validate_elf_valid : Int [cost: Const(3)] =
  assert_eq (validate_elf 1000 2) 1 0

-- Test: validate_elf bad arg_count
let test_elf_validate_elf_bad_args : Int [cost: Const(3)] =
  assert_eq (validate_elf 1000 7) 0 0

-- Test: validate_elf zero code
let test_elf_validate_elf_zero_code : Int [cost: Const(3)] =
  assert_eq (validate_elf 0 2) 0 0

-- Test: build_elf_type_machine_bytes
let test_elf_type_machine : Int [cost: Const(3)] =
  let r = build_elf_type_machine_bytes in
  let ok1 = assert_eq (r.0) 2 0 in
  let ok2 = assert_eq (r.2) 62 1 in
  if ok1 > 0 then (if ok2 > 0 then 1 else 0 - 1) else 0 - 1

-- Test: build_phdr_type_bytes
let test_elf_phdr_type : Int [cost: Const(3)] =
  let r = build_phdr_type_bytes in
  assert_eq (r.0) 1 0

-- Test: build_phdr_flags_bytes
let test_elf_phdr_flags : Int [cost: Const(3)] =
  let r = build_phdr_flags_bytes in
  assert_eq (r.0) 5 0

-- Test: build_elf_sizes_bytes
let test_elf_sizes : Int [cost: Const(5)] =
  let s = build_elf_sizes_bytes in
  let ok1 = assert_eq (s.0) 64 0 in
  let ok2 = assert_eq (s.2) 56 1 in
  let ok3 = assert_eq (s.4) 1 2 in
  if ok1 > 0 then (if ok2 > 0 then (if ok3 > 0 then 1 else 0 - 1) else 0 - 1) else 0 - 1

-- =========================================================================
-- serialize_bytecode.iris tests
-- =========================================================================

-- Test: serialize_magic_bytes
let test_serialize_magic : Int [cost: Const(3)] =
  let m = serialize_magic_bytes in
  let ok1 = assert_eq (m.0) 73 0 in
  let ok2 = assert_eq (m.1) 82 1 in
  let ok3 = assert_eq (m.2) 73 2 in
  let ok4 = assert_eq (m.3) 83 3 in
  if ok1 > 0 then (if ok2 > 0 then (if ok3 > 0 then (if ok4 > 0 then 1 else 0 - 1) else 0 - 1) else 0 - 1) else 0 - 1

-- Test: encode_u32_le for 1
let test_serialize_encode_u32 : Int [cost: Const(3)] =
  let r = encode_u32_le 1 in
  let ok1 = assert_eq (r.0) 1 0 in
  let ok2 = assert_eq (r.1) 0 1 in
  if ok1 > 0 then (if ok2 > 0 then 1 else 0 - 1) else 0 - 1

-- Test: is_valid_opcode valid
let test_serialize_valid_opcode : Int [cost: Const(3)] =
  assert_eq (is_valid_opcode 16) 1 0

-- Test: is_valid_opcode invalid (0)
let test_serialize_invalid_opcode : Int [cost: Const(3)] =
  assert_eq (is_valid_opcode 0) 0 0

-- Test: validate_bytecode_header correct
let test_serialize_valid_header : Int [cost: Const(3)] =
  assert_eq (validate_bytecode_header 1397051977 1) 1 0

-- Test: validate_bytecode_header wrong magic
let test_serialize_invalid_header : Int [cost: Const(3)] =
  assert_eq (validate_bytecode_header 0 1) 0 0

-- Test: roundtrip_header_check
let test_serialize_roundtrip_header : Int [cost: Const(3)] =
  assert_eq (roundtrip_header_check 2 10 3) 1 0

-- =========================================================================
-- standalone.iris tests
-- =========================================================================

-- Test: standalone_step add (opcode 16)
let test_standalone_step_add : Int [cost: Const(5)] =
  let r = standalone_step 10 5 16 in
  let ok1 = assert_eq (r.0) 15 0 in
  let ok2 = assert_eq (r.2) (0 - 1) 1 in
  if ok1 > 0 then (if ok2 > 0 then 1 else 0 - 1) else 0 - 1

-- Test: standalone_step sub (opcode 17)
let test_standalone_step_sub : Int [cost: Const(5)] =
  let r = standalone_step 10 3 17 in
  assert_eq (r.0) 7 0

-- Test: standalone_step mul (opcode 18)
let test_standalone_step_mul : Int [cost: Const(5)] =
  let r = standalone_step 6 7 18 in
  assert_eq (r.0) 42 0

-- Test: standalone_step div-by-zero (opcode 19)
let test_standalone_step_div_zero : Int [cost: Const(5)] =
  let r = standalone_step 10 0 19 in
  assert_eq (r.0) 0 0

-- Test: standalone_step eq true (opcode 32)
let test_standalone_step_eq : Int [cost: Const(5)] =
  let r = standalone_step 5 5 32 in
  assert_eq (r.0) 1 0

-- Test: standalone_step lt (opcode 34)
let test_standalone_step_lt : Int [cost: Const(5)] =
  let r = standalone_step 3 5 34 in
  assert_eq (r.0) 1 0

-- Test: standalone_jump
let test_standalone_jump : Int [cost: Const(3)] =
  assert_eq (standalone_jump 10 3) 14 0

-- Test: parse_digit '0'
let test_standalone_parse_digit_0 : Int [cost: Const(3)] =
  assert_eq (parse_digit 48) 0 0

-- Test: parse_digit '9'
let test_standalone_parse_digit_9 : Int [cost: Const(3)] =
  assert_eq (parse_digit 57) 9 0

-- Test: parse_digit 'A' (not a digit)
let test_standalone_parse_digit_A : Int [cost: Const(3)] =
  assert_eq (parse_digit 65) (0 - 1) 0

-- Test: count_digits 0
let test_standalone_count_digits_0 : Int [cost: Const(3)] =
  assert_eq (count_digits 0) 1 0

-- Test: count_digits 42
let test_standalone_count_digits_42 : Int [cost: Const(3)] =
  assert_eq (count_digits 42) 2 0

-- Test: count_digits 12345
let test_standalone_count_digits_12345 : Int [cost: Const(3)] =
  assert_eq (count_digits 12345) 5 0

-- Test: fold_step add
let test_standalone_fold_step_add : Int [cost: Const(3)] =
  assert_eq (fold_step 10 5 0) 15 0

-- Test: fold_step mul
let test_standalone_fold_step_mul : Int [cost: Const(3)] =
  assert_eq (fold_step 4 3 2) 12 0

-- Test: fold_step min
let test_standalone_fold_step_min : Int [cost: Const(3)] =
  assert_eq (fold_step 7 3 7) 3 0

-- Test: fold_step max
let test_standalone_fold_step_max : Int [cost: Const(3)] =
  assert_eq (fold_step 7 3 8) 7 0

-- =========================================================================
-- shared_lib.iris tests
-- =========================================================================

-- Test: vm_arith add
let test_shared_lib_arith_add : Int [cost: Const(3)] =
  assert_eq (vm_arith 10 5 0) 15 0

-- Test: vm_arith sub
let test_shared_lib_arith_sub : Int [cost: Const(3)] =
  assert_eq (vm_arith 10 3 1) 7 0

-- Test: vm_arith mul
let test_shared_lib_arith_mul : Int [cost: Const(3)] =
  assert_eq (vm_arith 6 7 2) 42 0

-- Test: vm_arith div
let test_shared_lib_arith_div : Int [cost: Const(3)] =
  assert_eq (vm_arith 20 4 3) 5 0

-- Test: vm_arith div-by-zero
let test_shared_lib_arith_div_zero : Int [cost: Const(3)] =
  assert_eq (vm_arith 20 0 3) 0 0

-- Test: vm_compare less (strict)
let test_shared_lib_compare_lt : Int [cost: Const(3)] =
  assert_eq (vm_compare 3 5 1) 1 0

-- Test: vm_compare equal (strict = false for <=)
let test_shared_lib_compare_le : Int [cost: Const(3)] =
  assert_eq (vm_compare 5 5 0) 1 0

-- Test: vm_compare equal (strict = true for <)
let test_shared_lib_compare_lt_false : Int [cost: Const(3)] =
  assert_eq (vm_compare 5 5 1) 0 0

-- Test: validate_invoke_inputs valid
let test_shared_lib_validate_valid : Int [cost: Const(3)] =
  assert_eq (validate_invoke_inputs 2 2 0 0) 0 0

-- Test: validate_invoke_inputs too many inputs
let test_shared_lib_validate_too_many : Int [cost: Const(3)] =
  assert_eq (validate_invoke_inputs 2000 2 0 0) (0 - 1) 0

-- Test: validate_shared_lib valid
let test_shared_lib_validate : Int [cost: Const(3)] =
  assert_eq (validate_shared_lib 100 2) 1 0

-- Test: validate_shared_lib too small
let test_shared_lib_validate_small : Int [cost: Const(3)] =
  assert_eq (validate_shared_lib 5 2) 0 0

-- Test: instruction_wire_size for LoadConst (tag 1)
let test_shared_lib_instr_size_load : Int [cost: Const(3)] =
  assert_eq (instruction_wire_size 1) 5 0

-- Test: instruction_wire_size for LoadArg (tag 2)
let test_shared_lib_instr_size_loadarg : Int [cost: Const(3)] =
  assert_eq (instruction_wire_size 2) 4 0

-- Test: instruction_wire_size for Add (tag 16)
let test_shared_lib_instr_size_add : Int [cost: Const(3)] =
  assert_eq (instruction_wire_size 16) 3 0

-- =========================================================================
-- serialize_bytecode.iris: serialize_program tests
-- =========================================================================

-- Test: serialize_program produces non-empty cons-list
let test_serialize_program_nonempty : Int [cost: Const(5)] =
  let buf = serialize_program 2 0 0 0 0 in
  -- A non-empty result means we got a cons-cell
  if buf == () then 0 - 1 else 1

-- Test: serialize_program header starts with IRIS magic
let test_serialize_program_magic : Int [cost: Const(5)] =
  let buf = serialize_program 1 0 0 0 0 in
  let ok1 = assert_eq (buf.0) 73 0 in
  let r1 = buf.1 in
  let ok2 = assert_eq (r1.0) 82 1 in
  let r2 = r1.1 in
  let ok3 = assert_eq (r2.0) 73 2 in
  let r3 = r2.1 in
  let ok4 = assert_eq (r3.0) 83 3 in
  if ok1 > 0 then (if ok2 > 0 then (if ok3 > 0 then (if ok4 > 0 then 1 else 0 - 1) else 0 - 1) else 0 - 1) else 0 - 1

