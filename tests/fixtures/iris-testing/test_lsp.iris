-- Tests for LSP programs: lsp_server, completion, hover, diagnostics, document
-- depends: programs/lsp/lsp_server.iris, programs/lsp/completion.iris
-- depends: programs/lsp/hover.iris, programs/lsp/diagnostics.iris
-- depends: programs/lsp/document.iris

-- =========================================================================
-- lsp_server.iris tests
-- =========================================================================

-- Test: parse_content_length valid
let test_lsp_content_length_valid : Int [cost: Const(3)] =
  assert_eq (parse_content_length 100) 100 0

-- Test: parse_content_length zero (invalid)
let test_lsp_content_length_zero : Int [cost: Const(3)] =
  assert_eq (parse_content_length 0) (0 - 1) 0

-- Test: is_request with id
let test_lsp_is_request : Int [cost: Const(3)] =
  assert_eq (is_request 1) 1 0

-- Test: is_request without id
let test_lsp_is_request_no_id : Int [cost: Const(3)] =
  assert_eq (is_request 0) 0 0

-- Test: is_notification without id
let test_lsp_is_notification : Int [cost: Const(3)] =
  assert_eq (is_notification 0) 1 0

-- Test: is_notification with id
let test_lsp_is_notification_has_id : Int [cost: Const(3)] =
  assert_eq (is_notification 1) 0 0

-- Test: transition_state uninitialized + initialize
let test_lsp_transition_init : Int [cost: Const(3)] =
  assert_eq (transition_state 0 0) 1 0

-- Test: transition_state initialized + shutdown
let test_lsp_transition_shutdown : Int [cost: Const(3)] =
  assert_eq (transition_state 1 7) 2 0

-- Test: transition_state shutting_down + exit
let test_lsp_transition_exit : Int [cost: Const(3)] =
  assert_eq (transition_state 2 8) 3 0

-- Test: transition_state initialized + non-transition
let test_lsp_transition_noop : Int [cost: Const(3)] =
  assert_eq (transition_state 1 5) 1 0

-- Test: dispatch initialize (method 0, has_id 1) -> (1, 0, 0)
let test_lsp_dispatch_init : Int [cost: Const(5)] =
  let r = dispatch 0 1 in
  let ok1 = assert_eq (r.0) 1 0 in
  let ok2 = assert_eq (r.1) 0 1 in
  let ok3 = assert_eq (r.2) 0 2 in
  if ok1 > 0 then (if ok2 > 0 then (if ok3 > 0 then 1 else 0 - 1) else 0 - 1) else 0 - 1

-- Test: dispatch hover (method 2, has_id 0) -> (0, 1, 0)
let test_lsp_dispatch_hover : Int [cost: Const(5)] =
  let r = dispatch 2 0 in
  assert_eq (r.1) 1 0

-- Test: dispatch exit (method 8, has_id 0) -> (0, 0, 1)
let test_lsp_dispatch_exit : Int [cost: Const(5)] =
  let r = dispatch 8 0 in
  assert_eq (r.2) 1 0

-- Test: is_method_valid in uninitialized state
let test_lsp_method_valid_init : Int [cost: Const(3)] =
  assert_eq (is_method_valid 0 0) 1 0

-- Test: is_method_valid completion in uninitialized (invalid)
let test_lsp_method_invalid_in_uninit : Int [cost: Const(3)] =
  assert_eq (is_method_valid 0 5) 0 0

-- Test: is_method_valid completion in initialized (valid)
let test_lsp_method_valid_completion : Int [cost: Const(3)] =
  assert_eq (is_method_valid 1 5) 1 0

-- =========================================================================
-- completion.iris tests
-- =========================================================================

-- Test: is_ident_char 'a'
let test_completion_ident_a : Int [cost: Const(3)] =
  assert_eq (is_ident_char 97) 1 0

-- Test: is_ident_char space (not ident)
let test_completion_ident_space : Int [cost: Const(3)] =
  assert_eq (is_ident_char 32) 0 0

-- Test: is_ident_char '0'
let test_completion_ident_digit : Int [cost: Const(3)] =
  assert_eq (is_ident_char 48) 1 0

-- Test: is_ident_char '_'
let test_completion_ident_underscore : Int [cost: Const(3)] =
  assert_eq (is_ident_char 95) 1 0

-- Test: keyword_category 'l' -> binding (0)
let test_completion_keyword_l : Int [cost: Const(3)] =
  assert_eq (keyword_category 108) 0 0

-- Test: keyword_category 't' -> type (1)
let test_completion_keyword_t : Int [cost: Const(3)] =
  assert_eq (keyword_category 116) 1 0

-- Test: make_completion_item
let test_completion_make_item : Int [cost: Const(3)] =
  let r = make_completion_item 99 14 7 in
  let ok1 = assert_eq (r.0) 99 0 in
  let ok2 = assert_eq (r.1) 14 1 in
  let ok3 = assert_eq (r.2) 7 2 in
  if ok1 > 0 then (if ok2 > 0 then (if ok3 > 0 then 1 else 0 - 1) else 0 - 1) else 0 - 1

-- Test: estimate_completion_count empty prefix (all items)
let test_completion_estimate_all : Int [cost: Const(3)] =
  assert_eq (estimate_completion_count 0 0) 136 0

-- =========================================================================
-- hover.iris tests
-- =========================================================================

-- Test: is_ident_byte 'a'
let test_hover_ident_a : Int [cost: Const(3)] =
  assert_eq (is_ident_byte 97) 1 0

-- Test: is_ident_byte '_'
let test_hover_ident_underscore : Int [cost: Const(3)] =
  assert_eq (is_ident_byte 95) 1 0

-- Test: is_ident_byte space (not ident)
let test_hover_ident_space : Int [cost: Const(3)] =
  assert_eq (is_ident_byte 32) 0 0

-- Test: scan_word_end all ident bytes -> 4
let test_hover_scan_word_end_all : Int [cost: Const(3)] =
  assert_eq (scan_word_end 97 98 99 100) 4 0

-- Test: scan_word_end first non-ident -> 0
let test_hover_scan_word_end_none : Int [cost: Const(3)] =
  assert_eq (scan_word_end 32 97 98 99) 0 0

-- Test: identify_primitive "add" -> opcode=0, arity=2
let test_hover_identify_add : Int [cost: Const(3)] =
  assert_eq (identify_primitive 3 97 100) (0 * 256 + 2) 0

-- Test: identify_primitive unknown -> -1
let test_hover_identify_unknown : Int [cost: Const(3)] =
  assert_eq (identify_primitive 10 120 121) (0 - 1) 0

-- Test: resolve_hover "add" -> primitive (1)
let test_hover_resolve_add : Int [cost: Const(3)] =
  assert_eq (resolve_hover 3 97 100) 1 0

-- =========================================================================
-- diagnostics.iris tests
-- =========================================================================

-- Test: offset_to_position packs correctly
let test_diag_offset_to_pos : Int [cost: Const(3)] =
  assert_eq (offset_to_position 5 12) 500012 0

-- Test: position_line extracts line
let test_diag_position_line : Int [cost: Const(3)] =
  assert_eq (position_line 500012) 5 0

-- Test: position_col extracts column
let test_diag_position_col : Int [cost: Const(3)] =
  assert_eq (position_col 500012) 12 0

-- Test: should_report error <= warning
let test_diag_should_report_yes : Int [cost: Const(3)] =
  assert_eq (should_report 1 2) 1 0

-- Test: should_report info > warning
let test_diag_should_report_no : Int [cost: Const(3)] =
  assert_eq (should_report 3 2) 0 0

-- Test: total_diagnostics sums
let test_diag_total : Int [cost: Const(3)] =
  assert_eq (total_diagnostics 1 2 3) 6 0

-- Test: run_diagnostic_pipeline success
let test_diag_pipeline_success : Int [cost: Const(5)] =
  let r = run_diagnostic_pipeline 0 0 0 0 in
  let ok1 = assert_eq (r.0) 1 0 in
  let ok2 = assert_eq (r.1) 0 1 in
  if ok1 > 0 then (if ok2 > 0 then 1 else 0 - 1) else 0 - 1

-- Test: run_diagnostic_pipeline with errors
let test_diag_pipeline_errors : Int [cost: Const(5)] =
  let r = run_diagnostic_pipeline 1 3 2 1 in
  let ok1 = assert_eq (r.0) 0 0 in
  let ok2 = assert_eq (r.1) 2 1 in
  let ok3 = assert_eq (r.2) 1 2 in
  if ok1 > 0 then (if ok2 > 0 then (if ok3 > 0 then 1 else 0 - 1) else 0 - 1) else 0 - 1

-- Test: compare_diagnostics same
let test_diag_compare_same : Int [cost: Const(3)] =
  assert_eq (compare_diagnostics 1 5 1 5) 0 0

-- Test: compare_diagnostics different line
let test_diag_compare_diff_line : Int [cost: Const(3)] =
  assert_eq (compare_diagnostics 1 5 2 5) (0 - 1) 0

-- Test: compare_diagnostics same line, different col
let test_diag_compare_diff_col : Int [cost: Const(3)] =
  assert_eq (compare_diagnostics 1 10 1 5) 1 0

-- Test: minimum_check_tier simple
let test_diag_min_check_tier : Int [cost: Const(3)] =
  assert_eq (minimum_check_tier 10 0 0 0) 0 0

-- Test: minimum_check_tier neural
let test_diag_min_check_tier_neural : Int [cost: Const(3)] =
  assert_eq (minimum_check_tier 10 0 0 1) 3 0

-- =========================================================================
-- document.iris tests
-- =========================================================================

-- Test: doc_open creates entry
let test_doc_open : Int [cost: Const(5)] =
  let r = doc_open 12345 500 in
  let ok1 = assert_eq (r.0) 12345 0 in
  let ok2 = assert_eq (r.1) 500 1 in
  let ok3 = assert_eq (r.2) 1 2 in
  if ok1 > 0 then (if ok2 > 0 then (if ok3 > 0 then 1 else 0 - 1) else 0 - 1) else 0 - 1

-- Test: doc_exists with version > 0
let test_doc_exists_yes : Int [cost: Const(3)] =
  assert_eq (doc_exists 1) 1 0

-- Test: doc_exists with version 0
let test_doc_exists_no : Int [cost: Const(3)] =
  assert_eq (doc_exists 0) 0 0

-- Test: doc_update
let test_doc_update : Int [cost: Const(5)] =
  let r = doc_update 12345 1 600 in
  let ok1 = assert_eq (r.0) 12345 0 in
  let ok2 = assert_eq (r.1) 600 1 in
  let ok3 = assert_eq (r.2) 2 2 in
  if ok1 > 0 then (if ok2 > 0 then (if ok3 > 0 then 1 else 0 - 1) else 0 - 1) else 0 - 1

-- Test: is_valid_version ascending
let test_doc_valid_version : Int [cost: Const(3)] =
  assert_eq (is_valid_version 1 2) 1 0

-- Test: is_valid_version not ascending
let test_doc_invalid_version : Int [cost: Const(3)] =
  assert_eq (is_valid_version 3 2) 0 0

-- Test: can_open_document under limit
let test_doc_can_open : Int [cost: Const(3)] =
  assert_eq (can_open_document 100) 1 0

-- Test: can_open_document over limit
let test_doc_cannot_open : Int [cost: Const(3)] =
  assert_eq (can_open_document 10000) 0 0

-- Test: document_line_count
let test_doc_line_count : Int [cost: Const(3)] =
  assert_eq (document_line_count 1000 50) 51 0
