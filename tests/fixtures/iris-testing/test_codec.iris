-- Tests for codec programs: gin_encoder pure functions
-- Note: Tests requiring graph intrinsics (graph_new, extract_features, etc.)
-- need the bootstrap evaluator and are covered by Rust-level test suites.
-- depends: programs/codec/gin_encoder.iris

-- =========================================================================
-- gin_encoder.iris pure function tests
-- =========================================================================

-- Test: relu positive passthrough
let test_gin_relu_positive : Int [cost: Const(3)] =
  assert_eq (relu 42) 42 0

-- Test: relu zero
let test_gin_relu_zero : Int [cost: Const(3)] =
  assert_eq (relu 0) 0 0

-- Test: relu negative -> 0
let test_gin_relu_negative : Int [cost: Const(3)] =
  assert_eq (relu (0 - 5)) 0 0

-- Test: relu large positive
let test_gin_relu_large : Int [cost: Const(3)] =
  assert_eq (relu 1000000) 1000000 0

-- Test: relu large negative
let test_gin_relu_large_neg : Int [cost: Const(3)] =
  assert_eq (relu (0 - 1000000)) 0 0

-- Test: pool_sum adds elements
let test_gin_pool_sum : Int [cost: Unknown] =
  assert_eq (pool_sum (1, 2, 3)) 6 0

-- Test: pool_sum single element
let test_gin_pool_sum_single : Int [cost: Unknown] =
  assert_eq (pool_sum (42,)) 42 0

-- Test: pool_max finds maximum
let test_gin_pool_max : Int [cost: Unknown] =
  assert_eq (pool_max (3, 7, 2, 9, 1)) 9 0

-- Test: pool_max single element
let test_gin_pool_max_single : Int [cost: Unknown] =
  assert_eq (pool_max (42,)) 42 0

-- Test: pool_max with negatives
let test_gin_pool_max_negative : Int [cost: Unknown] =
  assert_eq (pool_max (0 - 5, 0 - 1, 0 - 10)) (0 - 1) 0

-- Test: dense_relu computes weighted sum + bias through relu
let test_gin_dense_relu : Int [cost: Unknown] =
  let result = dense_relu (2, 3) (10, 20) 5 in
  -- weights=(2,3), input=(10,20) -> 2*10 + 3*20 = 80, + bias 5 = 85, relu = 85
  assert_eq result 85 0

-- Test: dense_relu negative result -> 0
let test_gin_dense_relu_neg : Int [cost: Unknown] =
  let result = dense_relu (1,) (0 - 10,) 5 in
  -- 1*(-10) + 5 = -5, relu -> 0
  assert_eq result 0 0

-- Test: dense_linear no relu
let test_gin_dense_linear : Int [cost: Unknown] =
  let result = dense_linear (2, 3) (10, 20) 5 in
  assert_eq result 85 0

-- Test: dense_linear negative result preserved
let test_gin_dense_linear_neg : Int [cost: Unknown] =
  let result = dense_linear (1,) (0 - 10,) 5 in
  assert_eq result (0 - 5) 0

-- Test: gin_aggregate with epsilon = 0
let test_gin_aggregate_eps0 : Int [cost: Unknown] =
  let result = gin_aggregate 10 (20, 30) 0 in
  -- self_feat=10, sum(neighbors)=50, (1+0)*10 + 50 = 60
  assert_eq result 60 0

-- Test: gin_aggregate with epsilon = 100 (representing 1.0)
let test_gin_aggregate_eps100 : Int [cost: Unknown] =
  let result = gin_aggregate 10 (20, 30) 100 in
  -- (100+100)*10/100 = 20, + 50 = 70
  assert_eq result 70 0
