-- proof.iris tests
-- =========================================================================

-- Test: classify_verify_tier no quantifiers, no bounds, no extern
let test_proof_tier_0 : Int [cost: Const(3)] =
  assert_eq (classify_verify_tier 0 0 0) 0 0

-- Test: classify_verify_tier quantifiers + bounded
let test_proof_tier_1 : Int [cost: Const(3)] =
  assert_eq (classify_verify_tier 1 1 0) 1 0

-- Test: classify_verify_tier external
let test_proof_tier_3 : Int [cost: Const(3)] =
  assert_eq (classify_verify_tier 0 0 1) 3 0

-- Test: tier_time_limit for tier 0
let test_proof_tier_time_0 : Int [cost: Const(3)] =
  assert_eq (tier_time_limit 0) 10 0

-- Test: tier_time_limit for tier 2
let test_proof_tier_time_2 : Int [cost: Const(3)] =
  assert_eq (tier_time_limit 2) 60000 0

-- Test: validate_proof_receipt valid
let test_proof_receipt_valid : Int [cost: Const(3)] =
  assert_eq (validate_proof_receipt 1 100 5) 1 0

-- Test: validate_proof_receipt invalid
let test_proof_receipt_invalid : Int [cost: Const(3)] =
  assert_eq (validate_proof_receipt 5 100 5) 0 0

-- =========================================================================
-- guard.iris tests
-- =========================================================================

-- Test: is_valid_error_bound for exact (0)
let test_guard_valid_error_exact : Int [cost: Const(3)] =
  assert_eq (is_valid_error_bound 0) 1 0

-- Test: is_valid_error_bound for unverified (3)
let test_guard_valid_error_unverified : Int [cost: Const(3)] =
  assert_eq (is_valid_error_bound 3) 1 0

-- Test: is_valid_error_bound for out of range (4)
let test_guard_invalid_error : Int [cost: Const(3)] =
  assert_eq (is_valid_error_bound 4) 0 0

-- Test: validate_statistical good confidence
let test_guard_statistical_good : Int [cost: Const(3)] =
  assert_eq (validate_statistical 950 10) 1 0

-- Test: validate_statistical bad confidence
let test_guard_statistical_bad : Int [cost: Const(3)] =
  assert_eq (validate_statistical 1001 10) 0 0

-- Test: compare_error_bounds ordering
let test_guard_compare_bounds : Int [cost: Const(3)] =
  let ok1 = assert_eq (compare_error_bounds 0 3) (0 - 1) 0 in
  let ok2 = assert_eq (compare_error_bounds 2 2) 0 1 in
  if ok1 > 0 then (if ok2 > 0 then 1 else 0 - 1) else 0 - 1

