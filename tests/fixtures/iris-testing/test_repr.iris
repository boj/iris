-- Test: classify_eval_tier A (small, no effects, no recursion)
let test_eval_tier_a : Int [cost: Const(3)] =
  assert_eq (classify_eval_tier 10 0 0) 0 0

-- Test: classify_eval_tier B (medium complexity)
let test_eval_tier_b : Int [cost: Const(3)] =
  assert_eq (classify_eval_tier 30 0 0) 1 0

-- Test: classify_eval_tier C (has effects)
let test_eval_tier_c : Int [cost: Const(3)] =
  assert_eq (classify_eval_tier 10 1 0) 2 0

-- Test: tier_test_count for tier A
let test_eval_tier_test_count_a : Int [cost: Const(3)] =
  assert_eq (tier_test_count 0) 10 0

-- Test: tier_test_count for tier B
let test_eval_tier_test_count_b : Int [cost: Const(3)] =
  assert_eq (tier_test_count 1) 100 0

-- Test: compute_ipc
let test_eval_compute_ipc : Int [cost: Const(3)] =
  assert_eq (compute_ipc 3000 1000) 3000 0

-- Test: compute_ipc zero cycles
let test_eval_compute_ipc_zero : Int [cost: Const(3)] =
  assert_eq (compute_ipc 0 0) 0 0

-- Test: is_valid_value_type for Int (tag 0)
let test_eval_valid_value_type : Int [cost: Const(3)] =
  assert_eq (is_valid_value_type 0) 1 0

-- Test: is_valid_value_type for thunk (tag 14)
let test_eval_valid_value_type_max : Int [cost: Const(3)] =
  assert_eq (is_valid_value_type 14) 1 0

-- Test: is_valid_value_type for out-of-range
let test_eval_invalid_value_type : Int [cost: Const(3)] =
  assert_eq (is_valid_value_type 15) 0 0

